function Trig_ReekWalkb_Func002Func013Func005Func009A takes nothing returns nothing
    set udg_CenterPoint = GetUnitLoc(udg_Caster)
    set udg_TargetPoint = GetUnitLoc(GetEnumUnit())
    set udg_Knockback2DAngle = AngleBetweenPoints(udg_CenterPoint, udg_TargetPoint)
    call RemoveLocation(udg_CenterPoint)
    call RemoveLocation(udg_TargetPoint)
    set udg_Knockback2DTime = 0.70
    set udg_Knockback2DDistance = 200.00
    set udg_Knockback2DUnit = GetEnumUnit()
    call TriggerExecute( gg_trg_Knockback_2D )
endfunction

function Trig_ReekWalkb_Func002Func013Func005A takes nothing returns nothing
    call CreateNUnitsAtLoc( 1, 'h005', GetOwningPlayer(udg_Caster), udg_Points[2], bj_UNIT_FACING )
    call UnitApplyTimedLifeBJ( 2.00, 'BTLF', GetLastCreatedUnit() )
    call UnitAddAbilityBJ( 'A02W', GetLastCreatedUnit() )
    call IssueTargetOrderBJ( GetLastCreatedUnit(), "slow", GetEnumUnit() )
    call UnitDamageTargetBJ( udg_Caster, GetEnumUnit(), 330.00, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL )
    call AddSpecialEffectTargetUnitBJ( "chest", GetEnumUnit(), "Abilities\\Spells\\Other\\CrushingWave\\CrushingWaveDamage.mdl" )
    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
    set bj_wantDestroyGroup = true
    call ForGroupBJ( udg_Enemies, function Trig_ReekWalkb_Func002Func013Func005Func009A )
endfunction

function Trig_ReekWalkb_Func002Func014C takes nothing returns boolean
    if ( not ( udg_Real[1] >= 0.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_ReekWalkb_Func002A takes nothing returns nothing
    set udg_Caster = GetEnumUnit()
    set udg_Real[1] = LoadRealBJ(StringHashBJ("R_Distance"), GetHandleIdBJ(GetEnumUnit()), udg_Int_Cataclysm_Hashtable)
    set udg_Real[1] = ( udg_Real[1] - 56.00 )
    set udg_Real[2] = LoadRealBJ(StringHashBJ("R_Distance_T"), GetHandleIdBJ(GetEnumUnit()), udg_Int_Cataclysm_Hashtable)
    set udg_Real[3] = LoadRealBJ(StringHashBJ("R_OneHundred"), GetHandleIdBJ(GetEnumUnit()), udg_Int_Cataclysm_Hashtable)
    if ( Trig_ReekWalkb_Func002Func006001() ) then
        set udg_Real[3] = ( udg_Real[3] + 16.00 )
    else
        set udg_Real[3] = ( udg_Real[3] - 16.00 )
    endif
    set udg_Real[4] = LoadRealBJ(StringHashBJ("R_Angle"), GetHandleIdBJ(GetEnumUnit()), udg_Int_Cataclysm_Hashtable)
    set udg_Real[5] = LoadRealBJ(StringHashBJ("R_Damage"), GetHandleIdBJ(GetEnumUnit()), udg_Int_Cataclysm_Hashtable)
    set udg_Points[1] = GetUnitLoc(udg_Caster)
    set udg_Points[2] = PolarProjectionBJ(udg_Points[1], udg_Real[3], ( udg_Real[4] - 90.00 ))
    set udg_Points[3] = PolarProjectionBJ(udg_Points[1], udg_Real[3], ( udg_Real[4] + 90.00 ))
    set udg_Integer1[1] = 2
    set bj_forLoopAIndex = 1
    set bj_forLoopAIndexEnd = 2
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        call AddSpecialEffectLocBJ( udg_Points[udg_Integer1[1]], "Objects\\Spawnmodels\\Naga\\NagaDeath\\NagaDeath.mdl" )
        call DestroyEffectBJ( GetLastCreatedEffectBJ() )
        set udg_Enemies = GetUnitsInRangeOfLocMatching(125.00, udg_Points[udg_Integer1[1]], Condition(function Trig_ReekWalkb_Func002Func013Func003002003))
        set bj_wantDestroyGroup = true
        call ForGroupBJ( udg_Enemies, function Trig_ReekWalkb_Func002Func013Func005A )
        call DestroyGroup(udg_Enemies)
        set udg_Integer1[1] = ( udg_Integer1[1] + 1 )
        set bj_forLoopAIndex = bj_forLoopAIndex + 1
    endloop
    if ( Trig_ReekWalkb_Func002Func014C() ) then
        set udg_Points[4] = PolarProjectionBJ(udg_Points[1], 56.00, udg_Real[4])
        call SetUnitX(udg_Caster,GetLocationX(udg_Points[4]))
        call SetUnitY(udg_Caster,GetLocationY(udg_Points[4]))
        call SaveRealBJ( udg_Real[1], StringHashBJ("R_Distance"), GetHandleIdBJ(GetEnumUnit()), udg_Int_Cataclysm_Hashtable )
        call SaveRealBJ( udg_Real[3], StringHashBJ("R_OneHundred"), GetHandleIdBJ(GetEnumUnit()), udg_Int_Cataclysm_Hashtable )
        call RemoveLocation(udg_Points[4])
    else
        call FlushChildHashtableBJ( GetHandleIdBJ(GetEnumUnit()), udg_Repel_Hash )
        call SetUnitVertexColorBJ( udg_Caster, 100, 100, 100, 0.00 )
        call SetUnitScalePercent( udg_Caster, 100.00, 100.00, 100.00 )
        call SetUnitPathing( udg_Caster, true )
        call GroupRemoveUnitSimple( GetEnumUnit(), udg_Tides )
    endif
    call RemoveLocation(udg_Points[1])
    call RemoveLocation(udg_Points[2])
    call RemoveLocation(udg_Points[3])
endfunction

function Trig_ReekWalkb_Func003001 takes nothing returns boolean
    return ( IsUnitGroupEmptyBJ(udg_Tides) == true )
endfunction

function Trig_ReekWalkb_Actions takes nothing returns nothing
    set bj_wantDestroyGroup = true
    call ForGroupBJ( udg_Tides, function Trig_ReekWalkb_Func002A )
    if ( Trig_ReekWalkb_Func003001() ) then
        call DisableTrigger( GetTriggeringTrigger() )
    else
        call DoNothing(  )
    endif
endfunction

