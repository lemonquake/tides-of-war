//===========================================================================
function Trig_Drag_Func001Func001Func001Func001Func001Func001C takes nothing returns boolean
    if ( ( udg_EC_Power[udg_EC] <= 0.00 ) ) then
        return true
    endif
    if ( ( udg_EC_Fly[udg_EC] <= 0.00 ) ) then
        return true
    endif
    if ( ( IsUnitDeadBJ(udg_EC_Target[udg_EC]) == true ) ) then
        return true
    endif
    if ( ( IsUnitDeadBJ(udg_EC_Dummy1[udg_EC_Times]) == true ) ) then
        return true
    endif
