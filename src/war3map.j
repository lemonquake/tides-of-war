function Trig_PS_Trigger_Func001C takes nothing returns boolean
    if ( not ( udg_PS_Integers[1] == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_PS_Trigger_Actions takes nothing returns nothing
    if ( Trig_PS_Trigger_Func001C() ) then
        call EnableTrigger( gg_trg_PS_Loop )
    else
    endif
    set udg_PS_Integers[1] = ( udg_PS_Integers[1] + 1 )
    set udg_PS_Integers[2] = ( udg_PS_Integers[2] + 1 )
    set udg_PS_Trees_Destroy[udg_PS_Integers[2]] = udg_PS2_Destroy_Trees_Dash
    set udg_PS_Destroy_Trees_Sfx[udg_PS_Integers[2]] = udg_PS2_Destroy_Trees_Sfx
    set udg_PS_Caster[udg_PS_Integers[2]] = udg_PS2_Caster
    set udg_PS_Caster_Sfx[udg_PS_Integers[2]] = udg_PS2_Caster_Sfx
    set udg_PS_Target_Sfx[udg_PS_Integers[2]] = udg_PS2_Target_Sfx
    set udg_PS_Heal[udg_PS_Integers[2]] = udg_PS2_Heal
    set udg_PS_Damage[udg_PS_Integers[2]] = udg_PS2_Damage
    set udg_PS_Damage_Interval[udg_PS_Integers[2]] = udg_PS2_Damage_Interval
    set udg_PS_Damage_Interval_Reached[udg_PS_Integers[2]] = udg_PS2_Damage_Interval_Reached
    set udg_PS_Damage_Count[udg_PS_Integers[2]] = udg_PS2_Damage_Count
    set udg_PS_Damage_Count_Released[udg_PS_Integers[2]] = udg_PS2_Damage_Count_Released
    set udg_PS_Damage_Sfx[udg_PS_Integers[2]] = udg_PS2_Damage_Sfx
    set udg_PS_Damage_AoE[udg_PS_Integers[2]] = udg_PS2_Damage_AoE
    call GroupAddUnitSimple( udg_PS2_Caster, udg_PS_Group )
endfunction

