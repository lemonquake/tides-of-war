    call CreateTextTagUnitBJ( ( udg_PlayerColors[GetConvertedPlayerId(GetOwningPlayer(udg_GDD_DamageSource))] + ( "35|r + " + I2S(R2I(( 0.02 * GetUnitStateSwap(UNIT_STATE_MAX_LIFE, udg_GDD_DamagedUnit) ))) ) ), udg_GDD_DamagedUnit, 0.00, 8.50, 100.00, 100.00, 100.00, 0 )
