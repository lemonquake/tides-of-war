//===========================================================================
// Trigger: RW
//===========================================================================
function Trig_RW_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A06O' ) ) then
        return false
    endif
    return true
endfunction

function Trig_RW_Func005001003001 takes nothing returns boolean
    return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_STRUCTURE) == false )
endfunction

function Trig_RW_Func005001003002001 takes nothing returns boolean
    return ( IsUnitAliveBJ(GetFilterUnit()) == true )
endfunction

function Trig_RW_Func005001003002002001 takes nothing returns boolean
    return ( GetUnitAbilityLevelSwapped('A00A', GetFilterUnit()) < 1 )
endfunction

function Trig_RW_Func005001003002002002 takes nothing returns boolean
    return ( IsUnitEnemy(GetFilterUnit(), GetOwningPlayer(GetTriggerUnit())) == true )
endfunction

function Trig_RW_Func005001003002002 takes nothing returns boolean
    return GetBooleanAnd( Trig_RW_Func005001003002002001(), Trig_RW_Func005001003002002002() )
endfunction

function Trig_RW_Func005001003002 takes nothing returns boolean
    return GetBooleanAnd( Trig_RW_Func005001003002001(), Trig_RW_Func005001003002002() )
endfunction

function Trig_RW_Func005001003 takes nothing returns boolean
    return GetBooleanAnd( Trig_RW_Func005001003001(), Trig_RW_Func005001003002() )
endfunction

function Trig_RW_Func005A takes nothing returns nothing
    call UnitDamageTargetBJ( GetTriggerUnit(), GetEnumUnit(), 150.00, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL )
    call AddSpecialEffectTargetUnitBJ( "origin", GetEnumUnit(), "Objects\\Spawnmodels\\Naga\\NagaDeath\\NagaDeath.mdl" )
    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
    set udg_KBA_Caster = GetTriggerUnit()
    set udg_KBA_TargetUnit = GetEnumUnit()
    set udg_KBA_Level = 1
    set udg_KBA_StartingPosition = GetUnitLoc(udg_KBA_Caster)
    set udg_KBA_Speed = 7.00
    set udg_KBA_DistancePerLevel = 275.00
    set udg_KBA_SpecialEffects[1] = "Abilities\\Spells\\Other\\CrushingWave\\CrushingWaveDamage.mdl"
