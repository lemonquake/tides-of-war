//===========================================================================
function Trig_Deal_DOT_Func001Func001Func001Func002Func004001002001 takes nothing returns boolean
    return ( GetUnitTypeId(GetFilterUnit()) == 'htow' )
endfunction

function Trig_Deal_DOT_Func001Func001Func001Func002Func004001002002 takes nothing returns boolean
    return ( GetOwningPlayer(GetFilterUnit()) == GetOwningPlayer(udg_DT_Dealers[udg_DT_Integers[3]]) )
endfunction

function Trig_Deal_DOT_Func001Func001Func001Func002Func004001002 takes nothing returns boolean
    return GetBooleanAnd( Trig_Deal_DOT_Func001Func001Func001Func002Func004001002001(), Trig_Deal_DOT_Func001Func001Func001Func002Func004001002002() )
endfunction

function Trig_Deal_DOT_Func001Func001Func001Func002Func004A takes nothing returns nothing
    call UnitDamageTargetBJ( GetEnumUnit(), udg_DT_Targets[udg_DT_Integers[3]], udg_DT_DamagePerInterval[udg_DT_Integers[3]], udg_DT_Attacktype[udg_DT_Integers[3]], udg_DT_DamageTypes[udg_DT_Integers[3]] )
endfunction

function Trig_Deal_DOT_Func001Func001Func001Func002Func005Func005C takes nothing returns boolean
    if ( not ( udg_DT_Integers[1] == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Deal_DOT_Func001Func001Func001Func002Func005C takes nothing returns boolean
    if ( not ( udg_DT_ReachedDamage[udg_DT_Integers[3]] >= udg_DT_Damage[udg_DT_Integers[3]] ) ) then
        return false
    endif
    return true
endfunction

function Trig_Deal_DOT_Func001Func001Func001Func002C takes nothing returns boolean
    if ( not ( udg_DT_ReachedInterval[udg_DT_Integers[3]] >= udg_DT_IntervalReals[udg_DT_Integers[3]] ) ) then
        return false
    endif
    return true
endfunction

function Trig_Deal_DOT_Func001Func001Func001Func007C takes nothing returns boolean
    if ( not ( udg_DT_Integers[1] == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Deal_DOT_Func001Func001Func001C takes nothing returns boolean
    if ( not ( IsUnitDeadBJ(udg_DT_Targets[udg_DT_Integers[3]]) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Deal_DOT_Func001Func001C takes nothing returns boolean
    if ( not ( udg_DT_Targets[udg_DT_Integers[3]] != null ) ) then
        return false
    endif
    return true
endfunction

function Trig_Deal_DOT_Actions takes nothing returns nothing
    set udg_DT_Integers[3] = 1
    loop
        exitwhen udg_DT_Integers[3] > udg_DT_Integers[2]
        if ( Trig_Deal_DOT_Func001Func001C() ) then
            if ( Trig_Deal_DOT_Func001Func001Func001C() ) then
                set udg_DT_ReachedInterval[udg_DT_Integers[3]] = 0.00
                set udg_DT_ReachedDamage[udg_DT_Integers[3]] = 0.00
                call DestroyEffectBJ( udg_DT_Effects[udg_DT_Integers[3]] )
                set udg_DT_Targets[udg_DT_Integers[3]] = null
                set udg_DT_Integers[1] = ( udg_DT_Integers[1] - 1 )
                if ( Trig_Deal_DOT_Func001Func001Func001Func007C() ) then
                    set udg_DT_Integers[2] = 0
                    call DisableTrigger( GetTriggeringTrigger() )
                else
                endif
            else
                if ( Trig_Deal_DOT_Func001Func001Func001Func002C() ) then
                    set udg_DT_ReachedInterval[udg_DT_Integers[3]] = 0.00
                    set udg_DT_ReachedDamage[udg_DT_Integers[3]] = ( udg_DT_ReachedDamage[udg_DT_Integers[3]] + udg_DT_DamagePerInterval[udg_DT_Integers[3]] )
                    set bj_wantDestroyGroup = true
                    call ForGroupBJ( GetUnitsInRectMatching(gg_rct_hitman, Condition(function Trig_Deal_DOT_Func001Func001Func001Func002Func004001002)), function Trig_Deal_DOT_Func001Func001Func001Func002Func004A )
                    if ( Trig_Deal_DOT_Func001Func001Func001Func002Func005C() ) then
                        set udg_DT_ReachedDamage[udg_DT_Integers[3]] = 0.00
                        call DestroyEffectBJ( udg_DT_Effects[udg_DT_Integers[3]] )
                        set udg_DT_Targets[udg_DT_Integers[3]] = null
                        set udg_DT_Integers[1] = ( udg_DT_Integers[1] - 1 )
                        if ( Trig_Deal_DOT_Func001Func001Func001Func002Func005Func005C() ) then
                            set udg_DT_Integers[2] = 0
                            call DisableTrigger( GetTriggeringTrigger() )
                        else
                        endif
                    else
                    endif
                else
                    set udg_DT_ReachedInterval[udg_DT_Integers[3]] = ( udg_DT_ReachedInterval[udg_DT_Integers[3]] + 1.00 )
                endif
            endif
        else
        endif
        set udg_DT_Integers[3] = udg_DT_Integers[3] + 1
    endloop
endfunction

