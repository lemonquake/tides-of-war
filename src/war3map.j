function InitTrig_Blessing takes nothing returns nothing
    set gg_trg_Blessing = CreateTrigger(  )
    call TriggerRegisterVariableEvent( gg_trg_Blessing, "udg_GDD_Event", EQUAL, 1.00 )
    call TriggerAddCondition( gg_trg_Blessing, Condition( function Trig_Blessing_Conditions ) )
    call TriggerAddAction( gg_trg_Blessing, function Trig_Blessing_Actions )
endfunction

