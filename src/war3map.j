//===========================================================================
function Trig_Knockback_Effects_Func008Func005C takes nothing returns boolean
    if ( not ( IsUnitType(udg_UDexUnits[udg_UDex], UNIT_TYPE_FLYING) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_Knockback_Effects_Func008C takes nothing returns boolean
    if ( not ( 0 == GetRandomInt(0, udg_K2DFX) ) ) then
        return false
    endif
    return true
endfunction

function Trig_Knockback_Effects_Actions takes nothing returns nothing
    set udg_K2DFXModel = "Objects\\Spawnmodels\\Undead\\ImpaleTargetDust\\ImpaleTargetDust.mdl"
    call Preload( udg_K2DFXModel )
        call ExecuteFunc("InitKnockbackFX")
    endfunction
    function KnockbackFXLooper takes nothing returns boolean
    if ( Trig_Knockback_Effects_Func008C() ) then
        set udg_K2DFX = GetRandomInt(4, 8)
        set udg_UDex = udg_K2DNext[0]
        loop
            exitwhen udg_UDex == 0
        if ( Trig_Knockback_Effects_Func008Func005C() ) then
            call DestroyEffect(AddSpecialEffect(udg_K2DFXModel, GetUnitX(udg_UDexUnits[udg_UDex]), GetUnitY(udg_UDexUnits[udg_UDex])))
        else
        endif
        set udg_UDex = udg_K2DNext[udg_UDex]
        endloop
    else
        set udg_K2DFX = ( udg_K2DFX - 1 )
    endif
        return false
    endfunction
    function InitKnockbackFX takes nothing returns nothing
        call TriggerAddCondition(GetTriggeringTrigger(), Filter(function KnockbackFXLooper))
endfunction

