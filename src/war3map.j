function Trig_friendly_fire_Func001C takes nothing returns boolean
    if ( not ( IsUnitAlly(GetAttacker(), GetOwningPlayer(GetAttackedUnitBJ())) == true ) ) then
        return false
    endif
    if ( not ( GetUnitLifePercent(GetAttackedUnitBJ()) >= 10.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_friendly_fire_Actions takes nothing returns nothing
    if ( Trig_friendly_fire_Func001C() ) then
        call IssueImmediateOrderBJ( GetAttacker(), "stop" )
    else
    endif
endfunction

