    set gg_trg_Diffuse = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_Diffuse, EVENT_PLAYER_UNIT_DEATH )
    call TriggerAddCondition( gg_trg_Diffuse, Condition( function Trig_Diffuse_Conditions ) )
    call TriggerAddAction( gg_trg_Diffuse, function Trig_Diffuse_Actions )
