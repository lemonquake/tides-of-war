//===========================================================================
// Trigger: AoT
//===========================================================================
function Trig_AoT_Func002C takes nothing returns boolean
    if ( not ( udg_GDD_Damage > 0.00 ) ) then
        return false
    endif
    if ( not ( UnitHasBuffBJ(udg_GDD_DamagedUnit, 'B01E') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_AoT_Conditions takes nothing returns boolean
    if ( not Trig_AoT_Func002C() ) then
        return false
    endif
    return true
endfunction

function Trig_AoT_Func001Func001Func002001002001 takes nothing returns boolean
    return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_HERO) == true )
endfunction

function Trig_AoT_Func001Func001Func002001002002 takes nothing returns boolean
    return ( GetOwningPlayer(GetFilterUnit()) == GetOwningPlayer(udg_GDD_DamageSource) )
endfunction

function Trig_AoT_Func001Func001Func002001002 takes nothing returns boolean
    return GetBooleanAnd( Trig_AoT_Func001Func001Func002001002001(), Trig_AoT_Func001Func001Func002001002002() )
endfunction

function Trig_AoT_Func001Func001Func002A takes nothing returns nothing
    call UnitDamageTargetBJ( udg_GDD_DamagedUnit, GetEnumUnit(), udg_GDD_Damage, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_FIRE )
endfunction

function Trig_AoT_Func001Func001C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped('A00A', udg_GDD_DamageSource) > 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_AoT_Func001C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped('A00A', udg_GDD_DamageSource) < 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_AoT_Actions takes nothing returns nothing
    if ( Trig_AoT_Func001C() ) then
        call UnitDamageTargetBJ( udg_GDD_DamagedUnit, udg_GDD_DamageSource, udg_GDD_Damage, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_FIRE )
    else
        if ( Trig_AoT_Func001Func001C() ) then
            set bj_wantDestroyGroup = true
            call ForGroupBJ( GetUnitsInRectMatching(GetPlayableMapRect(), Condition(function Trig_AoT_Func001Func001Func002001002)), function Trig_AoT_Func001Func001Func002A )
        else
        endif
    endif
endfunction

//===========================================================================
function InitTrig_AoT takes nothing returns nothing
    set gg_trg_AoT = CreateTrigger(  )
    call TriggerRegisterVariableEvent( gg_trg_AoT, "udg_GDD_Event", EQUAL, 1.00 )
    call TriggerAddCondition( gg_trg_AoT, Condition( function Trig_AoT_Conditions ) )
    call TriggerAddAction( gg_trg_AoT, function Trig_AoT_Actions )
endfunction

//===========================================================================
// Trigger: Take Damage
//===========================================================================
function Trig_Take_Damage_Func001C takes nothing returns boolean
    if ( not ( udg_GDD_Damage > 0.00 ) ) then
        return false
    endif
    if ( not ( GetOwningPlayer(udg_GDD_DamageSource) != Player(PLAYER_NEUTRAL_AGGRESSIVE) ) ) then
        return false
    endif
    if ( not ( GetOwningPlayer(udg_GDD_DamageSource) != GetOwningPlayer(udg_GDD_DamagedUnit) ) ) then
        return false
    endif
    return true
endfunction

function Trig_Take_Damage_Conditions takes nothing returns boolean
    if ( not Trig_Take_Damage_Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_Take_Damage_Actions takes nothing returns nothing
    set udg_Combat_Index2 = ( udg_Combat_Index2 + 1 )
    set udg_Combat_Unit[udg_Combat_Index2] = udg_GDD_DamagedUnit
    set udg_Combat_Time[udg_Combat_Index2] = 2.00
    call ConditionalTriggerExecute( gg_trg_Combat_Check )
    set udg_Combat_Index2 = ( udg_Combat_Index2 + 1 )
    set udg_Combat_Unit[udg_Combat_Index2] = GetCancelledStructure()
    set udg_Combat_Time[udg_Combat_Index2] = 0.50
    call ConditionalTriggerExecute( gg_trg_Combat_Check )
endfunction

//===========================================================================
function InitTrig_Take_Damage takes nothing returns nothing
    set gg_trg_Take_Damage = CreateTrigger(  )
    call TriggerRegisterVariableEvent( gg_trg_Take_Damage, "udg_GDD_Event", EQUAL, 1.00 )
    call TriggerAddCondition( gg_trg_Take_Damage, Condition( function Trig_Take_Damage_Conditions ) )
    call TriggerAddAction( gg_trg_Take_Damage, function Trig_Take_Damage_Actions )
endfunction

//===========================================================================
// Trigger: Combat Check
//===========================================================================
function Trig_Combat_Check_Func002Func001C takes nothing returns boolean
    if ( not ( udg_Combat_Unit[udg_Combat_Index2] == udg_Combat_Unit[udg_Combat_Index3] ) ) then
        return false
    endif
    return true
endfunction

function Trig_Combat_Check_Func003Func005C takes nothing returns boolean
    if ( not ( udg_Combat_Index2 == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Combat_Check_Func003C takes nothing returns boolean
    if ( not ( udg_Combat_Found == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_Combat_Check_Actions takes nothing returns nothing
    set udg_Combat_Found = false
    set udg_Combat_Index3 = 1
    loop
        exitwhen udg_Combat_Index3 > ( udg_Combat_Index2 - 1 )
        if ( Trig_Combat_Check_Func002Func001C() ) then
            set udg_Combat_Time[udg_Combat_Index3] = 7.00
            set udg_Combat_Index2 = ( udg_Combat_Index2 - 1 )
            set udg_Combat_Found = true
        else
        endif
        set udg_Combat_Index3 = udg_Combat_Index3 + 1
    endloop
    if ( Trig_Combat_Check_Func003C() ) then
        call GroupAddUnitSimple( udg_Combat_Unit[udg_Combat_Index2], udg_Combat_Group )
        set udg_CombatState_Unit = udg_Combat_Unit[udg_Combat_Index2]
        set udg_Combat_Event = 1.00
        set udg_Combat_Event = 0.00
        if ( Trig_Combat_Check_Func003Func005C() ) then
            call EnableTrigger( gg_trg_Combat_Periodic )
        else
        endif
    else
    endif
endfunction

