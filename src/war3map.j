function Trig_Tentacles_Conditions takes nothing returns boolean
    if ( not ( GetUnitTypeId(udg_GDD_DamageSource) == 'o000' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Tentacles_Actions takes nothing returns nothing
    call UnitDamageTargetBJ( udg_GDD_DamageSource, udg_GDD_DamagedUnit, ( GetUnitStateSwap(UNIT_STATE_LIFE, GetAttackedUnitBJ()) / 17.00 ), ATTACK_TYPE_MELEE, DAMAGE_TYPE_ENHANCED )
endfunction

//===========================================================================
function InitTrig_Tentacles takes nothing returns nothing
    set gg_trg_Tentacles = CreateTrigger(  )
    call TriggerRegisterVariableEvent( gg_trg_Tentacles, "udg_GDD_Event", EQUAL, 1.00 )
