// Trigger: P2 Skill
//===========================================================================
function Trig_P2_Skill_Func001C takes nothing returns boolean
    if ( not ( GetPlayerController(Player(1)) == MAP_CONTROL_COMPUTER ) ) then
        return false
    endif
    if ( not ( GetUnitAbilityLevelSwapped('A00A', udg_GDD_DamageSource) < 1 ) ) then
        return false
    endif
    if ( not ( IsUnitType(udg_GDD_DamagedUnit, UNIT_TYPE_HERO) == true ) ) then
        return false
    endif
    if ( not ( GetOwningPlayer(udg_GDD_DamagedUnit) == Player(1) ) ) then
        return false
    endif
    return true
endfunction

function Trig_P2_Skill_Conditions takes nothing returns boolean
    if ( not Trig_P2_Skill_Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_P2_Skill_Func003C takes nothing returns boolean
    if ( not ( GetUnitLifePercent(udg_GDD_DamagedUnit) <= 40.00 ) ) then
        return false
    endif
    if ( not ( udg_AI_Skill == 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_P2_Skill_Func004Func001Func001C takes nothing returns boolean
    if ( not ( Eng_CountUnitsAt(GetUnitX(gg_unit_H002_0016), GetUnitY(gg_unit_H002_0016), 500.00) >= 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_P2_Skill_Func004Func001C takes nothing returns boolean
    if ( not ( udg_AI_Skill == 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_P2_Skill_Func004C takes nothing returns boolean
    if ( not ( udg_AI_Skill == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_P2_Skill_Actions takes nothing returns nothing
    set udg_AI_Skill = GetRandomInt(1, 3)
    if ( Trig_P2_Skill_Func003C() ) then
        call IssueImmediateOrderBJ( gg_unit_H002_0016, "stomp" )
        call TriggerSleepAction( GetRandomReal(0.20, 0.30) )
        set udg_TempPoint = PolarProjectionBJ(GetUnitLoc(gg_unit_H002_0016), 1000.00, GetRandomDirectionDeg())
        call UnitUseItemPointLoc( gg_unit_H002_0016, GetItemOfTypeFromUnitBJ(gg_unit_H002_0016, 'I000'), udg_TempPoint )
        call RemoveLocation(udg_TempPoint)
        call TriggerSleepAction( GetRandomReal(0.20, 0.30) )
        set udg_TempPoint = PolarProjectionBJ(GetUnitLoc(gg_unit_H002_0016), 400.00, GetUnitFacing(udg_GDD_DamageSource))
        call IssuePointOrderLocBJ( gg_unit_H002_0016, "move", udg_TempPoint )
        call RemoveLocation(udg_TempPoint)
    else
    endif
    if ( Trig_P2_Skill_Func004C() ) then
        call IssueTargetOrderBJ( gg_unit_H002_0016, "faeriefire", udg_GDD_DamageSource )
        call TriggerSleepAction( 0.30 )
        call IssueTargetOrderBJ( gg_unit_H002_0016, "attack", udg_GDD_DamageSource )
    else
        if ( Trig_P2_Skill_Func004Func001C() ) then
            if ( Trig_P2_Skill_Func004Func001Func001C() ) then
                call IssueImmediateOrderBJ( gg_unit_H002_0016, "stomp" )
                call TriggerSleepAction( 0.30 )
                call IssueTargetOrderBJ( gg_unit_H002_0016, "attack", udg_GDD_DamageSource )
            else
            endif
        else
        endif
    endif
endfunction

