function Trig_Leave_Func003Func001Func003A takes nothing returns nothing
    call SetPlayerUnitAvailableBJ( GetUnitTypeId(GetEnumUnit()), true, GetEnumPlayer() )
endfunction

function Trig_Leave_Func003Func001C takes nothing returns boolean
    if ( not ( GetOwningPlayer(GetEnumUnit()) == GetTriggerPlayer() ) ) then
        return false
    endif
    if ( not ( IsUnitType(GetEnumUnit(), UNIT_TYPE_HERO) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Leave_Func003A takes nothing returns nothing
    if ( Trig_Leave_Func003Func001C() ) then
        call RemoveUnit( GetEnumUnit() )
        set bj_wantDestroyGroup = true
        call ForForce( bj_FORCE_ALL_PLAYERS, function Trig_Leave_Func003Func001Func003A )
    else
    endif
endfunction

function Trig_Leave_Actions takes nothing returns nothing
    call DisplayTimedTextToForce( bj_FORCE_ALL_PLAYERS, 15.00, ( udg_Players_Name[GetConvertedPlayerId(GetTriggerPlayer())] + " has left teh Game ._. NO COOKIES FOR HIM ..l.." ) )
    set bj_wantDestroyGroup = true
    call ForGroupBJ( GetUnitsInRectAll(GetEntireMapRect()), function Trig_Leave_Func003A )
endfunction

