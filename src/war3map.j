//===========================================================================
// Trigger: Tidal Orbs AW
//===========================================================================
function Trig_Tidal_Orbs_AW_Func005Func001C takes nothing returns boolean
    if ( not ( udg_AW_Skip == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Tidal_Orbs_AW_Actions takes nothing returns nothing
    set udg_AW_Level = GetUnitAbilityLevelSwapped('A02U', GetSpellAbilityUnit())
    set udg_AW_Orbs_Howmuch = 10
    set udg_AW_Real_Decoy_Formulas[1] = ( 360.00 / I2R(udg_AW_Orbs_Howmuch) )
    set udg_AW_Real_Decoy_Formulas[2] = udg_AW_Real_Decoy_Formulas[1]
    set bj_forLoopAIndex = 1
    set bj_forLoopAIndexEnd = udg_AW_Orbs_Howmuch
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_Tidal_Orbs_AW_Func005Func001C() ) then
            call EnableTrigger( gg_trg_TO_AW_eff )
        else
        endif
        set udg_AW_Times = ( udg_AW_Times + 1 )
        set udg_AW_Skip = ( udg_AW_Skip + 1 )
        set udg_AW_Off[udg_AW_Times] = true
        set udg_AW_Damage[udg_AW_Times] = false
        set udg_AW_Caster[udg_AW_Times] = GetSpellAbilityUnit()
        set udg_AW_Point[0] = GetUnitLoc(udg_AW_Caster[udg_AW_Times])
        set udg_AW_SpinSpeed[udg_AW_Times] = 4.00
        set udg_AW_Distance_Attract_React[udg_AW_Times] = 50.00
        set udg_AW_Debug_Distance_Border[udg_AW_Times] = 1000.00
        set udg_AW_AttractionSpeed_ReactionS_P[udg_AW_Times] = 9.00
        set udg_AW_FallingSpeed[udg_AW_Times] = 10.00
        set udg_AW_DamageDone[udg_AW_Times] = ( 10.00 * I2R(udg_AW_Level) )
        set udg_AW_Damage_Time[udg_AW_Times] = 7
        set udg_AW_Duration_Effect = 10
        set udg_AW_Real_Damage_Time_Caa[udg_AW_Times] = 50
        set udg_AW_Steps[udg_AW_Times] = 0
        set udg_AW_AT_REA_Debug[udg_AW_Times] = 0
        set udg_AW_Real_Decoy_Formulas[3] = ( RMaxBJ(I2R(udg_AW_Duration_Effect), 0.02) / 0.02 )
        set udg_AW_ExpirationTime[udg_AW_Times] = R2I(udg_AW_Real_Decoy_Formulas[3])
        set udg_AW_Height[udg_AW_Times] = 1000.00
        set udg_AW_Point[1] = PolarProjectionBJ(udg_AW_Point[0], udg_AW_Distance_Attract_React[udg_AW_Times], udg_AW_Real_Decoy_Formulas[2])
        call CreateNUnitsAtLoc( 1, 'h00K', GetOwningPlayer(udg_AW_Caster[udg_AW_Times]), udg_AW_Point[1], bj_UNIT_FACING )
        call UnitApplyTimedLifeBJ( 12.00, 'BTLF', GetLastCreatedUnit() )
        set udg_AW_Dummy[udg_AW_Times] = GetLastCreatedUnit()
        call SetUnitFlyHeightBJ( udg_AW_Dummy[udg_AW_Times], udg_AW_Height[udg_AW_Times], 1000000000.00 )
        call AddSpecialEffectTargetUnitBJ( "chest", udg_AW_Dummy[udg_AW_Times], "Abilities\\Spells\\Items\\AIob\\AIobTarget.mdl" )
        set udg_AW_SpecialEffect1[udg_AW_Times] = GetLastCreatedEffectBJ()
        call AddSpecialEffectTargetUnitBJ( "chest", udg_AW_Dummy[udg_AW_Times], "Abilities\\Spells\\Undead\\AbsorbMana\\AbsorbManaBirthMissile.mdl" )
        set udg_AW_SpecialEffect2[udg_AW_Times] = GetLastCreatedEffectBJ()
        set udg_AW_Angle[udg_AW_Times] = AngleBetweenPoints(udg_AW_Point[0], udg_AW_Point[1])
        set udg_AW_StepLast[udg_AW_Times] = 0
        set udg_AW_Real_Decoy_Formulas[2] = ( udg_AW_Real_Decoy_Formulas[2] + udg_AW_Real_Decoy_Formulas[1] )
        call RemoveLocation(udg_AW_Point[0])
        call RemoveLocation(udg_AW_Point[1])
        set bj_forLoopAIndex = bj_forLoopAIndex + 1
    endloop
endfunction

