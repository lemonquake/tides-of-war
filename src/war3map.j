    call SetHeroLevelBJ( GetEnumUnit(), udg_Level_Set, false )
endfunction

function Trig_Duel_Mode_Dialog_Func001Func001C takes nothing returns boolean
    if ( not ( GetClickedButtonBJ() == udg_DIALOG_DUEL_NO ) ) then
        return false
    endif
    return true
endfunction

function Trig_Duel_Mode_Dialog_Func001Func006001002 takes nothing returns boolean
    return ( IsUnitType(GetEnumUnit(), UNIT_TYPE_HERO) == true )
endfunction

