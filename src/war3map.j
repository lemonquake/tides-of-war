    call KillUnit( LoadUnitHandleBJ(StringHashBJ("beacon"), GetHandleIdBJ(GetTriggerUnit()), udg_Int_Cataclysm_Hashtable) )
    call FlushChildHashtableBJ( GetHandleIdBJ(GetTriggerUnit()), udg_Int_Cataclysm_Hashtable )
endfunction

