function Trig_Repel_go_Func009C takes nothing returns boolean
    if ( not ( IsUnitGroupEmptyBJ(udg_Repeleds) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Repel_go_Actions takes nothing returns nothing
    set udg_Caster = GetTriggerUnit()
    set udg_Repel_Point[1] = GetUnitLoc(udg_Caster)
    set udg_Repel_Real[1] = 600.00
    call CreateNUnitsAtLoc( 1, 'hgry', GetOwningPlayer(udg_Caster), udg_Repel_Point[1], bj_UNIT_FACING )
    call SaveRealBJ( udg_Repel_Real[1], StringHashBJ("Repel_Real"), GetHandleIdBJ(GetLastCreatedUnit()), udg_Repel_Hash )
    call SaveUnitHandleBJ( udg_Caster, StringHashBJ("Repel_Caster"), GetHandleIdBJ(GetLastCreatedUnit()), udg_Repel_Hash )
    if ( Trig_Repel_go_Func009C() ) then
        call EnableTrigger( gg_trg_Repel_eff )
    else
    endif
    call GroupAddUnitSimple( GetLastCreatedUnit(), udg_Repeleds )
    call RemoveLocation(udg_Points[1])
        call RemoveLocation(udg_Repel_Point[1])
endfunction

