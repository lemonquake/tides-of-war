    set gg_trg_Create_Multiboard = CreateTrigger(  )
    call TriggerRegisterTimerEventSingle( gg_trg_Create_Multiboard, 10.00 )
    call TriggerAddAction( gg_trg_Create_Multiboard, function Trig_Create_Multiboard_Actions )
endfunction

