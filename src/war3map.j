    if ( not ( GetUnitAbilityLevelSwapped('A05T', udg_GDD_DamageSource) > 0 ) ) then
        return false
    endif
    if ( not ( udg_GDD_Damage > 0.00 ) ) then
        return false
    endif
    return true
