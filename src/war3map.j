    set gg_trg_BH = CreateTrigger(  )
    call TriggerRegisterVariableEvent( gg_trg_BH, "udg_GDD_Event", EQUAL, 1.00 )
    call TriggerAddCondition( gg_trg_BH, Condition( function Trig_BH_Conditions ) )
    call TriggerAddAction( gg_trg_BH, function Trig_BH_Actions )
endfunction

