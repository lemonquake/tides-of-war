function Trig_Warp_Ef_Func001Func001Func001Func002Func001C takes nothing returns boolean
    if ( not ( udg_GC_Check[udg_GC_Integers[2]] == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_Warp_Ef_Func001Func001Func001Func002Func002Func012002003001 takes nothing returns boolean
