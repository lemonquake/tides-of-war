function Trig_On_Move_Func001C takes nothing returns boolean
    if ( not ( IsUnitType(udg_UDexUnits[udg_UDex], UNIT_TYPE_HERO) == true ) ) then
        return false
    endif
    if ( not ( IsUnitInGroup(udg_UDexUnits[udg_UDex], udg_Combat_Group) == false ) ) then
        return false
    endif
    return true
endfunction

