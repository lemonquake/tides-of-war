function Trig_BH_Actions takes nothing returns nothing
    if ( Trig_BH_Func001C() ) then
        call CreateUnit(GetOwningPlayer(udg_GDD_DamageSource), 'h005', GetUnitX(udg_GDD_DamagedUnit), GetUnitY(udg_GDD_DamagedUnit), bj_UNIT_FACING)
        call UnitAddAbilityBJ( 'A06C', GetLastCreatedUnit() )
        call IssueTargetOrderBJ( GetLastCreatedUnit(), "acidbomb", udg_GDD_DamagedUnit )
        call UnitApplyTimedLifeBJ( 1.00, 'BTLF', GetLastCreatedUnit() )
    else
    endif
endfunction

