        return false
    endif
    return true
endfunction

function Trig_Diffuse_Func004001002001 takes nothing returns boolean
    return ( GetUnitTypeId(GetFilterUnit()) == 'hdhw' )
endfunction

function Trig_Diffuse_Func004001002002 takes nothing returns boolean
    return ( GetOwningPlayer(GetFilterUnit()) == GetOwningPlayer(GetTriggerUnit()) )
endfunction

function Trig_Diffuse_Func004001002 takes nothing returns boolean
    return GetBooleanAnd( Trig_Diffuse_Func004001002001(), Trig_Diffuse_Func004001002002() )
endfunction

function Trig_Diffuse_Func004A takes nothing returns nothing
    call SetUnitPosition(GetEnumUnit(), GetRectCenterX(gg_rct_hitman), GetRectCenterY(gg_rct_hitman))
    call UnitRemoveAbilityBJ( 'A07D', GetEnumUnit() )
    call RemoveUnit( GetEnumUnit() )
