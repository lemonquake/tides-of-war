function Trig_Angels_Conditions takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetTriggerUnit()) == 'h00I' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Angels_Func003Func001Func002001002001 takes nothing returns boolean
    return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_HERO) == true )
endfunction

function Trig_Angels_Func003Func001Func002001002002 takes nothing returns boolean
    return ( GetOwningPlayer(GetFilterUnit()) == GetOwningPlayer(GetTriggerUnit()) )
endfunction

function Trig_Angels_Func003Func001Func002001002 takes nothing returns boolean
    return GetBooleanAnd( Trig_Angels_Func003Func001Func002001002001(), Trig_Angels_Func003Func001Func002001002002() )
endfunction

function Trig_Angels_Func003Func001Func002A takes nothing returns nothing
    call UnitDamageTargetBJ( GetTriggerUnit(), GetKillingUnitBJ(), 100.00, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_FIRE )
endfunction

function Trig_Angels_Func003Func001C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped('A00A', GetKillingUnitBJ()) > 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Angels_Func003C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped('A00A', GetKillingUnitBJ()) < 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Angels_Actions takes nothing returns nothing
    call AddSpecialEffectTargetUnitBJ( "chest", GetKillingUnitBJ(), "war3mapImported\\LightStrikeArray.mdx" )
    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
    if ( Trig_Angels_Func003C() ) then
        call UnitDamageTargetBJ( GetTriggerUnit(), GetKillingUnitBJ(), 100.00, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_FIRE )
    else
        if ( Trig_Angels_Func003Func001C() ) then
            set bj_wantDestroyGroup = true
            call ForGroupBJ( GetUnitsInRectMatching(GetPlayableMapRect(), Condition(function Trig_Angels_Func003Func001Func002001002)), function Trig_Angels_Func003Func001Func002A )
        else
        endif
    endif
endfunction

