//===========================================================================
function Trig_Game_Func009001001 takes nothing returns boolean
    return ( GetFilterPlayer() != Player(0) )
endfunction

function Trig_Game_Func009A takes nothing returns nothing
    call CinematicModeBJ( true, GetForceOfPlayer(GetEnumPlayer()) )
    call TransmissionFromUnitTypeWithNameBJ( GetForceOfPlayer(GetEnumPlayer()), Player(0), 'Hblm', "TRIGSTR_2854", GetRectCenter(gg_rct_InitialView), null, "TRIGSTR_2855", bj_TIMETYPE_ADD, 0.00, false )
endfunction

function Trig_Game_Func011A takes nothing returns nothing
    set udg_Kill_P = GetConvertedPlayerId(GetEnumPlayer())
    set udg_Kill_Limit[udg_Kill_P] = 50
    call SetPlayerFlagBJ( PLAYER_STATE_GIVES_BOUNTY, true, GetEnumPlayer() )
    call SetPlayerStateBJ( GetEnumPlayer(), PLAYER_STATE_RESOURCE_GOLD, 700 )
    call PanCameraToTimedForPlayer(GetEnumPlayer(), GetRectCenterX(gg_rct_InitialView), GetRectCenterY(gg_rct_InitialView), 0)
    call CreateFogModifierRectBJ( true, GetEnumPlayer(), FOG_OF_WAR_VISIBLE, gg_rct_InitialView )
endfunction

function Trig_Game_Actions takes nothing returns nothing
    local force tempForce = null
    call EnableDawnDusk( false )
    call StopMusicBJ( false )
    call CreateQuestBJ( bj_QUESTTYPE_REQ_DISCOVERED, "TRIGSTR_2846", "TRIGSTR_2847", "ReplaceableTextures\\CommandButtons\\BTNAmbush.blp" )
    call CreateQuestBJ( bj_QUESTTYPE_REQ_DISCOVERED, "TRIGSTR_2848", "TRIGSTR_2849", "ReplaceableTextures\\CommandButtons\\BTNAmbush.blp" )
    call CreateQuestBJ( bj_QUESTTYPE_REQ_DISCOVERED, "TRIGSTR_2850", "TRIGSTR_2851", "ReplaceableTextures\\CommandButtons\\BTNAmbush.blp" )
    call CreateQuestBJ( bj_QUESTTYPE_REQ_DISCOVERED, "TRIGSTR_2852", "TRIGSTR_2853", "ReplaceableTextures\\CommandButtons\\BTNAmbush.blp" )
    call CreateQuestBJ( bj_QUESTTYPE_REQ_DISCOVERED, "TRIGSTR_3503", "TRIGSTR_3504", "ReplaceableTextures\\CommandButtons\\BTNAmbush.blp" )
    set bj_wantDestroyGroup = true
    set tempForce = GetPlayersMatching(Condition(function Trig_Game_Func009001001))
    call ForForce(tempForce, function Trig_Game_Func009A)
    call DestroyForce(tempForce)
    set tempForce = null
    set bj_wantDestroyGroup = true
    call ForForce( bj_FORCE_ALL_PLAYERS, function Trig_Game_Func011A )
    call InitHashtableBJ(  )
    set udg_Hashtable = GetLastCreatedHashtableBJ()
    set udg_Fissure = 'A1es'
endfunction

