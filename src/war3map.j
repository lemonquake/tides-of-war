function RunInitializationTriggers takes nothing returns nothing
    call ConditionalTriggerExecute( gg_trg_Initialization )
    call ConditionalTriggerExecute( gg_trg_Toss_Rock_in )
    call ConditionalTriggerExecute( gg_trg_Init_Trigger )
    call ConditionalTriggerExecute( gg_trg_INTIALIZATION )
    call ConditionalTriggerExecute( gg_trg_Knockback_2D )
    call ConditionalTriggerExecute( gg_trg_Knockback_Effects )
    call ConditionalTriggerExecute( gg_trg_Configuration )
    call ConditionalTriggerExecute( gg_trg_Unit_Indexer )
endfunction

