function Trig_Unit_Event_Actions takes nothing returns nothing
    if udg_DEvAbility == 0 then
    set udg_DEvAbility = 'A06F'
        call ExecuteFunc("InitDeathEvent")
    endif
    if ( Trig_Unit_Event_Func005C() ) then
        call UnitAddAbilityBJ( udg_DEvAbility, udg_UDexUnits[udg_UDex] )
        call UnitMakeAbilityPermanent(udg_UDexUnits[udg_UDex], true, udg_DEvAbility)
        set udg_DEvBlock[udg_UDex] = true
        set udg_IsUnitAlive[udg_UDex] = true
        call ExecuteFunc("DEvCheckDeathProxy")
    else
        set udg_IsUnitAlive[udg_UDex] = false
        set udg_IsUnitReincarnating[udg_UDex] = false
        set udg_DEvRemoved[udg_UDex] = false
        if ( Trig_Unit_Event_Func005Func004C() ) then
            call ExecuteFunc("CEvFireUnload")
        else
        endif
        if udg_CargoTransportGroup[udg_UDex] != null then
            call DestroyGroup(udg_CargoTransportGroup[udg_UDex])
            set udg_CargoTransportGroup[udg_UDex] = null
        endif
    endif
    endfunction
     
    function CEvFireUnload takes nothing returns nothing
    call GroupRemoveUnitSimple( udg_UDexUnits[udg_UDex], udg_CargoTransportGroup[GetUnitUserData(udg_CargoTransportUnit[udg_UDex])] )
    if ( Trig_Unit_Event_Func010C() ) then
        set udg_CEvSpecial[udg_UDex] = false
        set udg_CEvNext[udg_CEvPrev[udg_UDex]] = udg_CEvNext[udg_UDex]
        set udg_CEvPrev[udg_CEvNext[udg_UDex]] = udg_CEvPrev[udg_UDex]
        set udg_CEvPrev[udg_UDex] = 0
        if ( Trig_Unit_Event_Func010Func005C() ) then
            call PauseTimerBJ( true, udg_CEvUnloadTimer )
        else
        endif
    else
    endif
    set udg_CEvBlock[udg_UDex] = true
    set udg_CargoEvent = 0.00
    set udg_CargoEvent = 2.00
    set udg_CargoEvent = 0.00
    set udg_CEvBlock[udg_UDex] = false
        if not IsUnitLoaded(udg_UDexUnits[udg_UDex]) or IsUnitType(udg_CargoTransportUnit[udg_UDex], UNIT_TYPE_DEAD) or GetUnitTypeId(udg_CargoTransportUnit[udg_UDex]) == 0 then
    set udg_CargoTransportUnit[udg_UDex] = null
        endif
    endfunction
     
    function DEvOnDeath takes nothing returns boolean
        local integer pdex = udg_UDex
    set udg_UDex = GetUnitUserData(GetTriggerUnit())
    if ( Trig_Unit_Event_Func024C() ) then
        set udg_IsUnitAlive[udg_UDex] = false
        set udg_DeathEvent = 0.00
        set udg_DeathEvent = 1.00
        set udg_DeathEvent = 0.00
        if ( Trig_Unit_Event_Func024Func005C() ) then
            call CEvFireUnload()
        else
        endif
    else
    endif
        set udg_UDex = pdex
        return false
    endfunction
     
    function DEvCheckDeath takes nothing returns nothing
    set udg_UDex = udg_DEvList[0]
    set udg_DEvList[0] = 0
        loop
            exitwhen udg_UDex == 0
    if ( Trig_Unit_Event_Func034C() ) then
        set udg_DEvBlock[udg_UDex] = false
    else
        if ( Trig_Unit_Event_Func034Func001C() ) then
            set udg_IsUnitAlive[udg_UDex] = false
            set udg_IsUnitReincarnating[udg_UDex] = true
            set udg_DeathEvent = 0.50
            set udg_DeathEvent = 0.00
        else
        endif
    endif
    set udg_UDex = udg_DEvList[udg_UDex]
        endloop
    endfunction
     
    function DEvCheckDeathProxy takes nothing returns nothing
    if ( Trig_Unit_Event_Func040C() ) then
        call TimerStart(udg_DEvTimer, 0, false, function DEvCheckDeath)
    else
    endif
    set udg_DEvList[udg_UDex] = udg_DEvList[0]
    set udg_DEvList[0] = udg_UDex
    endfunction
     
    function DEvOnOrder takes nothing returns boolean
        local integer pdex = udg_UDex
    set udg_UDex = GetUnitUserData(GetFilterUnit())
    if ( Trig_Unit_Event_Func048C() ) then
        if ( Trig_Unit_Event_Func048Func001C() ) then
            if ( Trig_Unit_Event_Func048Func001Func001C() ) then
                set udg_DEvRemoved[udg_UDex] = true
                set udg_DeathEvent = 0.00
                set udg_DeathEvent = 3.00
                set udg_DeathEvent = 0.00
            else
            endif
        else
            if ( Trig_Unit_Event_Func048Func001Func003C() ) then
                set udg_IsUnitAlive[udg_UDex] = true
                set udg_DeathEvent = 0.00
                set udg_DeathEvent = 2.00
                set udg_DeathEvent = 0.00
                set udg_IsUnitReincarnating[udg_UDex] = false
            else
                if IsUnitType(udg_UDexUnits[udg_UDex], UNIT_TYPE_DEAD) then
                if ( Trig_Unit_Event_Func048Func001Func003Func002C() ) then
                    set udg_IsUnitAlive[udg_UDex] = false
                    set udg_DeathEvent = 0.00
                    set udg_DeathEvent = 1.00
                    set udg_DeathEvent = 0.00
                else
                    if ( Trig_Unit_Event_Func048Func001Func003Func002Func001C() ) then
                    else
                        call DEvCheckDeathProxy()
                    endif
                endif
                endif
            endif
        endif
        if udg_CargoTransportUnit[udg_UDex] != null and not udg_CEvBlock[udg_UDex] and not IsUnitLoaded(udg_UDexUnits[udg_UDex]) or IsUnitType(udg_UDexUnits[udg_UDex], UNIT_TYPE_DEAD) then
            call CEvFireUnload()
        endif
    else
    endif
        set udg_UDex = pdex
        return false
    endfunction
     
    function CEvUnloadChecker takes nothing returns nothing
    set udg_UDex = udg_CEvNext[0]
        loop
            exitwhen udg_UDex == 0
    if ( Trig_Unit_Event_Func057C() ) then
        call CEvFireUnload()
    else
    endif
    set udg_UDex = udg_CEvNext[udg_UDex]
        endloop
    endfunction
     
    function CEvStartChecker takes nothing returns nothing
    if ( Trig_Unit_Event_Func063C() ) then
        call TimerStart(udg_CEvUnloadTimer, 0.03125, true, function CEvUnloadChecker)
    else
    endif
    set udg_CEvSpecial[udg_UDex] = true
    set udg_CEvPrev[udg_CEvNext[0]] = udg_UDex
    set udg_CEvNext[udg_UDex] = udg_CEvNext[0]
    set udg_CEvNext[0] = udg_UDex
    endfunction
     
    function CEvOnLoad takes nothing returns boolean
        local integer pdex = udg_UDex
        local integer udg_TempInteger
    set udg_UDex = GetUnitUserData(GetTriggerUnit())
    if ( Trig_Unit_Event_Func074C() ) then
        if ( Trig_Unit_Event_Func074Func001C() ) then
            call CEvFireUnload()
        else
        endif
        if ( Trig_Unit_Event_Func074Func002C() ) then
            call CEvStartChecker()
        else
        endif
        set udg_CargoTransportUnit[udg_UDex] = GetTransportUnitBJ()
        set udg_TempInteger = GetUnitUserData(udg_CargoTransportUnit[udg_UDex])
        if udg_CargoTransportGroup[udg_TempInteger] == null then
            set udg_CargoTransportGroup[udg_TempInteger] = CreateGroup()
        endif
        call GroupAddUnitSimple( udg_UDexUnits[udg_UDex], udg_CargoTransportGroup[udg_TempInteger] )
        set udg_CargoEvent = 0.00
        set udg_CargoEvent = 1.00
        set udg_CargoEvent = 0.00
    else
    endif
        set udg_UDex = pdex
        return false
    endfunction
     
    function CEvOnPause takes nothing returns boolean
        local integer pdex = udg_UDex
    set udg_UDex = GetUnitUserData(GetFilterUnit())
    if ( Trig_Unit_Event_Func082C() ) then
        call CEvStartChecker()
    else
    endif
        set udg_UDex = pdex
        return false
    endfunction
     
    function InitDeathEvent takes nothing returns nothing
        local integer i = 15
        local player p
        local trigger d = CreateTrigger()
        local trigger l = CreateTrigger()
        local trigger t = GetTriggeringTrigger()
        local boolexpr o = Filter(function DEvOnOrder)
        local boolexpr u = Filter(function CEvOnPause)
        call TriggerAddCondition(d, Filter(function DEvOnDeath))
        call TriggerAddCondition(l, Filter(function CEvOnLoad))
        loop
            set p = Player(i)
            call SetPlayerAbilityAvailable(p, udg_DEvAbility, false)
            call TriggerRegisterPlayerUnitEvent(t, p, EVENT_PLAYER_UNIT_ISSUED_ORDER, o)
            call TriggerRegisterPlayerUnitEvent(t, p, EVENT_PLAYER_UNIT_ISSUED_POINT_ORDER, u)
            call TriggerRegisterPlayerUnitEvent(d, p, EVENT_PLAYER_UNIT_DEATH, null)
            call TriggerRegisterPlayerUnitEvent(l, p, EVENT_PLAYER_UNIT_LOADED, null)
            exitwhen i == 0
            set i = i - 1
        endloop
        set d = null
        set l = null
        set o = null
        set p = null
        set t = null
        set u = null
        call DestroyGroup(udg_CargoTransportGroup[0])
        set udg_CargoTransportGroup[0] = null
endfunction

