function Trig_Normal_Mode_Func004C takes nothing returns boolean
    if ( ( GetClickedButtonBJ() == udg_DIALOG_FREE_FOR_ALL ) ) then
        return true
    endif
    if ( ( GetClickedButtonBJ() == udg_DIALOG_NORMAL ) ) then
        return true
    endif
    if ( ( GetClickedButtonBJ() == udg_DIALOG_BOMB ) ) then
        return true
    endif
