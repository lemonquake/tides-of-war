function Trig_RW_Actions takes nothing returns nothing
    set udg_TempPoint = GetSpellTargetLoc()
    call AddSpecialEffectLocBJ( GetUnitLoc(GetTriggerUnit()), "Objects\\Spawnmodels\\Naga\\NagaDeath\\NagaDeath.mdl" )
    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
    set bj_wantDestroyGroup = true
    call ForGroupBJ( GetUnitsInRangeOfLocMatching(300.00, GetUnitLoc(GetTriggerUnit()), Condition(function Trig_RW_Func005001003)), function Trig_RW_Func005A )
    call TriggerSleepAction( 0.20 )
    call AddSpecialEffectTargetUnitBJ( "origin", GetTriggerUnit(), "Objects\\Spawnmodels\\Naga\\NagaDeath\\NagaDeath.mdl" )
    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
    call SetUnitPositionLoc( GetTriggerUnit(), udg_TempPoint )
    set bj_wantDestroyGroup = true
    call ForGroupBJ( GetUnitsInRangeOfLocMatching(300.00, GetUnitLoc(GetTriggerUnit()), Condition(function Trig_RW_Func011001003)), function Trig_RW_Func011A )
    call RemoveLocation(udg_TempPoint)
endfunction

