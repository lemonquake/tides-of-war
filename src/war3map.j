function Trig_The_Triforce_Func002C takes nothing returns boolean
    if ( not ( UnitHasItemOfTypeBJ(udg_Item_Holder, 'I00Z') == true ) ) then
        return false
    endif
    if ( not ( UnitHasItemOfTypeBJ(udg_Item_Holder, 'I011') == true ) ) then
        return false
    endif
    if ( not ( UnitHasItemOfTypeBJ(udg_Item_Holder, 'I010') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_The_Triforce_Actions takes nothing returns nothing
    set udg_Item_Holder = GetManipulatingUnit()
    if ( Trig_The_Triforce_Func002C() ) then
        call RemoveItem( GetItemOfTypeFromUnitBJ(udg_Item_Holder, 'I00Z') )
        call RemoveItem( GetItemOfTypeFromUnitBJ(udg_Item_Holder, 'I011') )
        call RemoveItem( GetItemOfTypeFromUnitBJ(udg_Item_Holder, 'I010') )
        DestroyEffect(AddSpecialEffect("Abilities\\Spells\\Items\\AIem\\AIemTarget.mdl", GetUnitX(udg_Item_Holder), GetUnitY(udg_Item_Holder)))
        call DestroyEffectBJ( GetLastCreatedEffectBJ() )
        call UnitAddItemByIdSwapped( 'I012', udg_Item_Holder )
    else
    endif
endfunction

