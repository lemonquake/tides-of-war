    set gg_trg_NN_Forceb = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_NN_Forceb, EVENT_PLAYER_UNIT_SPELL_EFFECT )
    call TriggerAddCondition( gg_trg_NN_Forceb, Condition( function Trig_NN_Forceb_Conditions ) )
