function InitTrig_Knockback_Collider takes nothing returns nothing
    set gg_trg_Knockback_Collider = CreateTrigger(  )
    call TriggerRegisterTimerExpireEventBJ( gg_trg_Knockback_Collider, udg_K2DTimer )
