//===========================================================================
// Trigger: Repel eff
//
// GetEnumUnit()
//===========================================================================
function Trig_Repel_eff_Func002Func004002003001 takes nothing returns boolean
    return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_STRUCTURE) != true )
endfunction

function Trig_Repel_eff_Func002Func004002003002001 takes nothing returns boolean
    return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_MECHANICAL) != true )
endfunction

function Trig_Repel_eff_Func002Func004002003002002001 takes nothing returns boolean
    return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_MAGIC_IMMUNE) != true )
endfunction

function Trig_Repel_eff_Func002Func004002003002002002001 takes nothing returns boolean
    return ( IsUnitDeadBJ(GetFilterUnit()) != true )
endfunction

function Trig_Repel_eff_Func002Func004002003002002002002001 takes nothing returns boolean
    return ( IsUnitEnemy(GetFilterUnit(), GetOwningPlayer(udg_Caster)) == true )
endfunction

function Trig_Repel_eff_Func002Func004002003002002002002002 takes nothing returns boolean
    return ( GetUnitAbilityLevelSwapped('A00A', GetFilterUnit()) < 1 )
endfunction

function Trig_Repel_eff_Func002Func004002003002002002002 takes nothing returns boolean
    return GetBooleanAnd( Trig_Repel_eff_Func002Func004002003002002002002001(), Trig_Repel_eff_Func002Func004002003002002002002002() )
endfunction

function Trig_Repel_eff_Func002Func004002003002002002 takes nothing returns boolean
    return GetBooleanAnd( Trig_Repel_eff_Func002Func004002003002002002001(), Trig_Repel_eff_Func002Func004002003002002002002() )
endfunction

function Trig_Repel_eff_Func002Func004002003002002 takes nothing returns boolean
    return GetBooleanAnd( Trig_Repel_eff_Func002Func004002003002002001(), Trig_Repel_eff_Func002Func004002003002002002() )
endfunction

function Trig_Repel_eff_Func002Func004002003002 takes nothing returns boolean
    return GetBooleanAnd( Trig_Repel_eff_Func002Func004002003002001(), Trig_Repel_eff_Func002Func004002003002002() )
endfunction

function Trig_Repel_eff_Func002Func004002003 takes nothing returns boolean
    return GetBooleanAnd( Trig_Repel_eff_Func002Func004002003001(), Trig_Repel_eff_Func002Func004002003002() )
endfunction

function Trig_Repel_eff_Func002Func006A takes nothing returns nothing
    set udg_Repel_Point[2] = GetUnitLoc(GetEnumUnit())
    set udg_Repel_Point[3] = PolarProjectionBJ(udg_Repel_Point[2], 45.00, AngleBetweenPoints(udg_Repel_Point[1], udg_Repel_Point[2]))
    call SetUnitX(GetEnumUnit(),GetLocationX(udg_Repel_Point[3]))
    call SetUnitY(GetEnumUnit(),GetLocationY(udg_Repel_Point[3]))
    call AddSpecialEffectTargetUnitBJ( "chest", GetEnumUnit(), "Abilities\\Weapons\\AncientProtectorMissile\\AncientProtectorMissile.mdl" )
    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
    call RemoveLocation(udg_Repel_Point[2])
    call RemoveLocation(udg_Repel_Point[3])
endfunction

function Trig_Repel_eff_Func002Func007C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(udg_Caster) == true ) ) then
        return false
    endif
    if ( not ( UnitHasBuffBJ(udg_Caster, 'B01B') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Repel_eff_Func002A takes nothing returns nothing
    set udg_Repel_Real[1] = LoadRealBJ(StringHashBJ("Repel_Real"), GetHandleIdBJ(GetEnumUnit()), udg_Repel_Hash)
    set udg_Caster = LoadUnitHandleBJ(StringHashBJ("Repel_Caster"), GetHandleIdBJ(GetEnumUnit()), udg_Repel_Hash)
    set udg_Repel_Point[1] = GetUnitLoc(udg_Caster)
    set udg_Enemies = GetUnitsInRangeOfLocMatching(udg_Repel_Real[1], udg_Repel_Point[1], Condition(function Trig_Repel_eff_Func002Func004002003))
    set bj_wantDestroyGroup = true
    call ForGroupBJ( udg_Enemies, function Trig_Repel_eff_Func002Func006A )
    if ( Trig_Repel_eff_Func002Func007C() ) then
    else
        call FlushChildHashtableBJ( GetHandleIdBJ(GetEnumUnit()), udg_Repel_Hash )
        call GroupRemoveUnitSimple( GetEnumUnit(), udg_Repeleds )
        call RemoveUnit( GetEnumUnit() )
    endif
    call RemoveLocation(udg_Repel_Point[1])
    call DestroyGroup(udg_Enemies)
endfunction

function Trig_Repel_eff_Func003C takes nothing returns boolean
    if ( not ( IsUnitGroupEmptyBJ(udg_Repeleds) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Repel_eff_Actions takes nothing returns nothing
    set bj_wantDestroyGroup = true
    call ForGroupBJ( udg_Repeleds, function Trig_Repel_eff_Func002A )
    if ( Trig_Repel_eff_Func003C() ) then
        call DisableTrigger( GetTriggeringTrigger() )
    else
    endif
endfunction

