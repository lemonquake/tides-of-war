    endif
    set udg_BL_MUI1 = ( udg_BL_MUI1 + 1 )
    set udg_BL_MUI2 = ( udg_BL_MUI2 + 1 )
    set udg_BL_Caster[udg_BL_MUI2] = GetTriggerUnit()
