//===========================================================================
// Trigger: Split
//===========================================================================
function Trig_Split_Func002C takes nothing returns boolean
    if ( not ( udg_order >= 852002 ) ) then
        return false
    endif
    if ( not ( udg_order <= 852007 ) ) then
        return false
    endif
    if ( not ( GetOrderTargetItem() == UnitItemInSlotBJ(GetOrderedUnit(), ( udg_order - 852001 )) ) ) then
        return false
    endif
    if ( not ( GetItemCharges(GetOrderTargetItem()) > 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Split_Actions takes nothing returns nothing
    set udg_order = GetIssuedOrderId()
    if ( Trig_Split_Func002C() ) then
        call SetItemCharges( GetOrderTargetItem(), ( GetItemCharges(GetOrderTargetItem()) - 1 ) )
        set udg_L = GetUnitLoc(GetOrderedUnit())
        call CreateItemLoc( GetItemTypeId(GetOrderTargetItem()), udg_L )
        call RemoveLocation(udg_L)
        call SetItemCharges( GetLastCreatedItem(), 1 )
    else
    endif
endfunction

//===========================================================================
function InitTrig_Split takes nothing returns nothing
    set gg_trg_Split = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_Split, EVENT_PLAYER_UNIT_ISSUED_TARGET_ORDER )
    call TriggerAddAction( gg_trg_Split, function Trig_Split_Actions )
endfunction

