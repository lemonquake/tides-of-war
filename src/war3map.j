//===========================================================================
function Trig_Hammer_Mastery_Func001C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped('A05S', udg_GDD_DamageSource) > 0 ) ) then
        return false
    endif
    if ( not ( udg_GDD_Damage > 0.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Hammer_Mastery_Conditions takes nothing returns boolean
    if ( not Trig_Hammer_Mastery_Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_Hammer_Mastery_Func003C takes nothing returns boolean
    if ( not ( udg_Hammer_Mastery[GetConvertedPlayerId(GetOwningPlayer(udg_GDD_DamageSource))] == 4 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Hammer_Mastery_Actions takes nothing returns nothing
    set udg_Hammer_Mastery[GetConvertedPlayerId(GetOwningPlayer(udg_GDD_DamageSource))] = ( udg_Hammer_Mastery[GetConvertedPlayerId(GetOwningPlayer(udg_GDD_DamageSource))] + 1 )
    if ( Trig_Hammer_Mastery_Func003C() ) then
        call UnitAddAbilityBJ( 'A05T', udg_GDD_DamageSource )
    else
    endif
endfunction

//===========================================================================
function InitTrig_Hammer_Mastery takes nothing returns nothing
    set gg_trg_Hammer_Mastery = CreateTrigger(  )
    call TriggerRegisterVariableEvent( gg_trg_Hammer_Mastery, "udg_GDD_Event", EQUAL, 1.00 )
    call TriggerAddCondition( gg_trg_Hammer_Mastery, Condition( function Trig_Hammer_Mastery_Conditions ) )
    call TriggerAddAction( gg_trg_Hammer_Mastery, function Trig_Hammer_Mastery_Actions )
endfunction

