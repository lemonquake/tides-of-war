//===========================================================================
// Trigger: Kill Streak
//===========================================================================
function Trig_Kill_Streak_Func004C takes nothing returns boolean
    if ( not ( IsUnitType(GetDyingUnit(), UNIT_TYPE_HERO) == true ) ) then
        return false
    endif
    if ( not ( GetOwningPlayer(GetDyingUnit()) != Player(PLAYER_NEUTRAL_PASSIVE) ) ) then
        return false
    endif
    if ( not ( GetOwningPlayer(GetDyingUnit()) != Player(PLAYER_NEUTRAL_AGGRESSIVE) ) ) then
        return false
    endif
    return true
endfunction

function Trig_Kill_Streak_Conditions takes nothing returns boolean
    if ( not Trig_Kill_Streak_Func004C() ) then
        return false
    endif
    return true
endfunction

function Trig_Kill_Streak_Func002Func001C takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetKillingUnitBJ()) == 'U000' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Kill_Streak_Func002Func002C takes nothing returns boolean
    if ( not ( GetOwningPlayer(GetKillingUnitBJ()) == GetOwningPlayer(GetDyingUnit()) ) ) then
        return false
    endif
    return true
endfunction

function Trig_Kill_Streak_Func002Func003C takes nothing returns boolean
    if ( not ( GetOwningPlayer(GetKillingUnitBJ()) != GetOwningPlayer(GetDyingUnit()) ) ) then
        return false
    endif
    if ( not ( IsUnitAlly(GetKillingUnitBJ(), GetOwningPlayer(GetDyingUnit())) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Kill_Streak_Func002C takes nothing returns boolean
    if ( not ( GetOwningPlayer(GetKillingUnitBJ()) == Player(PLAYER_NEUTRAL_AGGRESSIVE) ) ) then
        return false
    endif
    if ( not ( GetUnitTypeId(GetKillingUnitBJ()) != 'U000' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Kill_Streak_Func003Func001C takes nothing returns boolean
    if ( not ( udg_Kill_Points[GetConvertedPlayerId(GetOwningPlayer(GetDyingUnit()))] <= udg_Start_Kills ) ) then
        return false
    endif
    if ( not ( GetOwningPlayer(GetDyingUnit()) != Player(PLAYER_NEUTRAL_PASSIVE) ) ) then
        return false
    endif
    return true
endfunction

function Trig_Kill_Streak_Func003Func005Func004C takes nothing returns boolean
    if ( not ( udg_First_Blood == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_Kill_Streak_Func003Func005C takes nothing returns boolean
    if ( not ( udg_Make_Kill == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Kill_Streak_Func003Func006C takes nothing returns boolean
    if ( not ( udg_Messages_List[udg_Kill_Points[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))]] != "" ) ) then
        return false
    endif
    if ( not ( udg_Kill_Points[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] <= udg_Total_Messages ) ) then
        return false
    endif
    return true
endfunction

function Trig_Kill_Streak_Func003Func007C takes nothing returns boolean
    if ( not ( udg_Kill_Points[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] > udg_Total_Messages ) ) then
        return false
    endif
    return true
endfunction

function Trig_Kill_Streak_Func003Func008C takes nothing returns boolean
    if ( not ( udg_Killing_Spree[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Kill_Streak_Func003Func009C takes nothing returns boolean
    if ( not ( udg_Killing_Spree[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] == 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Kill_Streak_Func003Func010C takes nothing returns boolean
    if ( not ( udg_Killing_Spree[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] == 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Kill_Streak_Func003Func011C takes nothing returns boolean
    if ( not ( udg_Killing_Spree[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] == 4 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Kill_Streak_Func003Func012C takes nothing returns boolean
    if ( not ( udg_Killing_Spree[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] >= 5 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Kill_Streak_Func003C takes nothing returns boolean
    if ( not ( udg_Make_Kill == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Kill_Streak_Actions takes nothing returns nothing
    set udg_Make_Kill = true
    if ( Trig_Kill_Streak_Func002C() ) then
        call DisplayTextToForce( bj_FORCE_ALL_PLAYERS, ( udg_Players_Name[GetConvertedPlayerId(GetOwningPlayer(GetDyingUnit()))] + " has been killed by neutral creeps" ) )
        set udg_Make_Kill = false
        set udg_Killing_Spree[GetConvertedPlayerId(GetOwningPlayer(GetDyingUnit()))] = 0
        set udg_Kill_Points[GetConvertedPlayerId(GetOwningPlayer(GetDyingUnit()))] = 0
        set udg_Kill_Waiting_Time[GetConvertedPlayerId(GetOwningPlayer(GetDyingUnit()))] = 0
    else
        if ( Trig_Kill_Streak_Func002Func001C() ) then
            call DisplayTextToForce( bj_FORCE_ALL_PLAYERS, ( udg_Players_Name[GetConvertedPlayerId(GetOwningPlayer(GetDyingUnit()))] + " has been killed by DINO!!! HAHA ..l.." ) )
            set udg_Make_Kill = false
        else
        endif
        if ( Trig_Kill_Streak_Func002Func002C() ) then
            call DisplayTextToForce( bj_FORCE_ALL_PLAYERS, ( udg_Players_Name[GetConvertedPlayerId(GetOwningPlayer(GetDyingUnit()))] + " has killed himself" ) )
            set udg_Make_Kill = false
        else
        endif
        if ( Trig_Kill_Streak_Func002Func003C() ) then
            call DisplayTextToForce( bj_FORCE_ALL_PLAYERS, ( udg_Players_Name[GetConvertedPlayerId(GetOwningPlayer(GetDyingUnit()))] + " has been killed by his teammate!" ) )
            set udg_Make_Kill = false
        else
        endif
    endif
    if ( Trig_Kill_Streak_Func003C() ) then
        if ( Trig_Kill_Streak_Func003Func001C() ) then
            call DisplayTextToForce( bj_FORCE_ALL_PLAYERS, ( ( udg_Players_Name[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] + " just pwnd " ) + udg_Players_Name[GetConvertedPlayerId(GetOwningPlayer(GetDyingUnit()))] ) )
            call MultiboardSetItemValueBJ( GetLastCreatedMultiboard(), 6, udg_Multiboard_Spots[GetConvertedPlayerId(GetOwningPlayer(GetDyingUnit()))], "TRIGSTR_3003" )
        else
            call DisplayTextToForce( bj_FORCE_ALL_PLAYERS, ( ( udg_Players_Name[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] + " just pwnd " ) + ( udg_Players_Name[GetConvertedPlayerId(GetOwningPlayer(GetDyingUnit()))] + ( " ending it's " + udg_Messages_List[udg_Kill_Points[GetConvertedPlayerId(GetOwningPlayer(GetDyingUnit()))]] ) ) ) )
            call MultiboardSetItemValueBJ( GetLastCreatedMultiboard(), 6, udg_Multiboard_Spots[GetConvertedPlayerId(GetOwningPlayer(GetDyingUnit()))], "TRIGSTR_3002" )
        endif
        set udg_Killing_Spree[GetConvertedPlayerId(GetOwningPlayer(GetDyingUnit()))] = 0
        set udg_Kill_Points[GetConvertedPlayerId(GetOwningPlayer(GetDyingUnit()))] = 0
        set udg_Kill_Waiting_Time[GetConvertedPlayerId(GetOwningPlayer(GetDyingUnit()))] = 0
        if ( Trig_Kill_Streak_Func003Func005C() ) then
            set udg_Kill_Points[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] = ( udg_Kill_Points[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] + 1 )
            set udg_Killing_Spree[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] = ( udg_Killing_Spree[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] + 1 )
            if ( Trig_Kill_Streak_Func003Func005Func004C() ) then
                call DisplayTextToForce( bj_FORCE_ALL_PLAYERS, ( udg_Players_Name[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] + " just drew |c00ff0000First Blood|r" ) )
                call PlaySoundBJ( gg_snd_firstblood )
                set udg_First_Blood = true
            else
            endif
        else
        endif
        if ( Trig_Kill_Streak_Func003Func006C() ) then
            call DisplayTextToForce( bj_FORCE_ALL_PLAYERS, ( udg_Players_Name[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] + ( " " + udg_Messages_List[udg_Kill_Points[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))]] ) ) )
            call PlaySoundBJ( udg_Sounds_List[udg_Kill_Points[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))]] )
        else
        endif
        if ( Trig_Kill_Streak_Func003Func007C() ) then
            call DisplayTextToForce( bj_FORCE_ALL_PLAYERS, ( udg_Players_Name[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] + ( " " + udg_Messages_List[udg_Total_Messages] ) ) )
            call PlaySoundBJ( udg_Sounds_List[udg_Total_Messages] )
        else
        endif
        if ( Trig_Kill_Streak_Func003Func008C() ) then
            set udg_Kill_Waiting_Time[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] = 20
        else
        endif
        if ( Trig_Kill_Streak_Func003Func009C() ) then
            call PlaySoundBJ( gg_snd_doublekill )
            call DisplayTextToForce( bj_FORCE_ALL_PLAYERS, ( udg_Players_Name[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] + " made a |c000000ffDouble Kill|r" ) )
            set udg_Kill_Waiting_Time[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] = 20
        else
        endif
        if ( Trig_Kill_Streak_Func003Func010C() ) then
            call PlaySoundBJ( gg_snd_tripplekill )
            call DisplayTextToForce( bj_FORCE_ALL_PLAYERS, ( udg_Players_Name[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] + " made a |c0000ccccTriple Kill|r" ) )
            set udg_Kill_Waiting_Time[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] = 20
        else
        endif
        if ( Trig_Kill_Streak_Func003Func011C() ) then
            call PlaySoundBJ( gg_snd_ultrakill )
            call DisplayTextToForce( bj_FORCE_ALL_PLAYERS, ( udg_Players_Name[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] + " made an |c00cc6600Ultrakill|r!" ) )
            set udg_Kill_Waiting_Time[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] = 20
        else
        endif
        if ( Trig_Kill_Streak_Func003Func012C() ) then
            call PlaySoundBJ( gg_snd_rampage )
            call DisplayTextToForce( bj_FORCE_ALL_PLAYERS, ( udg_Players_Name[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] + " in on a |c00cc6600RAMPAGEEEEE!!!!|r" ) )
            set udg_Kill_Waiting_Time[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] = 20
        else
        endif
    else
    endif
endfunction

//===========================================================================
function InitTrig_Kill_Streak takes nothing returns nothing
    set gg_trg_Kill_Streak = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_Kill_Streak, EVENT_PLAYER_UNIT_DEATH )
    call TriggerAddCondition( gg_trg_Kill_Streak, Condition( function Trig_Kill_Streak_Conditions ) )
    call TriggerAddAction( gg_trg_Kill_Streak, function Trig_Kill_Streak_Actions )
endfunction

//===========================================================================
// Trigger: Timer
//===========================================================================
function Trig_Timer_Func001Func001C takes nothing returns boolean
    if ( not ( udg_Kill_Waiting_Time[GetForLoopIndexA()] >= 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Timer_Func001Func002C takes nothing returns boolean
    if ( not ( udg_Kill_Waiting_Time[GetForLoopIndexA()] <= 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Timer_Actions takes nothing returns nothing
    set bj_forLoopAIndex = 1
    set bj_forLoopAIndexEnd = 8
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_Timer_Func001Func001C() ) then
            set udg_Kill_Waiting_Time[GetForLoopIndexA()] = ( udg_Kill_Waiting_Time[GetForLoopIndexA()] - 1 )
        else
        endif
        if ( Trig_Timer_Func001Func002C() ) then
            set udg_Killing_Spree[GetForLoopIndexA()] = 0
        else
        endif
        set bj_forLoopAIndex = bj_forLoopAIndex + 1
    endloop
endfunction

//===========================================================================
function InitTrig_Timer takes nothing returns nothing
    set gg_trg_Timer = CreateTrigger(  )
    call TriggerRegisterTimerEventPeriodic( gg_trg_Timer, 1.00 )
    call TriggerAddAction( gg_trg_Timer, function Trig_Timer_Actions )
endfunction

//===========================================================================
// Trigger: Ancient Statue debug
//===========================================================================
function Trig_Ancient_Statue_debug_Conditions takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetTriggerUnit()) == 'esen' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Ancient_Statue_debug_Actions takes nothing returns nothing
    call RemoveUnit( GetTriggerUnit() )
endfunction

//===========================================================================
function InitTrig_Ancient_Statue_debug takes nothing returns nothing
    set gg_trg_Ancient_Statue_debug = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_Ancient_Statue_debug, EVENT_PLAYER_UNIT_DEATH )
    call TriggerAddCondition( gg_trg_Ancient_Statue_debug, Condition( function Trig_Ancient_Statue_debug_Conditions ) )
    call TriggerAddAction( gg_trg_Ancient_Statue_debug, function Trig_Ancient_Statue_debug_Actions )
endfunction

//===========================================================================
// Trigger: Panda Style
//===========================================================================
function Trig_Panda_Style_Func001C takes nothing returns boolean
    if ( not ( udg_GDD_Damage > 0.00 ) ) then
        return false
    endif
    if ( not ( UnitHasBuffBJ(udg_GDD_DamageSource, 'B01V') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Panda_Style_Conditions takes nothing returns boolean
    if ( not Trig_Panda_Style_Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_Panda_Style_Actions takes nothing returns nothing
    call SetUnitLifeBJ( udg_GDD_DamageSource, ( GetUnitStateSwap(UNIT_STATE_LIFE, udg_GDD_DamageSource) + ( udg_GDD_Damage / 2.00 ) ) )
    call CreateTextTagUnitBJ( ( "+|cff7cfc00" + I2S(R2I(udg_GDD_Damage)) ), udg_GDD_DamageSource, 0.00, 11.00, 100.00, 100.00, 100.00, 0 )
    call SetTextTagVelocityBJ( GetLastCreatedTextTag(), 120.00, 90.00 )
    call SetTextTagPermanentBJ( GetLastCreatedTextTag(), false )
    call SetTextTagLifespanBJ( GetLastCreatedTextTag(), udg_Text_Duration )
    call SetTextTagFadepointBJ( GetLastCreatedTextTag(), 0.35 )
endfunction

//===========================================================================
function InitTrig_Panda_Style takes nothing returns nothing
    set gg_trg_Panda_Style = CreateTrigger(  )
    call TriggerRegisterVariableEvent( gg_trg_Panda_Style, "udg_GDD_Event", EQUAL, 1.00 )
    call TriggerAddCondition( gg_trg_Panda_Style, Condition( function Trig_Panda_Style_Conditions ) )
    call TriggerAddAction( gg_trg_Panda_Style, function Trig_Panda_Style_Actions )
endfunction

//===========================================================================
// Trigger: BOMB
//===========================================================================
function Trig_BOMB_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A07C' ) ) then
        return false
    endif
    return true
endfunction

function Trig_BOMB_Actions takes nothing returns nothing
    call UnitRemoveItemSwapped( GetItemOfTypeFromUnitBJ(GetTriggerUnit(), 'I004'), GetTriggerUnit() )
    call RemoveItem( GetLastRemovedItem() )
endfunction

//===========================================================================
function InitTrig_BOMB takes nothing returns nothing
    set gg_trg_BOMB = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_BOMB, EVENT_PLAYER_UNIT_SPELL_EFFECT )
    call TriggerAddCondition( gg_trg_BOMB, Condition( function Trig_BOMB_Conditions ) )
    call TriggerAddAction( gg_trg_BOMB, function Trig_BOMB_Actions )
endfunction

