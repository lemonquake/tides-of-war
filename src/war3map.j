function InitTrig_Repick_h takes nothing returns nothing
    set gg_trg_Repick_h = CreateTrigger(  )
    call TriggerRegisterPlayerChatEvent( gg_trg_Repick_h, Player(0), "-repick", true )
    call TriggerRegisterPlayerChatEvent( gg_trg_Repick_h, Player(1), "-repick", true )
    call TriggerRegisterPlayerChatEvent( gg_trg_Repick_h, Player(2), "-repick", true )
    call TriggerRegisterPlayerChatEvent( gg_trg_Repick_h, Player(3), "-repick", true )
    call TriggerRegisterPlayerChatEvent( gg_trg_Repick_h, Player(4), "-repick", true )
    call TriggerRegisterPlayerChatEvent( gg_trg_Repick_h, Player(5), "-repick", true )
    call TriggerRegisterPlayerChatEvent( gg_trg_Repick_h, Player(6), "-repick", true )
    call TriggerRegisterPlayerChatEvent( gg_trg_Repick_h, Player(7), "-repick", true )
    call TriggerRegisterPlayerChatEvent( gg_trg_Repick_h, Player(8), "-repick", true )
    call TriggerRegisterPlayerChatEvent( gg_trg_Repick_h, Player(9), "-repick", true )
    call TriggerRegisterPlayerChatEvent( gg_trg_Repick_h, Player(10), "-repick", true )
    call TriggerRegisterPlayerChatEvent( gg_trg_Repick_h, Player(11), "-repick", true )
    call TriggerAddAction( gg_trg_Repick_h, function Trig_Repick_h_Actions )
endfunction

//===========================================================================
// Trigger: GUI SpellEvent
//===========================================================================
function Trig_GUI_SpellEvent_Actions takes nothing returns nothing
    local integer i = 1
    call ExecuteFunc("InitSpellEvent")
    call InitHashtableBJ(  )
    set udg_SpellEventHash = GetLastCreatedHashtableBJ()
    loop
    exitwhen udg_SpellEventAbility[i] == 0
    call SaveTriggerHandle(udg_SpellEventHash, udg_SpellEventAbility[i], 0, udg_SpellEventTrigger[i])
    set i = i + 1
    endloop
    endfunction
    function OnSpell takes nothing returns boolean
    local trigger t = LoadTriggerHandle(udg_SpellEventHash, GetSpellAbilityId(), 0)
    if TriggerEvaluate(t) then
    call TriggerExecute(t)
    endif
    set t = null
    return false
    endfunction
    function InitSpellEvent takes nothing returns nothing
        local trigger t = CreateTrigger()
        call TriggerRegisterAnyUnitEventBJ(t, EVENT_PLAYER_UNIT_SPELL_EFFECT)
        call TriggerAddCondition(t, Condition(function OnSpell))
        set t = null
    set udg_SpellEventTrigger[0] = GetTriggeringTrigger()
    set udg_SpellEventAbility[0] = 'AIsb'
endfunction

//===========================================================================
function InitTrig_GUI_SpellEvent takes nothing returns nothing
    set gg_trg_GUI_SpellEvent = CreateTrigger(  )
    call TriggerAddAction( gg_trg_GUI_SpellEvent, function Trig_GUI_SpellEvent_Actions )
endfunction

