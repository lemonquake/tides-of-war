        call IssuePointOrderLocBJ( gg_unit_H00X_0160, "breathoffire", udg_TempPoint )
        call RemoveLocation(udg_TempPoint)
    else
        call IssueTargetOrderBJ( gg_unit_H00X_0160, "chainlightning", udg_GDD_DamageSource )
