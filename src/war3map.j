function InitTrig_On_Damage2 takes nothing returns nothing
    set gg_trg_On_Damage2 = CreateTrigger(  )
    call DisableTrigger( gg_trg_On_Damage2 )
    call TriggerRegisterVariableEvent( gg_trg_On_Damage2, "udg_DamageEvent", EQUAL, 1.00 )
    call TriggerAddAction( gg_trg_On_Damage2, function Trig_On_Damage2_Actions )
endfunction

