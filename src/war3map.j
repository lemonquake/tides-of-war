//===========================================================================
// Trigger: Is Unit Moving
//===========================================================================
function Trig_Is_Unit_Moving_Func001Func004C takes nothing returns boolean
    if ( not ( GetUnitDefaultMoveSpeed(udg_UDexUnits[udg_UDex]) != 0.00 ) ) then
        return false
    endif
    if ( not ( GetOwningPlayer(udg_UDexUnits[udg_UDex]) != Player(PLAYER_NEUTRAL_AGGRESSIVE) ) ) then
        return false
    endif
    if ( not ( GetOwningPlayer(udg_UDexUnits[udg_UDex]) != Player(PLAYER_NEUTRAL_PASSIVE) ) ) then
        return false
    endif
    if ( not ( GetPlayerSlotState(GetOwningPlayer(udg_UDexUnits[udg_UDex])) == PLAYER_SLOT_STATE_PLAYING ) ) then
        return false
    endif
    return true
endfunction

function Trig_Is_Unit_Moving_Func001C takes nothing returns boolean
    if ( not ( udg_UnitIndexEvent == 1.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Is_Unit_Moving_Actions takes nothing returns nothing
    if ( Trig_Is_Unit_Moving_Func001C() ) then
        //  
        // The next conditions let you filter out unwanted units
        //  
        if ( Trig_Is_Unit_Moving_Func001Func004C() ) then
            //  
            // Register the indexed unit to the list
            //  
            set udg_UMovPrev[udg_UMovNext[0]] = udg_UDex
            set udg_UMovNext[udg_UDex] = udg_UMovNext[0]
            set udg_UMovNext[0] = udg_UDex
            set udg_UnitMovingX[udg_UDex] = GetUnitX(udg_UDexUnits[udg_UDex])
            set udg_UnitMovingY[udg_UDex] = GetUnitY(udg_UDexUnits[udg_UDex])
        else
            //  
            // The unit will not be registered
            //  
        endif
        elseif udg_UnitIndexEvent == 2 then
        if udg_UMovPrev[udg_UDex] != 0 or udg_UMovNext[0] == udg_UDex then
        //  
        // Unregister the deindexed unit from the list
        //  
        set udg_UnitMoving[udg_UDex] = false
        set udg_UMovNext[udg_UMovPrev[udg_UDex]] = udg_UMovNext[udg_UDex]
        set udg_UMovPrev[udg_UMovNext[udg_UDex]] = udg_UMovPrev[udg_UDex]
        set udg_UMovPrev[udg_UDex] = 0
        endif
    else
        set udg_UDex = udg_UMovNext[0]
        loop
        exitwhen udg_UDex == 0
        set udg_TempX = GetUnitX(udg_UDexUnits[udg_UDex])
        set udg_TempY = GetUnitY(udg_UDexUnits[udg_UDex])
        //  
        // Check if unit's coordinates have changed
        //  
        if udg_TempX != udg_UnitMovingX[udg_UDex] or udg_TempY != udg_UnitMovingY[udg_UDex] then
        set udg_UnitMovingX[udg_UDex] = udg_TempX
        set udg_UnitMovingY[udg_UDex] = udg_TempY
        if not udg_UnitMoving[udg_UDex] and GetUnitTypeId(udg_UDexUnits[udg_UDex]) != 0 then
        //  
        // The unit has started moving, fire event for UDex
        //  
        set udg_UnitMoving[udg_UDex] = true
        set udg_UnitMovingEvent = 1.00
        set udg_UnitMovingEvent = 0.00
        endif
        elseif udg_UnitMoving[udg_UDex] then
        //  
        // The unit has stopped moving, fire event for UDex
        //  
        set udg_UnitMoving[udg_UDex] = false
        set udg_UnitMovingEvent = 2.00
        set udg_UnitMovingEvent = 0.00
        endif
        set udg_UDex = udg_UMovNext[udg_UDex]
        endloop
    endif
endfunction

//===========================================================================
function InitTrig_Is_Unit_Moving takes nothing returns nothing
    set gg_trg_Is_Unit_Moving = CreateTrigger(  )
    call TriggerRegisterTimerEventPeriodic( gg_trg_Is_Unit_Moving, 0.05 )
    call TriggerRegisterVariableEvent( gg_trg_Is_Unit_Moving, "udg_UnitIndexEvent", EQUAL, 1.00 )
    call TriggerRegisterVariableEvent( gg_trg_Is_Unit_Moving, "udg_UnitIndexEvent", EQUAL, 2.00 )
    call TriggerAddAction( gg_trg_Is_Unit_Moving, function Trig_Is_Unit_Moving_Actions )
endfunction

