        return false
    endif
    return true
endfunction

function Trig_NN_Forceb_Func003Func010Func010C takes nothing returns boolean
    if ( ( GetSpellTargetUnit() == GetTriggerUnit() ) ) then
        return true
    endif
    if ( ( GetItemTypeId(GetSpellTargetItem()) == 'I00Y' ) ) then
        return true
    endif
    return false
endfunction

