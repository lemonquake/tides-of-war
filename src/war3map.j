    set gg_trg_Normal_Mode_Con = CreateTrigger(  )
    call TriggerRegisterDialogEventBJ( gg_trg_Normal_Mode_Con, udg_DIALOG2 )
    call TriggerAddAction( gg_trg_Normal_Mode_Con, function Trig_Normal_Mode_Con_Actions )
endfunction

