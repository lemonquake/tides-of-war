    set bj_wantDestroyGroup = true
    call ForGroupBJ( GetUnitsInRangeOfLocMatching(1200.00, GetUnitLoc(gg_unit_U000_0120), Condition(function Trig_Behavior3_Func003001003)), function Trig_Behavior3_Func003A )
endfunction

