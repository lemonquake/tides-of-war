// Trigger: Obser Des
//===========================================================================
function Trig_Obser_Des_Func005C takes nothing returns boolean
    if ( not ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetTriggerUnit()) == true ) ) then
        return false
    endif
    if ( not ( GetOwningPlayer(GetTriggerUnit()) != Player(PLAYER_NEUTRAL_AGGRESSIVE) ) ) then
        return false
    endif
    return true
endfunction

function Trig_Obser_Des_Conditions takes nothing returns boolean
    if ( not Trig_Obser_Des_Func005C() ) then
        return false
    endif
    return true
endfunction

function Trig_Obser_Des_Actions takes nothing returns nothing
    call ResetUnitAnimation( gg_unit_h01M_0146 )
    set udg_Obser_Con[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))] = false
    call DestroyFogModifier( udg_Observatory[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))] )
    call DestroyEffectBJ( udg_Obser[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))] )
endfunction

