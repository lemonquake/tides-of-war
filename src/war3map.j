    set gg_trg_Drag = CreateTrigger(  )
    call DisableTrigger( gg_trg_Drag )
    call TriggerRegisterTimerEventPeriodic( gg_trg_Drag, 0.02 )
    call TriggerAddAction( gg_trg_Drag, function Trig_Drag_Actions )
