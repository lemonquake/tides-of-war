    local unit u = udg_UDexUnits[udg_UDex]
    call SaveReal(udg_CreepTable, udg_UDex, 1, GetUnitX(u))
    call SaveReal(udg_CreepTable, udg_UDex, 2, GetUnitY(u))
    call SaveReal(udg_CreepTable, udg_UDex, 3, GetUnitFacing(u))
    set u = null
endfunction

