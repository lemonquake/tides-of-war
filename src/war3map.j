    if ( Trig_On_Move_Func001C() ) then
        call MultiboardSetItemValueBJ( GetLastCreatedMultiboard(), 5, udg_Multiboard_Spots[GetConvertedPlayerId(GetOwningPlayer(udg_UDexUnits[udg_UDex]))], "TRIGSTR_3636" )
    else
    endif
endfunction

