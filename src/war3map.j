function Trig_Normal_Mode_Con_Func001Func001C takes nothing returns boolean
    if ( ( GetClickedButtonBJ() == udg_DIALOG_20_KILLS ) ) then
        return true
    endif
    if ( ( GetClickedButtonBJ() == udg_DIALOG_50_KILLS ) ) then
        return true
    endif
    if ( ( GetClickedButtonBJ() == udg_DIALOG_99_KILLS ) ) then
        return true
    endif
    return false
endfunction

function Trig_Normal_Mode_Con_Func001C takes nothing returns boolean
    if ( not Trig_Normal_Mode_Con_Func001Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_Normal_Mode_Con_Func002Func001C takes nothing returns boolean
    if ( ( GetClickedButtonBJ() == udg_DIALOG_99_POINTS ) ) then
        return true
    endif
    if ( ( GetClickedButtonBJ() == udg_DIALOG_50_POINTS ) ) then
        return true
    endif
    if ( ( GetClickedButtonBJ() == udg_DIALOG_20_POINTS ) ) then
        return true
    endif
    return false
endfunction

function Trig_Normal_Mode_Con_Func002C takes nothing returns boolean
    if ( not Trig_Normal_Mode_Con_Func002Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_Normal_Mode_Con_Actions takes nothing returns nothing
    if ( Trig_Normal_Mode_Con_Func001C() ) then
        call DialogDisplayBJ( false, udg_DIALOG2, Player(0) )
        call DialogSetMessageBJ( udg_DIALOG3_DUEL, "TRIGSTR_3485" )
        call DialogAddButtonBJ( udg_DIALOG3_DUEL, "TRIGSTR_3486" )
        set udg_DIALOG_DUEL_YES = GetLastCreatedButtonBJ()
        call DialogAddButtonBJ( udg_DIALOG3_DUEL, "TRIGSTR_3487" )
        set udg_DIALOG_DUEL_NO = GetLastCreatedButtonBJ()
        set udg_Level_Set = 16
        call DialogDisplayBJ( true, udg_DIALOG3_DUEL, Player(0) )
    else
    endif
    if ( Trig_Normal_Mode_Con_Func002C() ) then
        call DialogDisplayBJ( false, udg_DIALOG4_BOMB, Player(0) )
        call DialogSetMessageBJ( udg_DIALOG3_DUEL, "TRIGSTR_3488" )
        call DialogAddButtonBJ( udg_DIALOG3_DUEL, "TRIGSTR_3489" )
        set udg_DIALOG_DUEL_YES = GetLastCreatedButtonBJ()
        call DialogAddButtonBJ( udg_DIALOG3_DUEL, "TRIGSTR_3490" )
        set udg_DIALOG_DUEL_NO = GetLastCreatedButtonBJ()
        call DialogDisplayBJ( true, udg_DIALOG3_DUEL, Player(0) )
    else
    endif
endfunction

