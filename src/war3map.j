function Trig_Get_DOT_Func001C takes nothing returns boolean
    if ( not ( udg_DT_Integers[1] == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Get_DOT_Actions takes nothing returns nothing
    if ( Trig_Get_DOT_Func001C() ) then
        call EnableTrigger( gg_trg_Deal_DOT )
    else
    endif
    set udg_DT_Integers[1] = ( udg_DT_Integers[1] + 1 )
    set udg_DT_Integers[2] = ( udg_DT_Integers[2] + 1 )
    set udg_DT_Targets[udg_DT_Integers[2]] = udg_DTA_Target
    set udg_DT_Dealers[udg_DT_Integers[2]] = udg_DTA_DmgDealer
    set udg_DT_Damage[udg_DT_Integers[2]] = udg_DTA_TotalDamageDealt
    set udg_DT_DamagePerInterval[udg_DT_Integers[2]] = ( udg_DTA_TotalDamageDealt / ( udg_DTA_Time / udg_DTA_Interval ) )
    set udg_DT_Attacktype[udg_DT_Integers[2]] = udg_DTA_Attacktype
    set udg_DT_DamageTypes[udg_DT_Integers[2]] = udg_DTA_DamageType
    set udg_DT_IntervalReals[udg_DT_Integers[2]] = ( RMaxBJ(udg_DTA_Interval, 0.01) / 0.01 )
    call AddSpecialEffectTargetUnitBJ( udg_DTA_EffectAttachmentPoint, udg_DTA_Target, udg_DTA_SpecialEffect )
    set udg_DT_Effects[udg_DT_Integers[2]] = GetLastCreatedEffectBJ()
endfunction

