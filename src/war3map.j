function Trig_Burning_Will_Cast_Func001Func002C takes nothing returns boolean
    if ( ( GetSpellAbilityId() == 'A00R' ) ) then
        return true
    endif
    if ( ( GetSpellAbilityId() == 'A04N' ) ) then
        return true
    endif
    return false
endfunction

function Trig_Burning_Will_Cast_Func001C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped('A00S', GetTriggerUnit()) > 0 ) ) then
        return false
    endif
    if ( not Trig_Burning_Will_Cast_Func001Func002C() ) then
        return false
    endif
    return true
endfunction

