//===========================================================================
// Trigger: LF
//===========================================================================
function Trig_LF_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A057' ) ) then
        return false
    endif
    return true
endfunction

function Trig_LF_Actions takes nothing returns nothing
    set udg_SR_U = GetTriggerUnit()
    set udg_SR_TempPoint = GetUnitLoc(udg_SR_U)
    set udg_SR_TempReal = I2R(GetUnitAbilityLevelSwapped(udg_SR_Spell, udg_SR_U))
    set udg_SR_Angle = 0.00
    set udg_SR_I = 1
    loop
        exitwhen udg_SR_I > ( R2I(udg_SR_RocksBase) + ( R2I(udg_SR_RocksPerLevel) * GetUnitAbilityLevelSwapped(udg_SR_Spell, udg_SR_U) ) )
        set udg_SR_Angle = ( udg_SR_Angle + ( 360.00 / ( udg_SR_RocksBase + ( udg_SR_RocksPerLevel * udg_SR_TempReal ) ) ) )
        set udg_SR_TempPoint2 = PolarProjectionBJ(udg_SR_TempPoint, udg_SR_RockDistance, udg_SR_Angle)
        set udg_SR_Angle2 = 0.00
        call CreateNUnitsAtLoc( 1, udg_SR_RockCore, GetOwningPlayer(udg_SR_U), udg_SR_TempPoint2, bj_UNIT_FACING )
        set udg_SR_TempU = GetLastCreatedUnit()
        call UnitApplyTimedLifeBJ( ( udg_SR_DurationBase + ( udg_SR_DurationPerLevel * udg_SR_TempReal ) ), 'BTLF', udg_SR_TempU )
        call SetUnitFlyHeightBJ( udg_SR_TempU, udg_SR_RockHeight, 0.00 )
        set udg_SR_I2 = 1
        loop
            exitwhen udg_SR_I2 > R2I(udg_SR_RockPairCount)
            set udg_SR_Angle2 = ( udg_SR_Angle2 + ( 360.00 / udg_SR_RockPairCount ) )
            set udg_SR_TempPoint3 = PolarProjectionBJ(udg_SR_TempPoint2, udg_SR_RockSeperationDistance, udg_SR_Angle2)
            call CreateNUnitsAtLoc( 1, udg_SR_Rock, Player(PLAYER_NEUTRAL_PASSIVE), udg_SR_TempPoint3, bj_UNIT_FACING )
            set udg_SR_TempU2 = GetLastCreatedUnit()
            set udg_SR_UHandle = GetHandleId(udg_SR_TempU2)
            call SetUnitFlyHeightBJ( udg_SR_TempU2, udg_SR_RockHeight, 0.00 )
            call SaveUnitHandleBJ( udg_SR_U, 1, udg_SR_UHandle, udg_SR_Hash )
            call SaveIntegerBJ( 4, 2, udg_SR_UHandle, udg_SR_Hash )
            call SaveUnitHandleBJ( udg_SR_TempU, 3, udg_SR_UHandle, udg_SR_Hash )
            call SaveRealBJ( udg_SR_Angle2, 6, udg_SR_UHandle, udg_SR_Hash )
            call SaveRealBJ( udg_SR_RockSeperationDistance, 7, udg_SR_UHandle, udg_SR_Hash )
            call SaveRealBJ( udg_SR_RockHeight, 8, udg_SR_UHandle, udg_SR_Hash )
            call GroupAddUnitSimple( udg_SR_TempU2, udg_SR_Rocks )
            call RemoveLocation(udg_SR_TempPoint3)
            set udg_SR_I2 = udg_SR_I2 + 1
        endloop
        set udg_SR_UHandle = GetHandleId(udg_SR_TempU)
        call CreateNUnitsAtLoc( 1, udg_SR_SummonSFX, Player(PLAYER_NEUTRAL_PASSIVE), udg_SR_TempPoint2, bj_UNIT_FACING )
        call SetUnitFlyHeightBJ( GetLastCreatedUnit(), udg_SR_RockHeight, 0.00 )
        call UnitApplyTimedLifeBJ( udg_SR_SummonSFXDuration, 'BTLF', GetLastCreatedUnit() )
        call SaveUnitHandleBJ( udg_SR_U, 1, udg_SR_UHandle, udg_SR_Hash )
        call SaveIntegerBJ( 1, 2, udg_SR_UHandle, udg_SR_Hash )
        call SaveRealBJ( ( udg_SR_RockDamageBase + ( udg_SR_RockDamagePerLevel * udg_SR_TempReal ) ), 3, udg_SR_UHandle, udg_SR_Hash )
        call SaveRealBJ( ( udg_SR_RockSearchAoeBase + ( udg_SR_RockSearchAoePerLevel * udg_SR_TempReal ) ), 4, udg_SR_UHandle, udg_SR_Hash )
        call SaveRealBJ( ( udg_SR_MoveSpeedBase + ( udg_SR_MoveSpeedPerLevel * udg_SR_TempReal ) ), 5, udg_SR_UHandle, udg_SR_Hash )
        call SaveRealBJ( udg_SR_Angle, 6, udg_SR_UHandle, udg_SR_Hash )
        call SaveRealBJ( udg_SR_RockHeight, 8, udg_SR_UHandle, udg_SR_Hash )
        call SaveUnitHandleBJ( udg_SR_U, 9, udg_SR_UHandle, udg_SR_Hash )
        call GroupAddUnitSimple( udg_SR_TempU, udg_SR_Rocks )
        call RemoveLocation(udg_SR_TempPoint2)
        set udg_SR_I = udg_SR_I + 1
    endloop
    call EnableTrigger( gg_trg_LF_Loop )
    call EnableTrigger( gg_trg_LF_Rem )
    call RemoveLocation(udg_SR_TempPoint)
endfunction

//===========================================================================
function InitTrig_LF takes nothing returns nothing
    set gg_trg_LF = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_LF, EVENT_PLAYER_UNIT_SPELL_EFFECT )
    call TriggerAddCondition( gg_trg_LF, Condition( function Trig_LF_Conditions ) )
    call TriggerAddAction( gg_trg_LF, function Trig_LF_Actions )
endfunction

