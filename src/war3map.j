    return true
endfunction

function Trig_Knockback_2D_Actions takes nothing returns nothing
    set udg_K2DTimeout = 0.03
    set udg_CenterPoint = Location(udg_TempX, udg_TempY)
    set udg_UnitIndexerEnabled = false
    call CreateNUnitsAtLoc( 1, 'h005', Player(PLAYER_NEUTRAL_PASSIVE), udg_CenterPoint, 0.00 )
    set udg_K2DCaster = GetLastCreatedUnit()
    call CreateNUnitsAtLoc( 1, 'h005', Player(PLAYER_NEUTRAL_PASSIVE), udg_CenterPoint, 0.00 )
    set udg_K2DClearer = GetLastCreatedUnit()
    set udg_UnitIndexerEnabled = true
    call RemoveLocation(udg_CenterPoint)
    set udg_K2DPathAbil = 'A06H'
    call UnitAddAbilityBJ( udg_K2DPathAbil, udg_K2DCaster )
    set udg_K2DDebrisAbil = 'A06G'
    call UnitAddAbilityBJ( udg_K2DDebrisAbil, udg_K2DClearer )
        call ExecuteFunc("InitKnockback2D")
    endfunction
    function DestroyKnockback2D takes nothing returns nothing
    set udg_IsUnitBeingKnockedBack[udg_UDex] = false
    set udg_K2DNext[udg_K2DPrev[udg_UDex]] = udg_K2DNext[udg_UDex]
    set udg_K2DPrev[udg_K2DNext[udg_UDex]] = udg_K2DPrev[udg_UDex]
    set udg_K2DPrev[udg_UDex] = 0
    endfunction
    function DestroyKnockback2DProxy takes nothing returns boolean
    if ( Trig_Knockback_2D_Func023C() ) then
        call DestroyKnockback2D()
    else
    endif
        return false
    endfunction
    function Knockback2DApplyAngle takes nothing returns nothing
    set udg_K2DCos[udg_UDex] = CosBJ(udg_K2DAngle[udg_UDex])
    set udg_K2DSin[udg_UDex] = SinBJ(udg_K2DAngle[udg_UDex])
    endfunction
    function Knockback2DCheckXY takes real x, real y returns boolean
        set udg_TempX = x + udg_K2DVelocity[udg_UDex] * udg_K2DCos[udg_UDex]
        set udg_TempY = y + udg_K2DVelocity[udg_UDex] * udg_K2DSin[udg_UDex]
        return IssuePointOrderById(udg_K2DCaster, 0xD0100, udg_TempX, udg_TempY)
    endfunction
    function Knockback2DSetup takes nothing returns nothing
    if ( Trig_Knockback_2D_Func036C() ) then
        set udg_UDex = GetUnitUserData(udg_Knockback2DUnit)
        if ( Trig_Knockback_2D_Func036Func002C() ) then
            if ( Trig_Knockback_2D_Func036Func002Func001C() ) then
                call PauseTimerBJ( false, udg_K2DTimer )
            else
            endif
            set udg_IsUnitBeingKnockedBack[udg_UDex] = true
            set udg_K2DPrev[udg_K2DNext[0]] = udg_UDex
            set udg_K2DNext[udg_UDex] = udg_K2DNext[0]
            set udg_K2DNext[0] = udg_UDex
        else
        endif
        set udg_K2DAngle[udg_UDex] = udg_Knockback2DAngle
        call Knockback2DApplyAngle()
        set udg_K2DTimeLeft[udg_UDex] = udg_Knockback2DTime
        set udg_K2DVelocity[udg_UDex] = ( ( udg_Knockback2DDistance / udg_Knockback2DTime ) * ( udg_K2DTimeout * 2.00 ) )
        set udg_K2DFriction[udg_UDex] = ( ( udg_K2DVelocity[udg_UDex] / udg_Knockback2DTime ) * ( udg_K2DTimeout * udg_K2DTimeout ) )
        set udg_TempX = GetUnitX(udg_Knockback2DUnit)
        set udg_TempY = GetUnitY(udg_Knockback2DUnit)
        if not IsUnitInRangeXY(udg_Knockback2DUnit, udg_TempX + 17, udg_TempY, 0) then
        set udg_K2DRadius[udg_UDex] = 1
        elseif not IsUnitInRangeXY(udg_Knockback2DUnit, udg_TempX + 33, udg_TempY, 0) then
        set udg_K2DRadius[udg_UDex] = 2
        elseif not IsUnitInRangeXY(udg_Knockback2DUnit, udg_TempX + 49, udg_TempY, 0) then
        set udg_K2DRadius[udg_UDex] = 3
        else
        set udg_K2DRadius[udg_UDex] = 4
        endif
    else
    endif
    endfunction
    function Knockback2DLooper takes nothing returns nothing
        local real x
        local real y
    call PauseUnitBJ( false, udg_K2DCaster )
    set udg_UDex = udg_K2DNext[0]
        loop
            exitwhen udg_UDex == 0
    set udg_K2DTimeLeft[udg_UDex] = ( udg_K2DTimeLeft[udg_UDex] - udg_K2DTimeout )
    if ( Trig_Knockback_2D_Func046C() ) then
        set udg_TempUnit = udg_UDexUnits[udg_UDex]
        set udg_K2DVelocity[udg_UDex] = ( udg_K2DVelocity[udg_UDex] - udg_K2DFriction[udg_UDex] )
        set x = GetUnitX(udg_UDexUnits[udg_UDex])
        set y = GetUnitY(udg_UDexUnits[udg_UDex])
        call SetUnitAbilityLevelSwapped( udg_K2DPathAbil, udg_K2DCaster, udg_K2DRadius[udg_UDex] )
        if not Knockback2DCheckXY(x, y) then
        set udg_K2DAngle[udg_UDex] = ( 360.00 - udg_K2DAngle[udg_UDex] )
            call Knockback2DApplyAngle()
            if not Knockback2DCheckXY(x, y) then
        set udg_K2DAngle[udg_UDex] = ModuloReal(( udg_K2DAngle[udg_UDex] + 180.00 ), 360.00)
                call Knockback2DApplyAngle()
                if not Knockback2DCheckXY(x, y) then
        set udg_K2DAngle[udg_UDex] = ( 360.00 - udg_K2DAngle[udg_UDex] )
                    call Knockback2DApplyAngle()
                    set udg_TempX = x
                    set udg_TempY = y
                endif
            endif
        endif
        call SetUnitX(udg_TempUnit, udg_TempX)
        call SetUnitY(udg_TempUnit, udg_TempY)
    else
        //  
        // The knockback has finished
        //  
        call DestroyKnockback2D()
    endif
    set udg_UDex = udg_K2DNext[udg_UDex]
        endloop
    call PauseUnitBJ( true, udg_K2DCaster )
    if ( Trig_Knockback_2D_Func050C() ) then
        set udg_K2Dex = udg_K2DNext[udg_K2Dex]
        if ( Trig_Knockback_2D_Func050Func002C() ) then
            set udg_K2Dex = udg_K2DNext[0]
        else
        endif
        call SetUnitAbilityLevelSwapped( udg_K2DDebrisAbil, udg_K2DClearer, udg_K2DRadius[udg_K2Dex] )
        call IssuePointOrderById(udg_K2DClearer, 0xD0208, GetUnitX(udg_UDexUnits[udg_K2Dex]), GetUnitY(udg_UDexUnits[udg_K2Dex]))
        call PauseTimerBJ( false, udg_K2DTimer )
    else
    endif
    endfunction
    function InitKnockback2D takes nothing returns nothing
        local trigger t = GetTriggeringTrigger()
        call TriggerClearActions(t)
        call TriggerRegisterVariableEvent(t, "udg_UnitIndexEvent", EQUAL, 2)
        call TriggerAddCondition(t, Filter(function DestroyKnockback2DProxy))
        call TriggerAddAction(t, function Knockback2DSetup)
        set t = null
        call UnitRemoveAbility(udg_K2DCaster, 'Amov')
        call UnitRemoveAbility(udg_K2DClearer, 'Amov')
        call TimerStart(udg_K2DTimer, udg_K2DTimeout, false, function Knockback2DLooper)
    call PauseTimerBJ( true, udg_K2DTimer )
endfunction

