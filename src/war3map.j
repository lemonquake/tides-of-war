                set udg_RA_Counter[udg_RA_Integers[2]] = ( udg_RA_Counter[udg_RA_Integers[2]] + ( 100.00 / ( RMaxBJ(udg_RA_Duration[udg_RA_Integers[2]], 0.05) / 0.05 ) ) )
                call SetUnitVertexColorBJ( udg_RA_Dummy[udg_RA_Integers[2]], 100, udg_RA_Color[udg_RA_Integers[2]], udg_RA_Color[udg_RA_Integers[2]], udg_RA_Counter[udg_RA_Integers[2]] )
                if ( Trig_RA2_Func001Func001Func001Func008C() ) then
                    call SetUnitFlyHeightBJ( udg_RA_Dummy[udg_RA_Integers[2]], ( udg_RA_Counter[udg_RA_Integers[2]] * 3.00 ), 0.00 )
                else
                endif
            else
                call RemoveUnit( udg_RA_Dummy[udg_RA_Integers[2]] )
                set udg_RA_Counter[udg_RA_Integers[2]] = 0.00
                set udg_RA_Dummy[udg_RA_Integers[2]] = null
                set udg_RA_Integers[0] = ( udg_RA_Integers[0] - 1 )
                if ( Trig_RA2_Func001Func001Func001Func007C() ) then
