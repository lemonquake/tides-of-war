//===========================================================================
// Trigger: Wind Strike
//===========================================================================
function Trig_Wind_Strike_Conditions takes nothing returns boolean
    if ( not ( UnitHasBuffBJ(udg_GDD_DamageSource, 'B00Z') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Wind_Strike_Func001Func001C takes nothing returns boolean
    if ( not ( GetUnitTypeId(udg_GDD_DamageSource) == 'H00Z' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Wind_Strike_Func001C takes nothing returns boolean
    if ( not ( GetUnitTypeId(udg_GDD_DamageSource) != 'H00Z' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Wind_Strike_Actions takes nothing returns nothing
    if ( Trig_Wind_Strike_Func001C() ) then
        set udg_WindStrike = ( I2R(GetHeroStatBJ(bj_HEROSTAT_AGI, udg_GDD_DamageSource, true)) * 1.25 )
        call UnitDamageTargetBJ( udg_GDD_DamageSource, udg_GDD_DamagedUnit, udg_WindStrike, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_ENHANCED )
        call CreateTextTagUnitBJ( ( udg_PlayerColors[GetConvertedPlayerId(GetOwningPlayer(udg_GDD_DamageSource))] + I2S(R2I(( udg_GDD_Damage + udg_WindStrike ))) ), udg_GDD_DamagedUnit, 0.00, 8.50, 100.00, 100.00, 100.00, 0 )
        call SetTextTagVelocityBJ( GetLastCreatedTextTag(), 100.00, 90.00 )
        call SetTextTagPermanentBJ( GetLastCreatedTextTag(), false )
        call SetTextTagLifespanBJ( GetLastCreatedTextTag(), udg_Text_Duration )
        call SetTextTagFadepointBJ( GetLastCreatedTextTag(), 0.65 )
    else
        if ( Trig_Wind_Strike_Func001Func001C() ) then
            set udg_PowerStance = ( 0.25 * ( I2R(GetHeroStatBJ(bj_HEROSTAT_AGI, udg_GDD_DamageSource, true)) + I2R(GetHeroStatBJ(bj_HEROSTAT_INT, udg_GDD_DamageSource, true)) ) )
            set udg_WindStrike = ( I2R(GetHeroStatBJ(bj_HEROSTAT_AGI, udg_GDD_DamageSource, true)) * ( 0.55 + ( 0.20 * I2R(GetUnitAbilityLevelSwapped('A00M', udg_GDD_DamageSource)) ) ) )
            set udg_PS_and_WS = ( udg_PowerStance + udg_WindStrike )
            call UnitDamageTargetBJ( udg_GDD_DamageSource, udg_GDD_DamagedUnit, udg_PS_and_WS, ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL )
            call CreateTextTagUnitBJ( ( udg_PlayerColors[GetConvertedPlayerId(GetOwningPlayer(udg_GDD_DamageSource))] + ( R2S(udg_GDD_Damage) + ( "|r + " + ( "|cffff8c00" + ( R2S(udg_PS_and_WS) + "|r" ) ) ) ) ), udg_GDD_DamagedUnit, 0.00, 8.50, 100.00, 100.00, 100.00, 0 )
            call SetTextTagVelocityBJ( GetLastCreatedTextTag(), 100.00, 90.00 )
            call SetTextTagPermanentBJ( GetLastCreatedTextTag(), false )
            call SetTextTagLifespanBJ( GetLastCreatedTextTag(), udg_Text_Duration )
            call SetTextTagFadepointBJ( GetLastCreatedTextTag(), 0.65 )
        else
        endif
    endif
endfunction

