//===========================================================================
// Trigger: Smite Loop
//===========================================================================
function Trig_Smite_Loop_Func001Func003Func009Func002001003001001 takes nothing returns boolean
    return ( IsUnitAliveBJ(GetFilterUnit()) == true )
endfunction

function Trig_Smite_Loop_Func001Func003Func009Func002001003001002 takes nothing returns boolean
    return ( IsUnitEnemy(GetFilterUnit(), GetOwningPlayer(udg_Smite_Projectile)) == true )
endfunction

function Trig_Smite_Loop_Func001Func003Func009Func002001003001 takes nothing returns boolean
    return GetBooleanAnd( Trig_Smite_Loop_Func001Func003Func009Func002001003001001(), Trig_Smite_Loop_Func001Func003Func009Func002001003001002() )
endfunction

function Trig_Smite_Loop_Func001Func003Func009Func002001003002 takes nothing returns boolean
    return ( GetUnitAbilityLevelSwapped('A00A', GetFilterUnit()) < 1 )
endfunction

function Trig_Smite_Loop_Func001Func003Func009Func002001003 takes nothing returns boolean
    return GetBooleanAnd( Trig_Smite_Loop_Func001Func003Func009Func002001003001(), Trig_Smite_Loop_Func001Func003Func009Func002001003002() )
endfunction

function Trig_Smite_Loop_Func001Func003Func009Func002A takes nothing returns nothing
    call UnitDamageTargetBJ( udg_Smite_Projectile, GetEnumUnit(), ( 150.00 + ( 0.20 * GetUnitStateSwap(UNIT_STATE_MAX_LIFE, GetEnumUnit()) ) ), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_ENHANCED )
    call GroupAddUnitSimple( GetEnumUnit(), udg_Smite_Group2 )
    set udg_Smite_Point3 = GetUnitLoc(GetEnumUnit())
    set udg_Smite_Angle = AngleBetweenPoints(udg_Smite_Point2, udg_Smite_Point3)
    set udg_Smite_Timer = 1.50
    set udg_Smite_Distance = 150.00
    call SaveRealBJ( udg_Smite_Timer, 1, GetHandleIdBJ(GetEnumUnit()), udg_Smite_Hash )
    call SaveRealBJ( udg_Smite_Angle, 2, GetHandleIdBJ(GetEnumUnit()), udg_Smite_Hash )
    call SaveRealBJ( udg_Smite_Distance, 3, GetHandleIdBJ(GetEnumUnit()), udg_Smite_Hash )
    set udg_Smite_Loop = ( udg_Smite_Loop + 1 )
    call RemoveLocation(udg_Smite_Point3)
endfunction

function Trig_Smite_Loop_Func001Func003Func009Func008001001003 takes nothing returns boolean
    return ( IsUnitEnemy(GetFilterUnit(), GetOwningPlayer(udg_Smite_Projectile)) == true )
endfunction

function Trig_Smite_Loop_Func001Func003Func009C takes nothing returns boolean
    set bj_wantDestroyGroup = true
    if ( not ( CountUnitsInGroupBJ(GetUnitsInRangeOfLocMatching(udg_Smite_AOE, udg_Smite_Point2, Condition(function Trig_Smite_Loop_Func001Func003Func009Func008001001003))) == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Smite_Loop_Func001Func003C takes nothing returns boolean
    if ( not ( udg_Smite_Timer > 0.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Smite_Loop_Func001A takes nothing returns nothing
    set udg_Smite_Timer = LoadRealBJ(1, GetHandleIdBJ(GetEnumUnit()), udg_Smite_Hash)
    set udg_Smite_Projectile = GetEnumUnit()
    if ( Trig_Smite_Loop_Func001Func003C() ) then
        call SaveRealBJ( ( udg_Smite_Timer - 0.04 ), 1, GetHandleIdBJ(GetEnumUnit()), udg_Smite_Hash )
        set udg_Smite_Point1 = GetUnitLoc(udg_Smite_Projectile)
        set udg_Smite_Point2 = PolarProjectionBJ(GetUnitLoc(udg_Smite_Projectile), 30.00, GetUnitFacing(udg_Smite_Projectile))
        call SetUnitPositionLoc( udg_Smite_Projectile, udg_Smite_Point2 )
        set bj_wantDestroyGroup = true
        if ( Trig_Smite_Loop_Func001Func003Func009C() ) then
            set bj_wantDestroyGroup = true
            call ForGroupBJ( GetUnitsInRangeOfLocMatching(300.00, udg_Smite_Point2, Condition(function Trig_Smite_Loop_Func001Func003Func009Func002001003)), function Trig_Smite_Loop_Func001Func003Func009Func002A )
            call ExplodeUnitBJ( udg_Smite_Projectile )
            call AddSpecialEffectLocBJ( udg_Smite_Point2, "war3mapImported\\AquaSpike.mdx" )
            call DestroyEffectBJ( GetLastCreatedEffectBJ() )
            set udg_Smite_Timer = 0.00
            call SaveRealBJ( udg_Smite_Timer, 1, GetHandleIdBJ(GetEnumUnit()), udg_Smite_Hash )
        else
        endif
        call RemoveLocation(udg_Smite_Point1)
        call RemoveLocation(udg_Smite_Point2)
    else
        call FlushChildHashtableBJ( GetHandleIdBJ(GetEnumUnit()), udg_Smite_Hash )
        call ExplodeUnitBJ( udg_Smite_Projectile )
        call GroupRemoveUnitSimple( udg_Smite_Projectile, udg_Smite_Group1 )
    endif
endfunction

function Trig_Smite_Loop_Func002Func002Func004C takes nothing returns boolean
    if ( not ( udg_Smite_Loop == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Smite_Loop_Func002Func002Func006Func004C takes nothing returns boolean
    if ( not ( udg_Smite_Loop == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Smite_Loop_Func002Func002Func006C takes nothing returns boolean
    if ( not ( udg_Smite_Timer > 0.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Smite_Loop_Func002Func002C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(udg_Smite_KB_Unit) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Smite_Loop_Func002A takes nothing returns nothing
    set udg_Smite_KB_Unit = GetEnumUnit()
    if ( Trig_Smite_Loop_Func002Func002C() ) then
        set udg_Smite_Timer = LoadRealBJ(1, GetHandleIdBJ(GetEnumUnit()), udg_Smite_Hash)
        if ( Trig_Smite_Loop_Func002Func002Func006C() ) then
            call SaveRealBJ( ( udg_Smite_Timer - 0.04 ), 1, GetHandleIdBJ(GetEnumUnit()), udg_Smite_Hash )
            set udg_Smite_Angle = LoadRealBJ(2, GetHandleIdBJ(GetEnumUnit()), udg_Smite_Hash)
            set udg_Smite_Distance = LoadRealBJ(3, GetHandleIdBJ(GetEnumUnit()), udg_Smite_Hash)
            set udg_Smite_Point1 = GetUnitLoc(udg_Smite_KB_Unit)
            set udg_Smite_Point2 = PolarProjectionBJ(udg_Smite_Point1, udg_Smite_Distance, udg_Smite_Angle)
            call SetUnitX(udg_Smite_KB_Unit, GetLocationX(udg_Smite_Point2))
            call SetUnitY(udg_Smite_KB_Unit, GetLocationY(udg_Smite_Point2))
            call AddSpecialEffectTargetUnitBJ( "origin", udg_Smite_KB_Unit, "Abilities\\Spells\\Human\\FlakCannons\\FlakTarget.mdl" )
            call DestroyEffectBJ( GetLastCreatedEffectBJ() )
            call IssueImmediateOrderBJ( udg_Smite_KB_Unit, "stop" )
        else
            call FlushChildHashtableBJ( GetHandleIdBJ(GetEnumUnit()), udg_Smite_Hash )
            call GroupRemoveUnitSimple( GetEnumUnit(), udg_Smite_Group2 )
            set udg_Smite_Loop = ( udg_Smite_Loop - 1 )
            if ( Trig_Smite_Loop_Func002Func002Func006Func004C() ) then
                call DisableTrigger( GetTriggeringTrigger() )
            else
            endif
        endif
    else
        call FlushChildHashtableBJ( GetHandleIdBJ(GetEnumUnit()), udg_Smite_Hash )
        call GroupRemoveUnitSimple( udg_Smite_KB_Unit, udg_Smite_Group2 )
        set udg_Smite_Loop = ( udg_Smite_Loop - 1 )
        if ( Trig_Smite_Loop_Func002Func002Func004C() ) then
            call DisableTrigger( GetTriggeringTrigger() )
        else
        endif
    endif
        call RemoveLocation(udg_Smite_Point1)
            call RemoveLocation(udg_Smite_Point2)
endfunction

function Trig_Smite_Loop_Actions takes nothing returns nothing
    call ForGroupBJ( udg_Smite_Group1, function Trig_Smite_Loop_Func001A )
    call ForGroupBJ( udg_Smite_Group2, function Trig_Smite_Loop_Func002A )
endfunction

//===========================================================================
function InitTrig_Smite_Loop takes nothing returns nothing
    set gg_trg_Smite_Loop = CreateTrigger(  )
    call DisableTrigger( gg_trg_Smite_Loop )
    call TriggerRegisterTimerEventPeriodic( gg_trg_Smite_Loop, 0.04 )
    call TriggerAddAction( gg_trg_Smite_Loop, function Trig_Smite_Loop_Actions )
endfunction

//===========================================================================
