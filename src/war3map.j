    return true
endfunction

function Trig_Curse_of_the_Sea_Func002C takes nothing returns boolean
    if ( not ( udg_Chance <= 25 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Curse_of_the_Sea_Actions takes nothing returns nothing
    set udg_Chance = GetRandomInt(1, 100)
    if ( Trig_Curse_of_the_Sea_Func002C() ) then
        call CreateUnit(GetOwningPlayer(udg_GDD_DamageSource), 'h005', GetUnitX(udg_GDD_DamagedUnit), GetUnitY(udg_GDD_DamagedUnit), bj_UNIT_FACING)
        call UnitAddAbilityBJ( 'A02Y', GetLastCreatedUnit() )
        call IssueTargetOrderBJ( GetLastCreatedUnit(), "doom", udg_GDD_DamagedUnit )
        call UnitApplyTimedLifeBJ( 2.00, 'BTLF', GetLastCreatedUnit() )
