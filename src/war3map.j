function Trig_On_Revival_Func001C takes nothing returns boolean
    if ( not ( udg_IsUnitReincarnating[udg_UDex] == true ) ) then
        return false
    endif
    if ( not ( IsUnitType(udg_UDexUnits[udg_UDex], UNIT_TYPE_HERO) == true ) ) then
        return false
    endif
    return true
endfunction

