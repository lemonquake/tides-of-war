//===========================================================================
// Trigger: NN Forceb
//===========================================================================
function Trig_NN_Forceb_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'A056' ) ) then
        return false
    endif
    return true
endfunction

function Trig_NN_Forceb_Func003Func010Func010C takes nothing returns boolean
    if ( ( GetSpellTargetUnit() == GetTriggerUnit() ) ) then
        return true
    endif
    if ( ( GetItemTypeId(GetSpellTargetItem()) == 'I00Y' ) ) then
        return true
    endif
    return false
endfunction

function Trig_NN_Forceb_Func003Func010C takes nothing returns boolean
    if ( not Trig_NN_Forceb_Func003Func010Func010C() ) then
        return false
    endif
    return true
endfunction

function Trig_NN_Forceb_Func003C takes nothing returns boolean
    if ( not ( GetSpellTargetUnit() != GetTriggerUnit() ) ) then
        return false
    endif
    return true
endfunction

function Trig_NN_Forceb_Actions takes nothing returns nothing
    if ( Trig_NN_Forceb_Func003C() ) then
        set udg_CenterPoint = GetUnitLoc(GetTriggerUnit())
        set udg_TargetPoint = GetUnitLoc(GetSpellTargetUnit())
        set udg_Knockback2DAngle = AngleBetweenPoints(udg_CenterPoint, udg_TargetPoint)
        call RemoveLocation(udg_CenterPoint)
        call RemoveLocation(udg_TargetPoint)
        set udg_Knockback2DTime = 0.80
        set udg_Knockback2DDistance = 600.00
        set udg_Knockback2DUnit = GetSpellTargetUnit()
        call TriggerExecute( gg_trg_Knockback_2D )
    else
        if ( Trig_NN_Forceb_Func003Func010C() ) then
            set udg_CenterPoint = GetUnitLoc(GetTriggerUnit())
            set udg_TargetPoint = GetUnitLoc(GetTriggerUnit())
            set udg_Knockback2DAngle = GetUnitFacing(GetTriggerUnit())
            call RemoveLocation(udg_CenterPoint)
            call RemoveLocation(udg_TargetPoint)
            set udg_Knockback2DTime = 0.80
            set udg_Knockback2DDistance = 600.00
            set udg_Knockback2DUnit = GetTriggerUnit()
            call TriggerExecute( gg_trg_Knockback_2D )
        else
        endif
    endif
endfunction

