    call UnitDamageTargetBJ( udg_GDD_DamageSource, udg_GDD_DamagedUnit, ( GetUnitStateSwap(UNIT_STATE_LIFE, udg_GDD_DamagedUnit) * 0.12 ), ATTACK_TYPE_CHAOS, DAMAGE_TYPE_FIRE )
