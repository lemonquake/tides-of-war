// Trigger: Combat Periodic
//===========================================================================
function Trig_Combat_Periodic_Func001Func001Func009C takes nothing returns boolean
    if ( not ( udg_Combat_Index2 == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Combat_Periodic_Func001Func001C takes nothing returns boolean
    if ( not ( udg_Combat_Time[udg_Combat_Index1] > 0.00 ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(udg_Combat_Unit[udg_Combat_Index1]) == true ) ) then
        return false
    endif
    if ( not ( IsUnitInGroup(udg_Combat_Unit[udg_Combat_Index1], udg_Combat_Group) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Combat_Periodic_Actions takes nothing returns nothing
    set udg_Combat_Index1 = 1
    loop
        exitwhen udg_Combat_Index1 > udg_Combat_Index2
        if ( Trig_Combat_Periodic_Func001Func001C() ) then
            set udg_Combat_Time[udg_Combat_Index1] = ( udg_Combat_Time[udg_Combat_Index1] - 1 )
        else
            call GroupRemoveUnitSimple( udg_Combat_Unit[udg_Combat_Index1], udg_Combat_Group )
            set udg_CombatState_Unit = udg_Combat_Unit[udg_Combat_Index1]
            set udg_Combat_Event = 2.00
            set udg_Combat_Event = 0.00
            set udg_Combat_Unit[udg_Combat_Index1] = udg_Combat_Unit[udg_Combat_Index2]
            set udg_Combat_Time[udg_Combat_Index1] = udg_Combat_Time[udg_Combat_Index2]
            set udg_Combat_Index2 = ( udg_Combat_Index2 - 1 )
            set udg_Combat_Index1 = ( udg_Combat_Index1 - 1 )
            if ( Trig_Combat_Periodic_Func001Func001Func009C() ) then
                call DisableTrigger( GetTriggeringTrigger() )
            else
            endif
        endif
        set udg_Combat_Index1 = udg_Combat_Index1 + 1
    endloop
endfunction

