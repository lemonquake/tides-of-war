//===========================================================================
function Trig_Gentle_Wind_Actions takes nothing returns nothing
    call UnitAddAbilityBJ( 'A04T', GetTriggerUnit() )
    call ModifyHeroStat( bj_HEROSTAT_AGI, GetTriggerUnit(), bj_MODIFYMETHOD_ADD, 60 )
    call TriggerSleepAction( 10.00 )
    call ModifyHeroStat( bj_HEROSTAT_AGI, GetTriggerUnit(), bj_MODIFYMETHOD_SUB, 60 )
    call UnitRemoveAbilityBJ( 'A04T', GetTriggerUnit() )
endfunction

