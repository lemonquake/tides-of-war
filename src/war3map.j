// Trigger: Init Trigger
//===========================================================================
function Trig_Init_Trigger_Actions takes nothing returns nothing
    // -
    set udg_SpellEventAbility[1] = 'A02K'
    set udg_SpellEventAbility[2] = 'A02U'
    set udg_SpellEventAbility[3] = 'A05Q'
    set udg_SpellEventAbility[4] = 'A100'
    set udg_SpellEventAbility[5] = 'A004'
    set udg_SpellEventAbility[6] = 'A00B'
    set udg_SpellEventAbility[7] = 'A05L'
    set udg_SpellEventAbility[8] = 'A02Z'
    set udg_SpellEventAbility[9] = 'A017'
    set udg_SpellEventAbility[10] = 'A014'
    set udg_SpellEventAbility[11] = 'A016'
