//===========================================================================
// Trigger: PS Loop
//
// 
//===========================================================================
function Trig_PS_Loop_Func001Func001Func001Func001Func012Func001Func007001001 takes nothing returns boolean
    return ( udg_PS_Heal[udg_PS_Integers[3]] != true )
endfunction

function Trig_PS_Loop_Func001Func001Func001Func001Func012Func001Func007001002 takes nothing returns boolean
    return ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(udg_PS_Caster[udg_PS_Integers[3]])) == true )
endfunction

function Trig_PS_Loop_Func001Func001Func001Func001Func012Func001Func007001 takes nothing returns boolean
    return GetBooleanAnd( Trig_PS_Loop_Func001Func001Func001Func001Func012Func001Func007001001(), Trig_PS_Loop_Func001Func001Func001Func001Func012Func001Func007001002() )
endfunction

function Trig_PS_Loop_Func001Func001Func001Func001Func012Func001Func007002001 takes nothing returns boolean
    return ( udg_PS_Heal[udg_PS_Integers[3]] == true )
endfunction

function Trig_PS_Loop_Func001Func001Func001Func001Func012Func001Func007002002 takes nothing returns boolean
    return ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(udg_PS_Caster[udg_PS_Integers[3]])) != true )
endfunction

function Trig_PS_Loop_Func001Func001Func001Func001Func012Func001Func007002 takes nothing returns boolean
    return GetBooleanAnd( Trig_PS_Loop_Func001Func001Func001Func001Func012Func001Func007002001(), Trig_PS_Loop_Func001Func001Func001Func001Func012Func001Func007002002() )
endfunction

function Trig_PS_Loop_Func001Func001Func001Func001Func012Func001C takes nothing returns boolean
    if ( not ( IsUnitType(GetEnumUnit(), UNIT_TYPE_STRUCTURE) != true ) ) then
        return false
    endif
    if ( not ( IsUnitType(GetEnumUnit(), UNIT_TYPE_MAGIC_IMMUNE) != true ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetEnumUnit()) == true ) ) then
        return false
    endif
    if ( not GetBooleanOr( Trig_PS_Loop_Func001Func001Func001Func001Func012Func001Func007001(), Trig_PS_Loop_Func001Func001Func001Func001Func012Func001Func007002() ) ) then
        return false
    endif
    return true
endfunction

function Trig_PS_Loop_Func001Func001Func001Func001Func012A takes nothing returns nothing
    if ( Trig_PS_Loop_Func001Func001Func001Func001Func012Func001C() ) then
        call CreateNUnitsAtLoc( 1, 'h005', GetOwningPlayer(udg_PS_Caster[udg_PS_Integers[3]]), GetUnitLoc(GetEnumUnit()), bj_UNIT_FACING )
        call IssueTargetOrderBJ( GetLastCreatedUnit(), "frostnova", GetEnumUnit() )
        call UnitApplyTimedLifeBJ( 1.00, 'BTLF', GetLastCreatedUnit() )
        call UnitDamageTargetBJ( udg_PS_Caster[udg_PS_Integers[3]], GetEnumUnit(), udg_PS_Damage[udg_PS_Integers[3]], ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL )
        set udg_PS_TempLoc2 = GetUnitLoc(GetEnumUnit())
        call AddSpecialEffectLocBJ( udg_PS_TempLoc2, udg_PS_Target_Sfx[udg_PS_Integers[3]] )
        call DestroyEffectBJ( GetLastCreatedEffectBJ() )
        call RemoveLocation (udg_PS_TempLoc2)
    else
    endif
endfunction

function Trig_PS_Loop_Func001Func001Func001Func001Func013Func001Func001C takes nothing returns boolean
    if ( not ( IsDestructableAliveBJ(GetEnumDestructable()) == true ) ) then
        return false
    endif
    if ( not ( IsDestructableInvulnerableBJ(GetEnumDestructable()) != true ) ) then
        return false
    endif
    return true
endfunction

function Trig_PS_Loop_Func001Func001Func001Func001Func013Func001A takes nothing returns nothing
    if ( Trig_PS_Loop_Func001Func001Func001Func001Func013Func001Func001C() ) then
        call KillDestructable( GetEnumDestructable() )
        set udg_PS_TempLoc2 = GetDestructableLoc(GetEnumDestructable())
        call AddSpecialEffectLocBJ( udg_PS_TempLoc2, udg_PS_Destroy_Trees_Sfx[udg_PS_Integers[3]] )
        call DestroyEffectBJ( GetLastCreatedEffectBJ() )
        call RemoveLocation (udg_PS_TempLoc2)
    else
    endif
endfunction

function Trig_PS_Loop_Func001Func001Func001Func001Func013C takes nothing returns boolean
    if ( not ( udg_PS_Trees_Destroy[udg_PS_Integers[3]] == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_PS_Loop_Func001Func001Func001Func001C takes nothing returns boolean
    if ( not ( udg_PS_Damage_Interval_Reached[udg_PS_Integers[3]] < udg_PS_Damage_Interval[udg_PS_Integers[3]] ) ) then
        return false
    endif
    return true
endfunction

function Trig_PS_Loop_Func001Func001Func001Func004C takes nothing returns boolean
    if ( not ( udg_PS_Integers[1] == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_PS_Loop_Func001Func001Func001C takes nothing returns boolean
    if ( not ( udg_PS_Damage_Count_Released[udg_PS_Integers[3]] < udg_PS_Damage_Count[udg_PS_Integers[3]] ) ) then
        return false
    endif
    return true
endfunction

function Trig_PS_Loop_Func001Func001C takes nothing returns boolean
    if ( not ( IsUnitInGroup(udg_PS_Caster[udg_PS_Integers[3]], udg_PS_Group) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_PS_Loop_Actions takes nothing returns nothing
    set udg_PS_Integers[3] = 1
    loop
        exitwhen udg_PS_Integers[3] > udg_PS_Integers[2]
        if ( Trig_PS_Loop_Func001Func001C() ) then
            if ( Trig_PS_Loop_Func001Func001Func001C() ) then
                if ( Trig_PS_Loop_Func001Func001Func001Func001C() ) then
                    set udg_PS_Damage_Interval_Reached[udg_PS_Integers[3]] = ( udg_PS_Damage_Interval_Reached[udg_PS_Integers[3]] + 0.05 )
                    set udg_PS_TempLoc1 = GetUnitLoc(udg_PS_Caster[udg_PS_Integers[3]])
                    call AddSpecialEffectLocBJ( udg_PS_TempLoc1, udg_PS_Caster_Sfx[udg_PS_Integers[3]] )
                    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
                    call RemoveLocation (udg_PS_TempLoc1)
                else
                    set udg_PS_Damage_Interval_Reached[udg_PS_Integers[3]] = 0.00
                    set udg_PS_Damage_Count_Released[udg_PS_Integers[3]] = ( udg_PS_Damage_Count_Released[udg_PS_Integers[3]] + 1 )
                    set udg_PS_TempLoc1 = GetUnitLoc(udg_PS_Caster[udg_PS_Integers[3]])
                    call AddSpecialEffectLocBJ( udg_PS_TempLoc1, udg_PS_Damage_Sfx[udg_PS_Integers[3]] )
                    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
                    set udg_PS_Damage_Group = GetUnitsInRangeOfLocAll(udg_PS_Damage_AoE[udg_PS_Integers[3]], udg_PS_TempLoc1)
                    call ForGroupBJ( udg_PS_Damage_Group, function Trig_PS_Loop_Func001Func001Func001Func001Func012A )
                    if ( Trig_PS_Loop_Func001Func001Func001Func001Func013C() ) then
                        call EnumDestructablesInCircleBJ( udg_PS_Damage_AoE[udg_PS_Integers[3]], udg_PS_TempLoc1, function Trig_PS_Loop_Func001Func001Func001Func001Func013Func001A )
                    else
                    endif
                    call RemoveLocation (udg_PS_TempLoc1)
                    call DestroyGroup (udg_PS_Damage_Group)
                endif
            else
                call GroupRemoveUnitSimple( udg_PS_Caster[udg_PS_Integers[3]], udg_PS_Group )
                set udg_PS_Integers[1] = ( udg_PS_Integers[1] - 1 )
                if ( Trig_PS_Loop_Func001Func001Func001Func004C() ) then
                    set udg_PS_Integers[2] = 0
                    call DisableTrigger( GetTriggeringTrigger() )
                else
                endif
            endif
        else
        endif
        set udg_PS_Integers[3] = udg_PS_Integers[3] + 1
    endloop
endfunction

