//===========================================================================
// Trigger: Hell Step 2
//===========================================================================
function Trig_Hell_Step_2_Func001C takes nothing returns boolean
    if ( not ( udg_HCS_Integers[1] == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Hell_Step_2_Actions takes nothing returns nothing
    if ( Trig_Hell_Step_2_Func001C() ) then
        call EnableTrigger( gg_trg_HCS2 )
    else
    endif
    set udg_HCS_Integers[0] = ( udg_HCS_Integers[0] + 1 )
    set udg_HCS_Integers[1] = ( udg_HCS_Integers[1] + 1 )
    set udg_HCS_Caster[udg_HCS_Integers[1]] = GetTriggerUnit()
    set udg_MVC_Point[0] = GetUnitLoc(udg_HCS_Caster[udg_HCS_Integers[1]])
    set udg_MVC_Point[1] = PolarProjectionBJ(GetUnitLoc(udg_HCS_Caster[udg_HCS_Integers[1]]), 800.00, GetUnitFacing(udg_HCS_Caster[udg_HCS_Integers[1]]))
    set udg_HCS_Ange[udg_HCS_Integers[1]] = AngleBetweenPoints(udg_MVC_Point[0], udg_MVC_Point[1])
    set udg_HCS_Damage[udg_HCS_Integers[1]] = 100.00
    set udg_HCS_Distance[udg_HCS_Integers[1]] = DistanceBetweenPoints(udg_MVC_Point[0], udg_MVC_Point[1])
    set udg_HCS_Interval[udg_HCS_Integers[1]] = 0.12
    set udg_HCS_Speed[udg_HCS_Integers[1]] = 35.00
    set udg_MVC_UnitType[6] = 'h010'
    call SetUnitPathing( udg_HCS_Caster[udg_HCS_Integers[1]], false )
    set udg_HCS_Check[udg_HCS_Integers[1]] = true
    call RemoveLocation (udg_MVC_Point[0])
    call RemoveLocation (udg_MVC_Point[1])
endfunction

//===========================================================================
function InitTrig_Hell_Step_2 takes nothing returns nothing
    set gg_trg_Hell_Step_2 = CreateTrigger(  )
    call TriggerAddAction( gg_trg_Hell_Step_2, function Trig_Hell_Step_2_Actions )
endfunction

//===========================================================================
// Trigger: HCS2
//===========================================================================
function Trig_HCS2_Func001Func001Func001Func005C takes nothing returns boolean
    if ( not ( udg_HCS_Integers[0] == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_HCS2_Func001Func001Func001Func017Func003002003001 takes nothing returns boolean
    return ( IsUnitAliveBJ(GetFilterUnit()) == true )
endfunction

function Trig_HCS2_Func001Func001Func001Func017Func003002003002001 takes nothing returns boolean
    return ( IsUnitEnemy(GetFilterUnit(), GetOwningPlayer(udg_HCS_Caster[udg_HCS_Integers[2]])) == true )
endfunction

function Trig_HCS2_Func001Func001Func001Func017Func003002003002002001 takes nothing returns boolean
    return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_STRUCTURE) == false )
endfunction

function Trig_HCS2_Func001Func001Func001Func017Func003002003002002002 takes nothing returns boolean
    return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_MAGIC_IMMUNE) == false )
endfunction

function Trig_HCS2_Func001Func001Func001Func017Func003002003002002 takes nothing returns boolean
    return GetBooleanAnd( Trig_HCS2_Func001Func001Func001Func017Func003002003002002001(), Trig_HCS2_Func001Func001Func001Func017Func003002003002002002() )
endfunction

function Trig_HCS2_Func001Func001Func001Func017Func003002003002 takes nothing returns boolean
    return GetBooleanAnd( Trig_HCS2_Func001Func001Func001Func017Func003002003002001(), Trig_HCS2_Func001Func001Func001Func017Func003002003002002() )
endfunction

function Trig_HCS2_Func001Func001Func001Func017Func003002003 takes nothing returns boolean
    return GetBooleanAnd( Trig_HCS2_Func001Func001Func001Func017Func003002003001(), Trig_HCS2_Func001Func001Func001Func017Func003002003002() )
endfunction

function Trig_HCS2_Func001Func001Func001Func017Func004A takes nothing returns nothing
    set udg_MVC_Point[2] = GetUnitLoc(GetEnumUnit())
    set udg_MVC_Point[3] = PolarProjectionBJ(udg_MVC_Point[2], ( udg_HCS_Speed[udg_HCS_Integers[2]] * ( RMaxBJ(udg_HCS_Interval[udg_HCS_Integers[2]], 0.04) / 0.04 ) ), udg_HCS_Ange[udg_HCS_Integers[2]])
    call SetUnitPositionLoc( GetEnumUnit(), udg_MVC_Point[3] )
    call UnitDamageTargetBJ( udg_HCS_Caster[udg_HCS_Integers[2]], GetEnumUnit(), udg_HCS_Damage[udg_HCS_Integers[2]], ATTACK_TYPE_NORMAL, DAMAGE_TYPE_UNIVERSAL )
    call AddSpecialEffectTargetUnitBJ( "chest", GetEnumUnit(), "Abilities\\Weapons\\FarseerMissile\\FarseerMissile.mdl" )
    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
    call RemoveLocation (udg_MVC_Point[2])
    call RemoveLocation (udg_MVC_Point[3])
endfunction

function Trig_HCS2_Func001Func001Func001Func017C takes nothing returns boolean
    if ( not ( udg_HCS_Timer[udg_HCS_Integers[2]] >= udg_HCS_Interval[udg_HCS_Integers[2]] ) ) then
        return false
    endif
    return true
endfunction

function Trig_HCS2_Func001Func001Func001C takes nothing returns boolean
    if ( not ( udg_HCS_Distance[udg_HCS_Integers[2]] > 0.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_HCS2_Func001Func001C takes nothing returns boolean
    if ( not ( udg_HCS_Check[udg_HCS_Integers[2]] == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_HCS2_Actions takes nothing returns nothing
    set udg_HCS_Integers[2] = 1
    loop
        exitwhen udg_HCS_Integers[2] > udg_HCS_Integers[1]
        if ( Trig_HCS2_Func001Func001C() ) then
            if ( Trig_HCS2_Func001Func001Func001C() ) then
                set udg_HCS_Distance[udg_HCS_Integers[2]] = ( udg_HCS_Distance[udg_HCS_Integers[2]] - udg_HCS_Speed[udg_HCS_Integers[2]] )
                set udg_MVC_Point[0] = GetUnitLoc(udg_HCS_Caster[udg_HCS_Integers[2]])
                set udg_MVC_Point[1] = PolarProjectionBJ(udg_MVC_Point[0], udg_HCS_Speed[udg_HCS_Integers[2]], udg_HCS_Ange[udg_HCS_Integers[2]])
                call SetUnitPositionLocFacingBJ( udg_HCS_Caster[udg_HCS_Integers[2]], udg_MVC_Point[1], udg_HCS_Ange[udg_HCS_Integers[2]] )
                call CreateNUnitsAtLoc( 1, udg_MVC_UnitType[6], GetOwningPlayer(udg_HCS_Caster[udg_HCS_Integers[2]]), udg_MVC_Point[1], udg_HCS_Ange[udg_HCS_Integers[2]] )
                set udg_RAS_Dummy = GetLastCreatedUnit()
                set udg_RAS_Duration = 0.40
                set udg_RAS_HeightInc = false
                set udg_RAS_Color = 100.00
                call ConditionalTriggerExecute( gg_trg_RemoveA )
                set udg_HCS_Timer[udg_HCS_Integers[2]] = ( udg_HCS_Timer[udg_HCS_Integers[2]] + 0.04 )
                if ( Trig_HCS2_Func001Func001Func001Func017C() ) then
                    set udg_HCS_Timer[udg_HCS_Integers[2]] = 0.00
                    set udg_MVC_PickGroup = GetUnitsInRangeOfLocMatching(130.00, udg_MVC_Point[1], Condition(function Trig_HCS2_Func001Func001Func001Func017Func003002003))
                    call ForGroupBJ( udg_MVC_PickGroup, function Trig_HCS2_Func001Func001Func001Func017Func004A )
                    call DestroyGroup (udg_MVC_PickGroup)
                else
                endif
                call RemoveLocation (udg_MVC_Point[0])
                call RemoveLocation (udg_MVC_Point[1])
            else
                set udg_HCS_Check[udg_HCS_Integers[2]] = false
                call SetUnitPathing( udg_HCS_Caster[udg_HCS_Integers[2]], true )
                set udg_HCS_Timer[udg_HCS_Integers[2]] = 0.00
                set udg_HCS_Integers[0] = ( udg_HCS_Integers[0] - 1 )
                if ( Trig_HCS2_Func001Func001Func001Func005C() ) then
                    set udg_HCS_Integers[1] = 0
                    call DisableTrigger( GetTriggeringTrigger() )
                else
                endif
            endif
        else
        endif
        set udg_HCS_Integers[2] = udg_HCS_Integers[2] + 1
    endloop
endfunction

//===========================================================================
function InitTrig_HCS2 takes nothing returns nothing
    set gg_trg_HCS2 = CreateTrigger(  )
    call DisableTrigger( gg_trg_HCS2 )
    call TriggerRegisterTimerEventPeriodic( gg_trg_HCS2, 0.04 )
    call TriggerAddAction( gg_trg_HCS2, function Trig_HCS2_Actions )
endfunction

//===========================================================================
// Trigger: RemoveA
//===========================================================================
function Trig_RemoveA_Func001C takes nothing returns boolean
    if ( not ( udg_RA_Integers[0] == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_RemoveA_Actions takes nothing returns nothing
    if ( Trig_RemoveA_Func001C() ) then
        call EnableTrigger( gg_trg_RA2 )
    else
    endif
    set udg_RA_Integers[0] = ( udg_RA_Integers[0] + 1 )
    set udg_RA_Integers[1] = ( udg_RA_Integers[1] + 1 )
    set udg_RA_Dummy[udg_RA_Integers[1]] = udg_RAS_Dummy
    set udg_RA_Duration[udg_RA_Integers[1]] = udg_RAS_Duration
    set udg_RA_HeightInc[udg_RA_Integers[1]] = udg_RAS_HeightInc
    set udg_RA_Color[udg_RA_Integers[1]] = udg_RAS_Color
endfunction

