endfunction

function Trig_Burning_Will_Cast_Conditions takes nothing returns boolean
    if ( not Trig_Burning_Will_Cast_Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_Burning_Will_Cast_Func002C takes nothing returns boolean
    if ( not ( UnitHasBuffBJ(GetTriggerUnit(), 'B010') == false ) ) then
        return false
    endif
    return true
endfunction

