//===========================================================================
// Trigger: P10 Skill
//===========================================================================
function Trig_P10_Skill_Func001C takes nothing returns boolean
    if ( not ( GetPlayerController(Player(9)) == MAP_CONTROL_COMPUTER ) ) then
        return false
    endif
    if ( not ( GetUnitAbilityLevelSwapped('A00A', udg_GDD_DamageSource) < 1 ) ) then
        return false
    endif
    if ( not ( IsUnitType(udg_GDD_DamagedUnit, UNIT_TYPE_HERO) == true ) ) then
        return false
    endif
    if ( not ( GetOwningPlayer(udg_GDD_DamagedUnit) == Player(9) ) ) then
        return false
    endif
    return true
endfunction

function Trig_P10_Skill_Conditions takes nothing returns boolean
    if ( not Trig_P10_Skill_Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_P10_Skill_Func003C takes nothing returns boolean
    if ( not ( GetUnitLifePercent(gg_unit_H006_0031) <= 20.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_P10_Skill_Func004Func002C takes nothing returns boolean
    if ( not ( udg_AI_Skill == 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_P10_Skill_Func004C takes nothing returns boolean
    if ( not ( udg_AI_Skill == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_P10_Skill_Actions takes nothing returns nothing
    set udg_AI_Skill = GetRandomInt(1, 3)
    if ( Trig_P10_Skill_Func003C() ) then
        call IssueImmediateOrderBJ( gg_unit_H006_0031, "battleroar" )
        call TriggerSleepAction( GetRandomReal(0.20, 0.30) )
        set udg_TempPoint = PolarProjectionBJ(GetUnitLoc(gg_unit_H006_0031), 1000.00, GetRandomDirectionDeg())
        call UnitUseItemPointLoc( gg_unit_H006_0031, GetItemOfTypeFromUnitBJ(gg_unit_H006_0031, 'I000'), udg_TempPoint )
        call RemoveLocation(udg_TempPoint)
        call TriggerSleepAction( GetRandomReal(0.20, 0.30) )
        set udg_TempPoint = PolarProjectionBJ(GetUnitLoc(gg_unit_H006_0031), 400.00, GetUnitFacing(udg_GDD_DamageSource))
        call IssuePointOrderLocBJ( gg_unit_H006_0031, "move", udg_TempPoint )
        call RemoveLocation(udg_TempPoint)
    else
    endif
    if ( Trig_P10_Skill_Func004C() ) then
        set udg_TempPoint = GetUnitLoc(udg_GDD_DamageSource)
        call IssuePointOrderLocBJ( gg_unit_H006_0031, "ward", udg_TempPoint )
        call RemoveLocation(udg_TempPoint)
        call TriggerSleepAction( 0.50 )
        call IssueImmediateOrderBJ( gg_unit_H006_0031, "battleroar" )
    else
        if ( Trig_P10_Skill_Func004Func002C() ) then
            set udg_TempPoint = GetUnitLoc(udg_GDD_DamageSource)
            call IssuePointOrderLocBJ( gg_unit_H006_0031, "carrionswarm", udg_TempPoint )
            call RemoveLocation(udg_TempPoint)
        else
        endif
    endif
endfunction

//===========================================================================
function InitTrig_P10_Skill takes nothing returns nothing
    set gg_trg_P10_Skill = CreateTrigger(  )
    call DisableTrigger( gg_trg_P10_Skill )
    call TriggerRegisterVariableEvent( gg_trg_P10_Skill, "udg_GDD_Event", EQUAL, 1.00 )
    call TriggerAddCondition( gg_trg_P10_Skill, Condition( function Trig_P10_Skill_Conditions ) )
    call TriggerAddAction( gg_trg_P10_Skill, function Trig_P10_Skill_Actions )
endfunction

