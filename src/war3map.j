function Trig_Create_Multiboard_Func001002001001001 takes nothing returns boolean
    return ( GetPlayerSlotState(GetFilterPlayer()) == PLAYER_SLOT_STATE_PLAYING )
endfunction

function Trig_Create_Multiboard_Func001002001001002001 takes nothing returns boolean
    return ( GetFilterPlayer() != Player(PLAYER_NEUTRAL_AGGRESSIVE) )
endfunction

function Trig_Create_Multiboard_Func001002001001002002 takes nothing returns boolean
    return ( GetFilterPlayer() != Player(PLAYER_NEUTRAL_PASSIVE) )
endfunction

function Trig_Create_Multiboard_Func001002001001002 takes nothing returns boolean
    return GetBooleanAnd( Trig_Create_Multiboard_Func001002001001002001(), Trig_Create_Multiboard_Func001002001001002002() )
endfunction

function Trig_Create_Multiboard_Func001002001001 takes nothing returns boolean
    return GetBooleanAnd( Trig_Create_Multiboard_Func001002001001001(), Trig_Create_Multiboard_Func001002001001002() )
endfunction

function Trig_Create_Multiboard_Func002C takes nothing returns boolean
    if ( not ( udg_DUEL_MODE_BOOL == true ) ) then
        return false
    endif
    if ( not ( udg_Player_Count > 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Create_Multiboard_Func003C takes nothing returns boolean
    if ( not ( udg_PLANT_TEH_BOMB == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Create_Multiboard_Func005Func001C takes nothing returns boolean
    if ( ( udg_KILL_LIM == 20 ) ) then
        return true
    endif
    if ( ( udg_Point_Limit == 20 ) ) then
        return true
    endif
    return false
endfunction

function Trig_Create_Multiboard_Func005C takes nothing returns boolean
    if ( not Trig_Create_Multiboard_Func005Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_Create_Multiboard_Func006Func001C takes nothing returns boolean
    if ( ( udg_KILL_LIM == 50 ) ) then
        return true
    endif
    if ( ( udg_Point_Limit == 50 ) ) then
        return true
    endif
    return false
endfunction

function Trig_Create_Multiboard_Func006C takes nothing returns boolean
    if ( not Trig_Create_Multiboard_Func006Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_Create_Multiboard_Func007Func001C takes nothing returns boolean
    if ( ( udg_KILL_LIM == 99 ) ) then
        return true
    endif
    if ( ( udg_Point_Limit == 99 ) ) then
        return true
    endif
    return false
endfunction

function Trig_Create_Multiboard_Func007C takes nothing returns boolean
    if ( not Trig_Create_Multiboard_Func007Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_Create_Multiboard_Func014001001 takes nothing returns boolean
    return ( GetPlayerSlotState(GetFilterPlayer()) == PLAYER_SLOT_STATE_PLAYING )
endfunction

function Trig_Create_Multiboard_Func014A takes nothing returns nothing
    set udg_Multiboard_Spots[GetConvertedPlayerId(GetEnumPlayer())] = udg_List
    call MultiboardSetItemIconBJ( GetLastCreatedMultiboard(), 1, udg_List, "ReplaceableTextures\\CommandButtons\\BTNVillagerMan.blp" )
    call MultiboardSetItemValueBJ( GetLastCreatedMultiboard(), 2, udg_List, ( udg_Players_Name[GetConvertedPlayerId(GetEnumPlayer())] + "|r" ) )
    call MultiboardSetItemValueBJ( GetLastCreatedMultiboard(), 3, udg_List, "TRIGSTR_2887" )
    call MultiboardSetItemValueBJ( GetLastCreatedMultiboard(), 4, udg_List, "TRIGSTR_2888" )
    call MultiboardSetItemValueBJ( GetLastCreatedMultiboard(), 5, udg_List, "TRIGSTR_2889" )
    set udg_List = ( udg_List + 1 )
endfunction

function Trig_Create_Multiboard_Actions takes nothing returns nothing
    local force tempForce = null
    set tempForce = GetPlayersMatching(Condition(function Trig_Create_Multiboard_Func001002001001))
    set udg_Player_Count = CountPlayersInForceBJ(tempForce)
    call DestroyForce(tempForce)
    set tempForce = null
    if ( Trig_Create_Multiboard_Func002C() ) then
        call StartTimerBJ( udg_DUEL, false, 180.00 )
        call CreateTimerDialogBJ( udg_DUEL, "TRIGSTR_3491" )
        set udg_Duel_T = GetLastCreatedTimerDialogBJ()
    else
    endif
    if ( Trig_Create_Multiboard_Func003C() ) then
        set udg_TempLoc = GetRandomLocInRect(gg_rct_Bomb)
        call CreateItemLoc( 'I004', udg_TempLoc )
        call PingMinimapLocForForceEx( bj_FORCE_ALL_PLAYERS, udg_TempLoc, 5.00, bj_MINIMAPPINGSTYLE_FLASHY, 100, 100, 100 )
        call CreateLeaderboardBJ( bj_FORCE_ALL_PLAYERS, "TRIGSTR_3566" )
        set udg_PLANT_THE_BOMB_LB = GetLastCreatedLeaderboard()
        call LeaderboardAddItemBJ( Player(0), udg_PLANT_THE_BOMB_LB, "TRIGSTR_3567", 0 )
        call LeaderboardAddItemBJ( Player(6), udg_PLANT_THE_BOMB_LB, "TRIGSTR_3568", 0 )
        call LeaderboardDisplayBJ( true, udg_PLANT_THE_BOMB_LB )
        call RemoveLocation(udg_TempLoc)
    else
    endif
    if ( Trig_Create_Multiboard_Func005C() ) then
        call CreateMultiboardBJ( 5, ( 1 + udg_Player_Count ), "TRIGSTR_2881" )
    else
    endif
    if ( Trig_Create_Multiboard_Func006C() ) then
        call CreateMultiboardBJ( 5, ( 1 + udg_Player_Count ), "TRIGSTR_3361" )
    else
    endif
    if ( Trig_Create_Multiboard_Func007C() ) then
        call CreateMultiboardBJ( 5, ( 1 + udg_Player_Count ), "TRIGSTR_3362" )
    else
    endif
    call MultiboardSetItemValueBJ( GetLastCreatedMultiboard(), 2, 1, "TRIGSTR_2882" )
    call MultiboardSetItemValueBJ( GetLastCreatedMultiboard(), 3, 1, "TRIGSTR_2883" )
    call MultiboardSetItemValueBJ( GetLastCreatedMultiboard(), 4, 1, "TRIGSTR_2884" )
    call MultiboardSetItemValueBJ( GetLastCreatedMultiboard(), 5, 1, "TRIGSTR_2885" )
    set bj_forLoopAIndex = 1
    set bj_forLoopAIndexEnd = ( 1 + udg_Player_Count )
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        call MultiboardSetItemStyleBJ( GetLastCreatedMultiboard(), 1, 1, true, false )
        call MultiboardSetItemStyleBJ( GetLastCreatedMultiboard(), 1, GetForLoopIndexA(), true, false )
        call MultiboardSetItemStyleBJ( GetLastCreatedMultiboard(), 2, GetForLoopIndexA(), true, false )
        call MultiboardSetItemStyleBJ( GetLastCreatedMultiboard(), 3, GetForLoopIndexA(), true, false )
        call MultiboardSetItemStyleBJ( GetLastCreatedMultiboard(), 4, GetForLoopIndexA(), true, false )
        call MultiboardSetItemStyleBJ( GetLastCreatedMultiboard(), 5, GetForLoopIndexA(), true, false )
        call MultiboardSetItemStyleBJ( GetLastCreatedMultiboard(), 7, GetForLoopIndexA(), false, false )
        call MultiboardSetItemWidthBJ( GetLastCreatedMultiboard(), 1, GetForLoopIndexA(), 1.00 )
        call MultiboardSetItemWidthBJ( GetLastCreatedMultiboard(), 2, GetForLoopIndexA(), 11.00 )
        call MultiboardSetItemWidthBJ( GetLastCreatedMultiboard(), 3, GetForLoopIndexA(), 4.00 )
        call MultiboardSetItemWidthBJ( GetLastCreatedMultiboard(), 4, GetForLoopIndexA(), 4.00 )
        call MultiboardSetItemWidthBJ( GetLastCreatedMultiboard(), 5, GetForLoopIndexA(), 5.00 )
        call MultiboardSetItemWidthBJ( GetLastCreatedMultiboard(), 7, GetForLoopIndexA(), 0.00 )
        set bj_forLoopAIndex = bj_forLoopAIndex + 1
    endloop
    set udg_List = 2
    call ForForce( GetPlayersMatching(Condition(function Trig_Create_Multiboard_Func014001001)), function Trig_Create_Multiboard_Func014A )
    call MultiboardDisplayBJ( true, GetLastCreatedMultiboard() )
endfunction

