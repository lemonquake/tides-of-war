function Trig_LF_Init_Actions takes nothing returns nothing
    call InitHashtableBJ(  )
    set udg_SR_Hash = GetLastCreatedHashtableBJ()
    set udg_SR_MoveSpeedBase = 15.00
    set udg_SR_MoveSpeedPerLevel = 0.00
    set udg_SR_RockDamageBase = 150.00
    set udg_SR_RockDamagePerLevel = 0.00
    set udg_SR_RockSearchAoeBase = 300.00
    set udg_SR_RockSearchAoePerLevel = 0.00
    set udg_SR_RocksBase = 4.00
    set udg_SR_RocksPerLevel = 0.00
    set udg_SR_DurationBase = 10.00
    set udg_SR_DurationPerLevel = 0.00
    set udg_SR_RockFallSpeed = 23.00
    set udg_SR_RockDistance = 300.00
    set udg_SR_RockSeperationDistance = 40.00
    set udg_SR_RockSpinSpeed = 3.00
    set udg_SR_RockSpinSpeed2 = 10.00
    set udg_SR_RockPairCount = 6.00
    set udg_SR_RockHeight = 300.00
    set udg_SR_SummonSFXDuration = 1.00
    set udg_SR_Spell = 'A057'
    set udg_SR_Rock = 'u001'
    set udg_SR_RockCore = 'h005'
    set udg_SR_SummonSFX = 'u001'
    set udg_SR_CollisionSFX = "Abilities\\Spells\\Other\\Doom\\DoomDeath.mdl"
    set udg_SR_RockLinkLightning = "CLPB"
endfunction

