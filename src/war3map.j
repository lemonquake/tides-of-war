function Trig_debug_f_Func001Func001C takes nothing returns boolean
    if ( not ( GetDestructableTypeId(GetEnumDestructable()) == 'B000' ) ) then
        return false
    endif
    return true
endfunction

function Trig_debug_f_Func001A takes nothing returns nothing
    if ( Trig_debug_f_Func001Func001C() ) then
