        call IssuePointOrderLocBJ( gg_unit_EEES_0029, "impale", udg_TempPoint )
        call RemoveLocation(udg_TempPoint)
        call TriggerSleepAction( 1.00 )
        call IssueTargetOrderBJ( gg_unit_EEES_0029, "attack", udg_GDD_DamageSource )
    else
        if ( Trig_P4_Skill_Func004Func002C() ) then
            call IssueImmediateOrderBJ( gg_unit_EEES_0029, "battleroar" )
        else
            if ( Trig_P4_Skill_Func004Func002Func001C() ) then
                if ( Trig_P4_Skill_Func004Func002Func001Func001C() ) then
