    call MultiboardSetItemValueBJ( GetLastCreatedMultiboard(), 5, udg_Multiboard_Spots[GetConvertedPlayerId(GetOwningPlayer(udg_GDD_DamageSource))], "TRIGSTR_3643" )
endfunction

