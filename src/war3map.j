    call CreateTextTagUnitBJ( ( udg_PlayerColors[GetConvertedPlayerId(GetOwningPlayer(udg_GDD_DamageSource))] + ( I2S(R2I(udg_GDD_Damage)) + ( " + " + ( I2S(R2I(( 0.40 * udg_GDD_Damage ))) + "!" ) ) ) ), udg_GDD_DamagedUnit, 0.00, 8.50, 100.00, 100.00, 100.00, 0 )
    call SetTextTagVelocityBJ( GetLastCreatedTextTag(), 100.00, 90.00 )
