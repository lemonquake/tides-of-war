//===========================================================================
// Trigger: Obser
//===========================================================================
function Trig_Obser_Func006C takes nothing returns boolean
    if ( not ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(GetTriggerUnit()) == true ) ) then
        return false
    endif
    if ( not ( GetOwningPlayer(GetTriggerUnit()) != Player(PLAYER_NEUTRAL_AGGRESSIVE) ) ) then
        return false
    endif
    if ( not ( IsUnitInGroup(GetTriggerUnit(), udg_Combat_Group) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_Obser_Conditions takes nothing returns boolean
    if ( not Trig_Obser_Func006C() ) then
        return false
    endif
    return true
endfunction

function Trig_Obser_Func005C takes nothing returns boolean
    if ( not ( udg_Obser_Con[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))] == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Obser_Actions takes nothing returns nothing
    call QueueUnitAnimationBJ( gg_unit_h01M_0146, "stand work" )
    set udg_Obser_Con[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))] = true
    call CreateFogModifierRadiusLocBJ( true, GetOwningPlayer(GetTriggerUnit()), FOG_OF_WAR_VISIBLE, GetUnitLoc(GetTriggerUnit()), 4000.00 )
    set udg_Observatory[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))] = GetLastCreatedFogModifier()
    if ( Trig_Obser_Func005C() ) then
        call AddSpecialEffectTargetUnitBJ( "overhead", GetTriggerUnit(), "Abilities\\Spells\\Other\\TalkToMe\\TalkToMe.mdl" )
        set udg_Obser[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))] = GetLastCreatedEffectBJ()
    else
    endif
endfunction

//===========================================================================
function InitTrig_Obser takes nothing returns nothing
    set gg_trg_Obser = CreateTrigger(  )
    call TriggerRegisterEnterRectSimple( gg_trg_Obser, gg_rct_Observatory )
    call TriggerAddCondition( gg_trg_Obser, Condition( function Trig_Obser_Conditions ) )
    call TriggerAddAction( gg_trg_Obser, function Trig_Obser_Actions )
endfunction

