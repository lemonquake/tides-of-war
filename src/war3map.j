    return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_STRUCTURE) == false )
endfunction

function Trig_Warp_Ef_Func001Func001Func001Func002Func002Func012002003002002002 takes nothing returns boolean
    return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_MAGIC_IMMUNE) == false )
endfunction

function Trig_Warp_Ef_Func001Func001Func001Func002Func002Func012002003002002 takes nothing returns boolean
    return GetBooleanAnd( Trig_Warp_Ef_Func001Func001Func001Func002Func002Func012002003002002001(), Trig_Warp_Ef_Func001Func001Func001Func002Func002Func012002003002002002() )
endfunction

function Trig_Warp_Ef_Func001Func001Func001Func002Func002Func012002003002 takes nothing returns boolean
