    if ( not ( udg_GC_Counter[udg_GC_Integers[2]] < 1000.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Warp_Ef_Func001Func001C takes nothing returns boolean
    if ( not ( IsUnitInGroup(udg_GC_Target[udg_GC_Integers[2]], udg_GC_Group) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Warp_Ef_Actions takes nothing returns nothing
    set udg_GC_Integers[2] = 1
    loop
        exitwhen udg_GC_Integers[2] > udg_GC_Integers[1]
        if ( Trig_Warp_Ef_Func001Func001C() ) then
            if ( Trig_Warp_Ef_Func001Func001Func001C() ) then
                set udg_MVC_Point[0] = GetUnitLoc(udg_GC_Dummy[udg_GC_Integers[2]])
                set udg_GC_Counter[udg_GC_Integers[2]] = ( udg_GC_Counter[udg_GC_Integers[2]] + udg_GC_Speed[udg_GC_Integers[2]] )
                call SetUnitFlyHeightBJ( udg_GC_Dummy[udg_GC_Integers[2]], udg_GC_Counter[udg_GC_Integers[2]], 0.00 )
                call CreateNUnitsAtLoc( 1, udg_MVC_UnitType[3], GetOwningPlayer(udg_GC_Target[udg_GC_Integers[2]]), udg_MVC_Point[0], bj_UNIT_FACING )
                call UnitApplyTimedLifeBJ( 2.00, 'BTLF', GetLastCreatedUnit() )
                set udg_RAS_Dummy = GetLastCreatedUnit()
                set udg_RAS_Duration = 0.50
                set udg_RAS_HeightInc = false
                set udg_RAS_Color = 0.00
                call ConditionalTriggerExecute( gg_trg_RemoveA )
                call SetUnitFlyHeightBJ( udg_RAS_Dummy, ( udg_GC_Counter[udg_GC_Integers[2]] + 100.00 ), 0.00 )
                call RemoveLocation (udg_MVC_Point[0])
            else
                if ( Trig_Warp_Ef_Func001Func001Func001Func002C() ) then
                    call SetUnitVertexColorBJ( udg_GC_Dummy[udg_GC_Integers[2]], 0.00, 0.00, 0.00, 100.00 )
                    set udg_GC_Delay[udg_GC_Integers[2]] = ( udg_GC_Delay[udg_GC_Integers[2]] - 0.04 )
                else
                    if ( Trig_Warp_Ef_Func001Func001Func001Func002Func001C() ) then
                        set udg_GC_Check[udg_GC_Integers[2]] = true
                        set udg_MVC_Point[0] = GetUnitLoc(udg_GC_Dummy[udg_GC_Integers[2]])
                        call CreateNUnitsAtLoc( 1, udg_MVC_UnitType[2], GetOwningPlayer(udg_GC_Dummy[udg_GC_Integers[2]]), udg_MVC_Point[0], GetUnitFacing(udg_GC_Dummy[udg_GC_Integers[2]]) )
                        call RemoveUnit( udg_GC_Dummy[udg_GC_Integers[2]] )
                        set udg_GC_Dummy[udg_GC_Integers[2]] = GetLastCreatedUnit()
                        call SelectUnitForPlayerSingle( udg_GC_Dummy[udg_GC_Integers[2]], GetOwningPlayer(udg_GC_Dummy[udg_GC_Integers[2]]) )
                        call RemoveLocation (udg_MVC_Point[0])
                    else
                    endif
                    if ( Trig_Warp_Ef_Func001Func001Func001Func002Func002C() ) then
                        set udg_MVC_Point[0] = GetUnitLoc(udg_GC_Dummy[udg_GC_Integers[2]])
                        set udg_GC_Counter[udg_GC_Integers[2]] = ( udg_GC_Counter[udg_GC_Integers[2]] + udg_GC_Speed[udg_GC_Integers[2]] )
                        call SetUnitFlyHeightBJ( udg_GC_Dummy[udg_GC_Integers[2]], ( 2000.00 - udg_GC_Counter[udg_GC_Integers[2]] ), 0.00 )
                        call CreateNUnitsAtLoc( 1, udg_MVC_UnitType[4], GetOwningPlayer(udg_GC_Target[udg_GC_Integers[2]]), udg_MVC_Point[0], bj_UNIT_FACING )
                        set udg_RAS_Dummy = GetLastCreatedUnit()
                        set udg_RAS_Duration = 0.50
                        set udg_RAS_HeightInc = false
                        set udg_RAS_Color = 0.00
                        call ConditionalTriggerExecute( gg_trg_RemoveA )
                        call SetUnitFlyHeightBJ( udg_RAS_Dummy, ( 2000.00 - udg_GC_Counter[udg_GC_Integers[2]] ), 0.00 )
                        call RemoveLocation (udg_MVC_Point[0])
                    else
                        set udg_MVC_Point[0] = GetUnitLoc(udg_GC_Dummy[udg_GC_Integers[2]])
                        call GroupRemoveUnitSimple( udg_GC_Target[udg_GC_Integers[2]], udg_GC_Group )
                        call SetUnitPositionLocFacingBJ( udg_GC_Target[udg_GC_Integers[2]], udg_MVC_Point[0], GetUnitFacing(udg_GC_Dummy[udg_GC_Integers[2]]) )
                        call PauseUnitBJ( false, udg_GC_Target[udg_GC_Integers[2]] )
                        call ShowUnitShow( udg_GC_Target[udg_GC_Integers[2]] )
                        call SelectUnitForPlayerSingle( udg_GC_Target[udg_GC_Integers[2]], GetOwningPlayer(udg_GC_Target[udg_GC_Integers[2]]) )
                        call RemoveUnit( udg_GC_Dummy[udg_GC_Integers[2]] )
                        call SetUnitScalePercent( GetLastCreatedUnit(), 230.00, 230.00, 230.00 )
                        call AddSpecialEffectTargetUnitBJ( "origin", udg_GC_Target[udg_GC_Integers[2]], "Abilities\\Spells\\Orc\\WarStomp\\WarStompCaster.mdl" )
                        call DestroyEffectBJ( GetLastCreatedEffectBJ() )
                        set udg_MVC_PickGroup = GetUnitsInRangeOfLocMatching(udg_GC_AOE[udg_GC_Integers[2]], udg_MVC_Point[0], Condition(function Trig_Warp_Ef_Func001Func001Func001Func002Func002Func012002003))
                        call CreateUnit(GetOwningPlayer(udg_GC_Cast[udg_GC_Integers[2]]), 'h005', GetUnitX(udg_GC_Target[udg_GC_Integers[1]]), GetUnitY(udg_GC_Target[udg_GC_Integers[1]]), bj_UNIT_FACING)
                        call UnitAddAbilityBJ( 'A03V', GetLastCreatedUnit() )
                        call SetUnitAbilityLevelSwapped( 'A03V', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped('A03U', udg_GC_Cast[udg_GC_Integers[2]]) )
                        call IssueImmediateOrderBJ( GetLastCreatedUnit(), "stomp" )
                        call UnitApplyTimedLifeBJ( 1.00, 'BTLF', GetLastCreatedUnit() )
                        call ForGroupBJ( udg_MVC_PickGroup, function Trig_Warp_Ef_Func001Func001Func001Func002Func002Func018A )
                        call RemoveLocation (udg_MVC_Point[0])
                        call DestroyGroup (udg_MVC_PickGroup)
                        set udg_GC_Integers[0] = ( udg_GC_Integers[0] - 1 )
                        if ( Trig_Warp_Ef_Func001Func001Func001Func002Func002Func022C() ) then
                            set udg_GC_Integers[1] = 0
                            call DisableTrigger( GetTriggeringTrigger() )
                        else
                        endif
                    endif
                endif
            endif
        else
        endif
        set udg_GC_Integers[2] = udg_GC_Integers[2] + 1
    endloop
endfunction

