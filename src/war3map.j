function Trig_TO_AW_eff_Func001Func001Func008Func003Func001Func003002003002002 takes nothing returns boolean
    return ( IsUnitEnemy(GetFilterUnit(), GetOwningPlayer(udg_AW_Caster[udg_AW1])) == true )
