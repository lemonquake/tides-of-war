    if ( not ( GetOwningPlayer(GetEnumUnit()) == GetOwningPlayer(udg_Hero[udg_Pnum]) ) ) then
        return false
    endif
    if ( not ( GetUnitTypeId(GetEnumUnit()) == 'n004' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Pick_Func015A takes nothing returns nothing
    if ( Trig_Pick_Func015Func001C() ) then
        call RemoveUnit( GetEnumUnit() )
    else
    endif
endfunction

function Trig_Pick_Func017001002001 takes nothing returns boolean
    return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_HERO) == true )
endfunction

function Trig_Pick_Func017001002002 takes nothing returns boolean
    return ( GetOwningPlayer(GetFilterUnit()) == GetOwningPlayer(udg_Hero[udg_Pnum]) )
endfunction

function Trig_Pick_Func017001002 takes nothing returns boolean
    return GetBooleanAnd( Trig_Pick_Func017001002001(), Trig_Pick_Func017001002002() )
endfunction

function Trig_Pick_Func017A takes nothing returns nothing
    call PanCameraToTimedLocForPlayer( GetOwningPlayer(udg_Hero[udg_Pnum]), GetUnitLoc(GetEnumUnit()), 0 )
endfunction

function Trig_Pick_Func019001001 takes nothing returns boolean
    return ( IsPlayerAlly(GetFilterPlayer(), GetOwningPlayer(GetSoldUnit())) == true )
endfunction

function Trig_Pick_Func019A takes nothing returns nothing
    call SetPlayerUnitAvailableBJ( GetUnitTypeId(GetSoldUnit()), false, GetEnumPlayer() )
    call SetPlayerMaxHeroesAllowed( 1, GetEnumPlayer() )
endfunction

function Trig_Pick_Func050Func001C takes nothing returns boolean
    if ( not ( GetItemPlayer(GetEnumItem()) == GetOwningPlayer(GetSoldUnit()) ) ) then
        return false
    endif
    return true
endfunction

function Trig_Pick_Func050A takes nothing returns nothing
    if ( Trig_Pick_Func050Func001C() ) then
        call UnitAddItemSwapped( GetEnumItem(), GetSoldUnit() )
    else
    endif
endfunction

function Trig_Pick_Actions takes nothing returns nothing
    local force tempForce = null
    set udg_TempPoint = GetUnitLoc(GetSoldUnit())
    set udg_Pnum = GetConvertedPlayerId(GetOwningPlayer(GetSoldUnit()))
    set udg_Hero[udg_Pnum] = GetSoldUnit()
    call SetHeroLevelBJ( udg_Hero[udg_Pnum], udg_Level_Set, false )
    if ( Trig_Pick_Func005C() ) then
        call UnitAddAbilityBJ( 'A04E', GetSoldUnit() )
    else
    endif
    if ( Trig_Pick_Func006C() ) then
        call UnitRemoveItemSwapped( GetItemOfTypeFromUnitBJ(GetSoldUnit(), 'I00I'), GetSoldUnit() )
        call RemoveItem( GetLastRemovedItem() )
        call CreateItem('I00L', GetUnitX(GetSoldUnit(), GetUnitY(GetSoldUnit()) )
        call UnitAddItemSwapped( GetLastCreatedItem(), GetSoldUnit() )
    else
    endif
    if ( Trig_Pick_Func007C() ) then
        call UnitRemoveItemSwapped( GetItemOfTypeFromUnitBJ(GetSoldUnit(), 'I00L'), GetSoldUnit() )
        call RemoveItem( GetLastRemovedItem() )
        call CreateItem('I00I', GetUnitX(GetSoldUnit(), GetUnitY(GetSoldUnit()) )
        call UnitAddItemSwapped( GetLastCreatedItem(), GetSoldUnit() )
    else
    endif
    if ( Trig_Pick_Func008C() ) then
        call UnitRemoveItemSwapped( GetItemOfTypeFromUnitBJ(GetSoldUnit(), 'I00A'), GetSoldUnit() )
        call RemoveItem( GetLastRemovedItem() )
        call CreateItem('I00C', GetUnitX(GetSoldUnit(), GetUnitY(GetSoldUnit()) )
        call UnitAddItemSwapped( GetLastCreatedItem(), GetSoldUnit() )
    else
    endif
    if ( Trig_Pick_Func009C() ) then
        call UnitRemoveItemSwapped( GetItemOfTypeFromUnitBJ(GetSoldUnit(), 'I00C'), GetSoldUnit() )
        call RemoveItem( GetLastRemovedItem() )
        call CreateItem('I00A', GetUnitX(GetSoldUnit(), GetUnitY(GetSoldUnit()) )
        call UnitAddItemSwapped( GetLastCreatedItem(), GetSoldUnit() )
    else
    endif
    call SelectUnitForPlayerSingle( udg_Hero[udg_Pnum], GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call DisplayTimedTextToForce( bj_FORCE_ALL_PLAYERS, 10.00, ( udg_Players_Name[udg_Pnum] + ( "|r " + ( "has chosen " + ( GetUnitName(udg_Hero[udg_Pnum]) + "." ) ) ) ) )
    if ( Trig_Pick_Func012C() ) then
        call SetUnitPositionLoc( udg_Hero[udg_Pnum], GetRandomLocInRect(gg_rct_TEAM1) )
        call CreateFogModifierRectBJ( true, GetOwningPlayer(udg_Hero[udg_Pnum]), FOG_OF_WAR_VISIBLE, gg_rct_team1 )
    else
        if ( Trig_Pick_Func012Func001C() ) then
            call SetUnitPositionLoc( udg_Hero[udg_Pnum], GetRandomLocInRect(gg_rct_TEAM2) )
            call CreateFogModifierRectBJ( true, GetOwningPlayer(udg_Hero[udg_Pnum]), FOG_OF_WAR_VISIBLE, gg_rct_team2 )
        else
        endif
    endif
    if ( Trig_Pick_Func013C() ) then
        call SetUnitPositionLoc( udg_Hero[udg_Pnum], GetRandomLocInRect(gg_rct_ROYAL_RUMBLE) )
    else
    endif
    set bj_wantDestroyGroup = true
    call ForGroupBJ( GetUnitsInRectAll(gg_rct_InitialView), function Trig_Pick_Func015A )
    set bj_wantDestroyGroup = true
    call ForGroupBJ( GetUnitsInRectMatching(GetEntireMapRect(), Condition(function Trig_Pick_Func017001002)), function Trig_Pick_Func017A )
    set bj_wantDestroyGroup = true
    set tempForce = GetPlayersMatching(Condition(function Trig_Pick_Func019001001))
    call ForForce(tempForce, function Trig_Pick_Func019A)
    call DestroyForce(tempForce)
    set tempForce = null
    call SetPlayerUnitAvailableBJ( 'H006', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H00D', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H003', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H00A', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H004', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H002', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H007', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H001', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'EEES', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H00H', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H00J', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'N005', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H004', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H00S', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H00O', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H00T', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H00W', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H00X', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H013', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H015', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H017', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H019', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H01C', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H01E', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H01J', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H01K', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H01N', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call SetPlayerUnitAvailableBJ( 'H01P', false, GetOwningPlayer(udg_Hero[udg_Pnum]) )
    call CreateFogModifierRectBJ( true, GetOwningPlayer(GetSoldUnit()), FOG_OF_WAR_FOGGED, gg_rct_InitialView )
    set bj_wantDestroyGroup = true
    call EnumItemsInRectBJ( gg_rct_Item_Dump, function Trig_Pick_Func050A )
    call RemoveLocation(udg_TempPoint)
endfunction

