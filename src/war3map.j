//===========================================================================
function Trig_rem_Func001C takes nothing returns boolean
    if ( ( GetUnitAbilityLevelSwapped('A00A', GetTriggerUnit()) == 1 ) ) then
        return true
    endif
    if ( ( GetUnitAbilityLevelSwapped('A048', GetTriggerUnit()) >= 1 ) ) then
        return true
    endif
    return false
endfunction

function Trig_rem_Conditions takes nothing returns boolean
    if ( not Trig_rem_Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_rem_Actions takes nothing returns nothing
    call RemoveUnit( GetTriggerUnit() )
endfunction

