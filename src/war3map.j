//===========================================================================
// Trigger: Bounce
//===========================================================================
function Trig_Bounce_Func002Func001C takes nothing returns boolean
    if ( not ( udg_BB_Index3 != 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Bounce_Func002Func003Func017Func005C takes nothing returns boolean
    if ( not ( udg_BB_Index == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Bounce_Func002Func003Func017C takes nothing returns boolean
    if ( not ( udg_BB_Jumps[udg_BB_Index3] == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Bounce_Func002Func003C takes nothing returns boolean
    if ( not ( udg_BB_Expire[udg_BB_Index3] <= 0.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Bounce_Actions takes nothing returns nothing
    set udg_BB_Index3 = 1
    loop
        exitwhen udg_BB_Index3 > udg_BB_Index2
        if ( Trig_Bounce_Func002Func001C() ) then
            set udg_BB_Expire[udg_BB_Index3] = ( udg_BB_Expire[udg_BB_Index3] - udg_BB_Speed[udg_BB_Index3] )
            set udg_BB_CurrentDistance[udg_BB_Index3] = ( udg_BB_CurrentDistance[udg_BB_Index3] + udg_BB_Speed[udg_BB_Index3] )
            set udg_BB_Real[1] = udg_BB_MaxHeight[udg_BB_Index3]
            set udg_BB_Real[2] = udg_BB_Distance[udg_BB_Index3]
            set udg_BB_Real[3] = udg_BB_CurrentDistance[udg_BB_Index3]
            set udg_BB_Real[4] = ( 4 * udg_BB_Real[1] / udg_BB_Real[2]) * ( udg_BB_Real[2] - udg_BB_Real[3]) * ( udg_BB_Real[3] / udg_BB_Real[2] )
            call SetUnitFlyHeightBJ( udg_BB_Dummy[udg_BB_Index3], udg_BB_Real[4], 0.00 )
        else
        endif
        set udg_BB_Point3 = GetUnitLoc(udg_BB_Dummy[udg_BB_Index3])
        if ( Trig_Bounce_Func002Func003C() ) then
            set udg_BB_Jumps[udg_BB_Index3] = ( udg_BB_Jumps[udg_BB_Index3] - 1 )
            set udg_BB_Angle[udg_BB_Index3] = GetRandomReal(0.00, 360.00)
            set udg_BB_Distance[udg_BB_Index3] = GetRandomReal(150.00, 300.00)
            set udg_BB_Expire[udg_BB_Index3] = udg_BB_Distance[udg_BB_Index3]
            set udg_BB_CurrentDistance[udg_BB_Index3] = 0.00
            call AddSpecialEffectLocBJ( udg_BB_Point3, "Abilities\\Spells\\Other\\Volcano\\VolcanoDeath.mdl" )
            call DestroyEffectBJ( GetLastCreatedEffectBJ() )
            call CreateNUnitsAtLoc( 1, 'hgry', GetOwningPlayer(udg_BB_Caster[udg_BB_Index3]), udg_BB_Point3, bj_UNIT_FACING )
            call UnitApplyTimedLifeBJ( 0.50, 'BTLF', GetLastCreatedUnit() )
            call UnitAddAbilityBJ( 'A018', GetLastCreatedUnit() )
            call SetUnitAbilityLevelSwapped( 'A018', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped(udg_BB_Ability, udg_BB_Caster[udg_BB_Index3]) )
            call IssueImmediateOrderBJ( GetLastCreatedUnit(), "thunderclap" )
            if ( Trig_Bounce_Func002Func003Func017C() ) then
                call RemoveUnit( udg_BB_Dummy[udg_BB_Index3] )
                set udg_BB_Dummy[udg_BB_Index3] = null
                set udg_BB_Index = ( udg_BB_Index - 1 )
                if ( Trig_Bounce_Func002Func003Func017Func005C() ) then
                    set udg_BB_Index2 = 0
                    call DisableTrigger( GetTriggeringTrigger() )
                else
                endif
            else
            endif
        else
            set udg_BB_Point2 = PolarProjectionBJ(udg_BB_Point3, udg_BB_Speed[udg_BB_Index3], udg_BB_Angle[udg_BB_Index3])
            call SetUnitPositionLoc( udg_BB_Dummy[udg_BB_Index3], udg_BB_Point2 )
            call RemoveLocation(udg_BB_Point2)
            call RemoveLocation(udg_BB_Point3)
        endif
        set udg_BB_Index3 = udg_BB_Index3 + 1
    endloop
endfunction

