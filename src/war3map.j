    set gg_trg_TO_AW_eff = CreateTrigger(  )
    call DisableTrigger( gg_trg_TO_AW_eff )
    call TriggerRegisterTimerEventPeriodic( gg_trg_TO_AW_eff, 0.02 )
    call TriggerAddAction( gg_trg_TO_AW_eff, function Trig_TO_AW_eff_Actions )
endfunction

