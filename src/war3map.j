//*
//*  Map Configuration
//*
//***************************************************************************

function config takes nothing returns nothing
    call SetMapName( "TRIGSTR_001" )
    call SetMapDescription( "TRIGSTR_553" )
    call SetPlayers( 10 )
    call SetTeams( 10 )
    call SetGamePlacement( MAP_PLACEMENT_TEAMS_TOGETHER )

    call DefineStartLocation( 0, -5760.0, 6144.0 )
    call DefineStartLocation( 1, -5760.0, 6144.0 )
    call DefineStartLocation( 2, -5760.0, 6144.0 )
    call DefineStartLocation( 3, -5760.0, 6144.0 )
    call DefineStartLocation( 4, -5760.0, 6144.0 )
    call DefineStartLocation( 5, -5760.0, 6144.0 )
    call DefineStartLocation( 6, -5760.0, 6144.0 )
    call DefineStartLocation( 7, -5760.0, 6144.0 )
    call DefineStartLocation( 8, -5760.0, 6144.0 )
    call DefineStartLocation( 9, -5760.0, 6144.0 )

    // Player setup
    call InitCustomPlayerSlots(  )
    call InitCustomTeams(  )
    call InitAllyPriorities(  )
endfunction

