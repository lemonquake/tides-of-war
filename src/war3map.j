        return false
    endif
    return true
endfunction

function Trig_Drag_Actions takes nothing returns nothing
    set udg_EC = 1
    loop
        exitwhen udg_EC > udg_EC_Times
        if ( Trig_Drag_Func001Func001C() ) then
            if ( Trig_Drag_Func001Func001Func001C() ) then
                if ( Trig_Drag_Func001Func001Func001Func002C() ) then
                    set udg_EC_Part[udg_EC] = 1
                    call SetUnitFlyHeightBJ( udg_EC_Dummy1[udg_EC], 38.00, 0.00 )
                    call SetUnitTimeScalePercent( udg_EC_Dummy1[udg_EC], 0.00 )
                    set udg_EC_Point[6] = GetUnitLoc(udg_EC_Dummy1[udg_EC])
                    set udg_EC_Point[7] = GetUnitLoc(udg_EC_Target[udg_EC])
                    call AddSpecialEffectLocBJ( udg_EC_Point[6], "Abilities\\Spells\\Undead\\UndeadMine\\UndeadMineCircle.mdl" )
                    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
                    set udg_EC_Fly[udg_EC] = 1500.00
                    set udg_EC_Power[udg_EC] = ( 40.00 + ( 20.00 * I2R(GetUnitAbilityLevelSwapped('A016', udg_EC_Caster[udg_EC_PNum])) ) )
                    set udg_EC_Struggle[udg_EC] = ( GetUnitMoveSpeed(udg_EC_Target[udg_EC]) / 680.00 )
                    call CreateTextTagLocBJ( I2S(R2I(udg_EC_Power[udg_EC])), udg_EC_Point[6], ( GetUnitFlyHeight(udg_EC_Dummy1[udg_EC]) + 25.00 ), 10, GetRandomPercentageBJ(), GetRandomPercentageBJ(), GetRandomPercentageBJ(), 0 )
                    set udg_EC_Floating[udg_EC] = GetLastCreatedTextTag()
                    set udg_EC_Distance[udg_EC] = ( DistanceBetweenPoints(udg_EC_Point[6], udg_EC_Point[7]) / 6.00 )
                    set udg_EC_Anlge[udg_EC] = AngleBetweenPoints(udg_EC_Point[6], udg_EC_Point[7])
                    set udg_EC_String[0] = "Abilities\\Weapons\\SerpentWardMissile\\SerpentWardMissile.mdl"
                    set udg_EC_Point[8] = PolarProjectionBJ(udg_EC_Point[6], ( udg_EC_Distance[udg_EC] * 1.00 ), udg_EC_Anlge[udg_EC])
                    call CreateNUnitsAtLoc( 1, 'h009', GetOwningPlayer(udg_EC_Dummy1[udg_EC]), udg_EC_Point[8], udg_EC_Anlge[udg_EC] )
                    set udg_EC_Dummy_Chain2[udg_EC] = GetLastCreatedUnit()
                    call SetUnitTimeScalePercent( udg_EC_Dummy_Chain2[udg_EC_Times], 0.00 )
                    call AddSpecialEffectTargetUnitBJ( "chest", udg_EC_Dummy_Chain2[udg_EC], udg_EC_String[0] )
                    set udg_EC_Special1[udg_EC] = GetLastCreatedEffectBJ()
                    call RemoveLocation(udg_EC_Point[8])
                    set udg_EC_Point[8] = PolarProjectionBJ(udg_EC_Point[6], ( udg_EC_Distance[udg_EC] * 2.40 ), udg_EC_Anlge[udg_EC])
                    call CreateNUnitsAtLoc( 1, 'h009', GetOwningPlayer(udg_EC_Dummy1[udg_EC]), udg_EC_Point[8], udg_EC_Anlge[udg_EC] )
                    set udg_EC_Dummy_Chain3[udg_EC] = GetLastCreatedUnit()
                    call SetUnitTimeScalePercent( udg_EC_Dummy_Chain3[udg_EC_Times], 0.00 )
                    call AddSpecialEffectTargetUnitBJ( "chest", udg_EC_Dummy_Chain3[udg_EC], udg_EC_String[0] )
                    set udg_EC_Special3[udg_EC] = GetLastCreatedEffectBJ()
                    call RemoveLocation(udg_EC_Point[8])
                    set udg_EC_Point[8] = PolarProjectionBJ(udg_EC_Point[6], ( udg_EC_Distance[udg_EC] * 3.80 ), udg_EC_Anlge[udg_EC])
                    call CreateNUnitsAtLoc( 1, 'h009', GetOwningPlayer(udg_EC_Dummy1[udg_EC]), udg_EC_Point[8], udg_EC_Anlge[udg_EC] )
                    set udg_EC_Dummy_Chain[udg_EC] = GetLastCreatedUnit()
                    call SetUnitTimeScalePercent( udg_EC_Dummy_Chain[udg_EC_Times], 0.00 )
                    call AddSpecialEffectTargetUnitBJ( "chest", udg_EC_Dummy_Chain[udg_EC], udg_EC_String[0] )
                    set udg_EC_Special[udg_EC] = GetLastCreatedEffectBJ()
                    call RemoveLocation(udg_EC_Point[8])
                    set udg_EC_Point[8] = PolarProjectionBJ(udg_EC_Point[6], ( udg_EC_Distance[udg_EC] * 5.20 ), udg_EC_Anlge[udg_EC])
                    call CreateNUnitsAtLoc( 1, 'h009', GetOwningPlayer(udg_EC_Dummy1[udg_EC]), udg_EC_Point[8], udg_EC_Anlge[udg_EC] )
                    set udg_EC_Dummy_Chain4[udg_EC] = GetLastCreatedUnit()
                    call SetUnitTimeScalePercent( udg_EC_Dummy_Chain4[udg_EC_Times], 0.00 )
                    call AddSpecialEffectTargetUnitBJ( "chest", udg_EC_Dummy_Chain4[udg_EC], udg_EC_String[0] )
                    set udg_EC_Special4[udg_EC] = GetLastCreatedEffectBJ()
                    call RemoveLocation(udg_EC_Point[8])
                    if ( Trig_Drag_Func001Func001Func001Func002Func044C() ) then
                        set udg_EC_Height[udg_EC] = ( ( GetUnitFlyHeight(udg_EC_Target[udg_EC]) + 25.00 ) / 6.00 )
                        call SetUnitFlyHeightBJ( udg_EC_Dummy_Chain2[udg_EC], ( udg_EC_Height[udg_EC] * 1.00 ), 0.00 )
                        call SetUnitFlyHeightBJ( udg_EC_Dummy_Chain3[udg_EC], ( udg_EC_Height[udg_EC] * 2.40 ), 0.00 )
                        call SetUnitFlyHeightBJ( udg_EC_Dummy_Chain[udg_EC], ( udg_EC_Height[udg_EC] * 3.80 ), 0.00 )
                        call SetUnitFlyHeightBJ( udg_EC_Dummy_Chain4[udg_EC], ( udg_EC_Height[udg_EC] * 5.20 ), 0.00 )
                    else
                    endif
                    call RemoveLocation(udg_EC_Point[6])
                    call RemoveLocation(udg_EC_Point[7])
                else
                    set udg_EC_Distance[udg_EC] = ( udg_EC_Distance[udg_EC] - udg_EC_Speed[udg_EC] )
                    set udg_EC_Point[2] = GetUnitLoc(udg_EC_Dummy1[udg_EC])
                    set udg_EC_Point[3] = PolarProjectionBJ(udg_EC_Point[2], udg_EC_Speed[udg_EC], udg_EC_Anlge[udg_EC])
                    call SetUnitPositionLoc( udg_EC_Dummy1[udg_EC], udg_EC_Point[3] )
                    call RemoveLocation(udg_EC_Point[2])
                    call RemoveLocation(udg_EC_Point[3])
                    set udg_EC_Fly[udg_EC] = ( ( ( 4.00 * udg_EC_Height[udg_EC] ) / udg_EC_Max_Distance[udg_EC] ) * ( ( udg_EC_Max_Distance[udg_EC] - udg_EC_Distance[udg_EC] ) * ( udg_EC_Distance[udg_EC] / udg_EC_Max_Distance[udg_EC] ) ) )
                    call SetUnitFlyHeightBJ( udg_EC_Dummy1[udg_EC], udg_EC_Fly[udg_EC], 0.00 )
                endif
            else
                if ( Trig_Drag_Func001Func001Func001Func001C() ) then
                    if ( Trig_Drag_Func001Func001Func001Func001Func001C() ) then
                        set udg_EC_Skip = ( udg_EC_Skip - 1 )
                        set udg_EC_Off[udg_EC] = false
                        call DestroyTextTagBJ( udg_EC_Floating[udg_EC] )
                        call DestroyEffectBJ( udg_EC_Special[udg_EC] )
                        call DestroyEffectBJ( udg_EC_Special1[udg_EC] )
                        call DestroyEffectBJ( udg_EC_Special3[udg_EC] )
                        call DestroyEffectBJ( udg_EC_Special4[udg_EC] )
                        call UnitApplyTimedLifeBJ( 0.01, 'BTLF', udg_EC_Dummy_Chain[udg_EC] )
                        call UnitApplyTimedLifeBJ( 0.01, 'BTLF', udg_EC_Dummy_Chain2[udg_EC] )
                        call UnitApplyTimedLifeBJ( 0.01, 'BTLF', udg_EC_Dummy_Chain3[udg_EC] )
                        call UnitApplyTimedLifeBJ( 0.01, 'BTLF', udg_EC_Dummy_Chain4[udg_EC] )
                        set udg_EC_Point[10] = GetUnitLoc(udg_EC_Dummy1[udg_EC])
                        call AddSpecialEffectLocBJ( udg_EC_Point[10], "Abilities\\Spells\\Other\\Doom\\DoomDeath.mdl" )
                        call DestroyEffectBJ( GetLastCreatedEffectBJ() )
                        call RemoveLocation(udg_EC_Point[10])
                        call KillUnit( udg_EC_Dummy1[udg_EC] )
                        if ( Trig_Drag_Func001Func001Func001Func001Func001Func018C() ) then
                            set udg_EC_Times = 0
                            call DisableTrigger( gg_trg_Drag )
                        else
                        endif
                    else
                        set udg_EC_Fly[udg_EC] = ( udg_EC_Fly[udg_EC] - 1 )
                        set udg_EC_Point[2] = GetUnitLoc(udg_EC_Dummy1[udg_EC])
                        set udg_EC_Point[3] = GetUnitLoc(udg_EC_Target[udg_EC])
                        set udg_EC_Distance[udg_EC] = ( DistanceBetweenPoints(udg_EC_Point[2], udg_EC_Point[3]) / 6.00 )
                        set udg_EC_Anlge[udg_EC] = AngleBetweenPoints(udg_EC_Point[2], udg_EC_Point[3])
                        set udg_EC_Point[8] = PolarProjectionBJ(udg_EC_Point[2], ( udg_EC_Distance[udg_EC] * 1.00 ), udg_EC_Anlge[udg_EC])
                        call SetUnitPositionLocFacingBJ( udg_EC_Dummy_Chain2[udg_EC], udg_EC_Point[8], udg_EC_Anlge[udg_EC] )
                        call RemoveLocation(udg_EC_Point[8])
                        set udg_EC_Point[8] = PolarProjectionBJ(udg_EC_Point[2], ( udg_EC_Distance[udg_EC] * 2.40 ), udg_EC_Anlge[udg_EC])
                        call SetUnitPositionLocFacingBJ( udg_EC_Dummy_Chain3[udg_EC], udg_EC_Point[8], udg_EC_Anlge[udg_EC] )
                        call RemoveLocation(udg_EC_Point[8])
                        set udg_EC_Point[8] = PolarProjectionBJ(udg_EC_Point[2], ( udg_EC_Distance[udg_EC] * 3.80 ), udg_EC_Anlge[udg_EC])
                        call SetUnitPositionLocFacingBJ( udg_EC_Dummy_Chain[udg_EC], udg_EC_Point[8], udg_EC_Anlge[udg_EC] )
                        call RemoveLocation(udg_EC_Point[8])
                        set udg_EC_Point[8] = PolarProjectionBJ(udg_EC_Point[2], ( udg_EC_Distance[udg_EC] * 5.20 ), udg_EC_Anlge[udg_EC])
                        call SetUnitPositionLocFacingBJ( udg_EC_Dummy_Chain4[udg_EC], udg_EC_Point[8], udg_EC_Anlge[udg_EC] )
                        call RemoveLocation(udg_EC_Point[8])
                        if ( Trig_Drag_Func001Func001Func001Func001Func001Func036C() ) then
                            set udg_EC_Height[udg_EC] = ( ( GetUnitFlyHeight(udg_EC_Target[udg_EC]) + 25.00 ) / 6.00 )
                            call SetUnitFlyHeightBJ( udg_EC_Dummy_Chain2[udg_EC], ( udg_EC_Height[udg_EC] * 1.00 ), 0.00 )
                            call SetUnitFlyHeightBJ( udg_EC_Dummy_Chain3[udg_EC], ( udg_EC_Height[udg_EC] * 2.40 ), 0.00 )
                            call SetUnitFlyHeightBJ( udg_EC_Dummy_Chain[udg_EC], ( udg_EC_Height[udg_EC] * 3.80 ), 0.00 )
                            call SetUnitFlyHeightBJ( udg_EC_Dummy_Chain4[udg_EC], ( udg_EC_Height[udg_EC] * 5.20 ), 0.00 )
                        else
                        endif
                        if ( Trig_Drag_Func001Func001Func001Func001Func001Func037C() ) then
                        else
                            set udg_EC_Size[udg_EC_PNum] = ( udg_EC_Size[udg_EC_PNum] - 1 )
                            call SetUnitUserData( udg_EC_Dummy1[udg_EC_Times], udg_EC_Size[udg_EC_PNum] )
                            call SetUnitScalePercent( udg_EC_Dummy1[udg_EC_Times], I2R(udg_EC_Size[udg_EC_PNum]), I2R(udg_EC_Size[udg_EC_PNum]), I2R(udg_EC_Size[udg_EC_PNum]) )
                            set udg_EC_Struggle[udg_EC] = ( GetUnitMoveSpeed(udg_EC_Target[udg_EC]) / 680.00 )
                            set udg_EC_Power[udg_EC] = ( udg_EC_Power[udg_EC] - udg_EC_Struggle[udg_EC] )
                            call SetTextTagPosBJ( udg_EC_Floating[udg_EC], udg_EC_Point[2], ( GetUnitFlyHeight(udg_EC_Dummy1[udg_EC]) + 25.00 ) )
                            call SetTextTagTextBJ( udg_EC_Floating[udg_EC], I2S(R2I(udg_EC_Power[udg_EC])), 10 )
                            call SetTextTagColorBJ( udg_EC_Floating[udg_EC], GetRandomPercentageBJ(), GetRandomPercentageBJ(), GetRandomPercentageBJ(), 0 )
                            set udg_EC_Point[4] = PolarProjectionBJ(udg_EC_Point[2], ( ( 10.00 / udg_EC_Weight[udg_EC] ) * 0.70 ), udg_EC_Anlge[udg_EC])
                            set udg_EC_Point[5] = PolarProjectionBJ(udg_EC_Point[3], udg_EC_Weight[udg_EC], ( udg_EC_Anlge[udg_EC] - 180.00 ))
                            call SetUnitX(udg_EC_Dummy1[udg_EC], GetLocationX(udg_EC_Point[4]))
                            call SetUnitY(udg_EC_Dummy1[udg_EC], GetLocationY(udg_EC_Point[4]))
                            call SetUnitX(udg_EC_Target[udg_EC], GetLocationX(udg_EC_Point[5]))
                            call SetUnitY(udg_EC_Target[udg_EC], GetLocationY(udg_EC_Point[5]))
                            if ( Trig_Drag_Func001Func001Func001Func001Func001Func037Func016C() ) then
                                call AddSpecialEffectLocBJ( udg_EC_Point[2], "Abilities\\Weapons\\AncientProtectorMissile\\AncientProtectorMissile.mdl" )
                                call DestroyEffectBJ( GetLastCreatedEffectBJ() )
                            else
                            endif
                            call RemoveLocation(udg_EC_Point[4])
                            call RemoveLocation(udg_EC_Point[5])
                        endif
                        call RemoveLocation(udg_EC_Point[2])
                        call RemoveLocation(udg_EC_Point[3])
                    endif
                else
                endif
            endif
        else
        endif
        set udg_EC = udg_EC + 1
    endloop
endfunction

