    call DisableTrigger( gg_trg_P7_Skill )
    call TriggerRegisterVariableEvent( gg_trg_P7_Skill, "udg_GDD_Event", EQUAL, 1.00 )
    call TriggerAddCondition( gg_trg_P7_Skill, Condition( function Trig_P7_Skill_Conditions ) )
