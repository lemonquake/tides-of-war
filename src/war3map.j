    set udg_AI_Skill = GetRandomInt(1, 4)
    if ( Trig_P4_Skill_Func003C() ) then
        call IssueImmediateOrderBJ( gg_unit_EEES_0029, "battleroar" )
        call TriggerSleepAction( GetRandomReal(0.20, 0.30) )
        set udg_TempPoint = PolarProjectionBJ(GetUnitLoc(gg_unit_EEES_0029), 1000.00, GetRandomDirectionDeg())
        call UnitUseItemPointLoc( gg_unit_EEES_0029, GetItemOfTypeFromUnitBJ(gg_unit_EEES_0029, 'I000'), udg_TempPoint )
        call RemoveLocation(udg_TempPoint)
        call TriggerSleepAction( GetRandomReal(0.20, 0.30) )
        set udg_TempPoint = PolarProjectionBJ(GetUnitLoc(gg_unit_EEES_0029), 400.00, GetUnitFacing(udg_GDD_DamageSource))
        call IssuePointOrderLocBJ( gg_unit_EEES_0029, "move", udg_TempPoint )
        call RemoveLocation(udg_TempPoint)
