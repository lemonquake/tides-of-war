function InitTrig_Water_Clone takes nothing returns nothing
    set gg_trg_Water_Clone = CreateTrigger(  )
    call TriggerRegisterVariableEvent( gg_trg_Water_Clone, "udg_GDD_Event", EQUAL, 1.00 )
    call TriggerAddCondition( gg_trg_Water_Clone, Condition( function Trig_Water_Clone_Conditions ) )
    call TriggerAddAction( gg_trg_Water_Clone, function Trig_Water_Clone_Actions )
