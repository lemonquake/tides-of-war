    if ( not ( GetClickedButtonBJ() == udg_DIALOG_FREE_FOR_ALL ) ) then
        return false
    endif
    return true
endfunction

function Trig_Normal_Mode_Func002C takes nothing returns boolean
    if ( not ( GetClickedButtonBJ() == udg_DIALOG_BOMB ) ) then
        return false
    endif
    return true
endfunction

function Trig_Normal_Mode_Func003C takes nothing returns boolean
    if ( not ( GetClickedButtonBJ() == udg_DIALOG_NORMAL ) ) then
        return false
    endif
    return true
endfunction

function Trig_Normal_Mode_Actions takes nothing returns nothing
    if ( Trig_Normal_Mode_Func001C() ) then
        set udg_FREEFORALL = true
        set udg_KILL_LIM = 50
        call DisplayTimedTextToForce( bj_FORCE_ALL_PLAYERS, 60.00, "TRIGSTR_2860" )
        call CinematicModeBJ( false, bj_FORCE_ALL_PLAYERS )
        call MultiboardSetTitleText( udg_Scoreboard, "TRIGSTR_3353" )
        set bj_wantDestroyGroup = true
        call ForForce( bj_FORCE_ALL_PLAYERS, function Trig_Normal_Mode_Func001Func007A )
    else
    endif
    if ( Trig_Normal_Mode_Func002C() ) then
        set udg_PLANT_TEH_BOMB = true
        call DisplayTimedTextToForce( bj_FORCE_ALL_PLAYERS, 60.00, "TRIGSTR_2861" )
        call DialogDisplayBJ( false, udg_DIALOG, Player(0) )
        call DialogSetMessageBJ( udg_DIALOG4_BOMB, "TRIGSTR_2862" )
        call DialogAddButtonBJ( udg_DIALOG4_BOMB, "TRIGSTR_2863" )
        set udg_DIALOG_20_POINTS = GetLastCreatedButtonBJ()
        call DialogAddButtonBJ( udg_DIALOG4_BOMB, "TRIGSTR_2864" )
        set udg_DIALOG_50_POINTS = GetLastCreatedButtonBJ()
        call DialogAddButtonBJ( udg_DIALOG4_BOMB, "TRIGSTR_2865" )
        set udg_DIALOG_99_POINTS = GetLastCreatedButtonBJ()
        call DialogDisplayBJ( true, udg_DIALOG4_BOMB, Player(0) )
    else
    endif
    if ( Trig_Normal_Mode_Func003C() ) then
        call DialogDisplayBJ( false, udg_DIALOG, Player(0) )
        call DialogSetMessageBJ( udg_DIALOG2, "TRIGSTR_2866" )
        call DialogAddButtonBJ( udg_DIALOG2, "TRIGSTR_2867" )
        set udg_DIALOG_20_KILLS = GetLastCreatedButtonBJ()
        call DialogAddButtonBJ( udg_DIALOG2, "TRIGSTR_2868" )
        set udg_DIALOG_50_KILLS = GetLastCreatedButtonBJ()
        call DialogAddButtonBJ( udg_DIALOG2, "TRIGSTR_2869" )
        set udg_DIALOG_99_KILLS = GetLastCreatedButtonBJ()
        call DialogDisplayBJ( true, udg_DIALOG2, Player(0) )
    else
    endif
endfunction

