    set gg_trg_SW_Time = CreateTrigger(  )
    call TriggerAddAction( gg_trg_SW_Time, function Trig_SW_Time_Actions )
endfunction

//===========================================================================
// Trigger: SW
//===========================================================================
function Trig_SW_Func001Func001Func002Func009Func001C takes nothing returns boolean
    if ( not ( udg_PC_Boolean[udg_PC_Integers[2]] != true ) ) then
        return false
    endif
    return true
endfunction

function Trig_SW_Func001Func001Func002Func009Func003C takes nothing returns boolean
    if ( not ( udg_PC_Counter[udg_PC_Integers[2]] >= 0.10 ) ) then
        return false
    endif
    return true
endfunction

function Trig_SW_Func001Func001Func002Func009Func004C takes nothing returns boolean
    if ( not ( udg_PC_Counter[udg_PC_Integers[2]] >= udg_PC_DamageInterval[udg_PC_Integers[2]] ) ) then
        return false
    endif
    return true
endfunction

function Trig_SW_Func001Func001Func002Func009C takes nothing returns boolean
    if ( not ( udg_PC_CastDelay[udg_PC_Integers[2]] > 0.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_SW_Func001Func001Func002Func012C takes nothing returns boolean
    if ( not ( udg_PC_Integers[0] == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_SW_Func001Func001Func002C takes nothing returns boolean
    if ( not ( udg_PC_ShootCount[udg_PC_Integers[2]] > 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_SW_Func001Func001C takes nothing returns boolean
    if ( not ( udg_PC_Cannon[udg_PC_Integers[2]] != null ) ) then
        return false
    endif
    return true
endfunction

function Trig_SW_Actions takes nothing returns nothing
    set udg_PC_Integers[2] = 1
    loop
        exitwhen udg_PC_Integers[2] > udg_PC_Integers[1]
        if ( Trig_SW_Func001Func001C() ) then
            if ( Trig_SW_Func001Func001Func002C() ) then
                set udg_PC_Counter[udg_PC_Integers[2]] = ( udg_PC_Counter[udg_PC_Integers[2]] + 0.05 )
                if ( Trig_SW_Func001Func001Func002Func009C() ) then
                    set udg_PC_CastDelay[udg_PC_Integers[2]] = ( udg_PC_CastDelay[udg_PC_Integers[2]] - 0.05 )
                    if ( Trig_SW_Func001Func001Func002Func009Func003C() ) then
                        set udg_PC_Counter[udg_PC_Integers[2]] = 0.00
                        call SetUnitVertexColorBJ( udg_PC_Cannon[udg_PC_Integers[2]], 20.00, 20.00, 20.00, 60.00 )
                    else
                        call SetUnitVertexColorBJ( udg_PC_Cannon[udg_PC_Integers[2]], 50.00, 50.00, 50.00, 0.00 )
                    endif
                else
                    if ( Trig_SW_Func001Func001Func002Func009Func001C() ) then
                        set udg_PC_Boolean[udg_PC_Integers[2]] = true
                        call SetUnitVertexColorBJ( udg_PC_Cannon[udg_PC_Integers[2]], 50.00, 50.00, 50.00, 0.00 )
                        call SetUnitFlyHeightBJ( udg_PC_Cannon[udg_PC_Integers[2]], 150.00, 0.00 )
                    else
                    endif
                    if ( Trig_SW_Func001Func001Func002Func009Func004C() ) then
                        set udg_PC_ShootCount[udg_PC_Integers[2]] = ( udg_PC_ShootCount[udg_PC_Integers[2]] - 1 )
                        set udg_PC_Counter[udg_PC_Integers[2]] = 0.00
                        set udg_MVC_Point[0] = GetUnitLoc(udg_PC_Cannon[udg_PC_Integers[2]])
                        set udg_MVC_Point[1] = PolarProjectionBJ(udg_MVC_Point[0], 100.00, udg_PC_Angle[udg_PC_Integers[2]])
                        call CreateNUnitsAtLoc( 1, udg_MVC_UnitType[8], GetOwningPlayer(udg_PC_Cannon[udg_PC_Integers[2]]), udg_MVC_Point[0], udg_PC_Angle[udg_PC_Integers[2]] )
                        call SetUnitScalePercent( GetLastCreatedUnit(), 200.00, 200.00, 400.00 )
                        call UnitAddAbilityBJ( 'A06T', GetLastCreatedUnit() )
                        call IssuePointOrderLocBJ( GetLastCreatedUnit(), "carrionswarm", udg_MVC_Point[1] )
                        call UnitApplyTimedLifeBJ( 0.50, 'BTLF', GetLastCreatedUnit() )
                        call RemoveLocation (udg_MVC_Point[0])
                        call RemoveLocation (udg_MVC_Point[1])
                    else
                    endif
                endif
            else
                set udg_RAS_Dummy = udg_PC_Cannon[udg_PC_Integers[2]]
                set udg_RAS_Duration = 0.50
                set udg_RAS_HeightInc = true
                set udg_RAS_Color = 100.00
                call ConditionalTriggerExecute( gg_trg_RemoveA )
                set udg_PC_Cannon[udg_PC_Integers[2]] = null
                set udg_PC_Boolean[udg_PC_Integers[2]] = false
                set udg_PC_Counter[udg_PC_Integers[2]] = 0.00
                set udg_PC_Integers[0] = ( udg_PC_Integers[0] - 1 )
                if ( Trig_SW_Func001Func001Func002Func012C() ) then
                    set udg_PC_Integers[1] = 0
                    call DisableTrigger( GetTriggeringTrigger() )
                else
                endif
            endif
        else
        endif
        set udg_PC_Integers[2] = udg_PC_Integers[2] + 1
    endloop
endfunction

//===========================================================================
function InitTrig_SW takes nothing returns nothing
    set gg_trg_SW = CreateTrigger(  )
    call DisableTrigger( gg_trg_SW )
    call TriggerRegisterTimerEventPeriodic( gg_trg_SW, 0.05 )
    call TriggerAddAction( gg_trg_SW, function Trig_SW_Actions )
endfunction

//===========================================================================
// Trigger: Bash
//===========================================================================
function Trig_Bash_Actions takes nothing returns nothing
    set udg_TempPoint = GetUnitLoc(GetSpellTargetUnit())
    call AddSpecialEffectTargetUnitBJ( "head", GetSpellTargetUnit(), "Abilities\\Spells\\Human\\StormBolt\\StormBoltMissile.mdl" )
    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
    call CreateNUnitsAtLoc( 1, 'h005', GetOwningPlayer(GetTriggerUnit()), GetUnitLoc(GetSpellTargetUnit()), bj_UNIT_FACING )
    call UnitAddAbilityBJ( 'A078', GetLastCreatedUnit() )
    call IssueTargetOrderBJ( GetLastCreatedUnit(), "thunderbolt", GetSpellTargetUnit() )
    call UnitApplyTimedLifeBJ( 1.00, 'BTLF', GetLastCreatedUnit() )
    call SetUnitX(GetTriggerUnit(), GetLocationX(udg_TempPoint))
    call SetUnitY(GetTriggerUnit(), GetLocationY(udg_TempPoint))
    call IssueTargetOrderBJ( GetTriggerUnit(), "attack", GetSpellTargetUnit() )
    call SetUnitFacingToFaceUnitTimed( GetTriggerUnit(), GetSpellTargetUnit(), 0 )
    call SetUnitFacingToFaceUnitTimed( GetSpellTargetUnit(), GetTriggerUnit(), 0 )
    call RemoveLocation (udg_TempPoint)
endfunction

//===========================================================================
function InitTrig_Bash takes nothing returns nothing
    set gg_trg_Bash = CreateTrigger(  )
    call TriggerAddAction( gg_trg_Bash, function Trig_Bash_Actions )
endfunction

