function Trig_AoT_Func002C takes nothing returns boolean
    if ( not ( udg_GDD_Damage > 0.00 ) ) then
        return false
    endif
    if ( not ( UnitHasBuffBJ(udg_GDD_DamagedUnit, 'B01E') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_AoT_Conditions takes nothing returns boolean
    if ( not Trig_AoT_Func002C() ) then
        return false
    endif
    return true
endfunction

function Trig_AoT_Func001Func001Func002001002001 takes nothing returns boolean
    return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_HERO) == true )
endfunction

function Trig_AoT_Func001Func001Func002001002002 takes nothing returns boolean
    return ( GetOwningPlayer(GetFilterUnit()) == GetOwningPlayer(udg_GDD_DamageSource) )
endfunction

function Trig_AoT_Func001Func001Func002001002 takes nothing returns boolean
    return GetBooleanAnd( Trig_AoT_Func001Func001Func002001002001(), Trig_AoT_Func001Func001Func002001002002() )
endfunction

function Trig_AoT_Func001Func001Func002A takes nothing returns nothing
    call UnitDamageTargetBJ( udg_GDD_DamagedUnit, GetEnumUnit(), udg_GDD_Damage, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_FIRE )
endfunction

function Trig_AoT_Func001Func001C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped('A00A', udg_GDD_DamageSource) > 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_AoT_Func001C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped('A00A', udg_GDD_DamageSource) < 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_AoT_Actions takes nothing returns nothing
    if ( Trig_AoT_Func001C() ) then
        call UnitDamageTargetBJ( udg_GDD_DamagedUnit, udg_GDD_DamageSource, udg_GDD_Damage, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_FIRE )
    else
        if ( Trig_AoT_Func001Func001C() ) then
            set bj_wantDestroyGroup = true
            call ForGroupBJ( GetUnitsInRectMatching(GetPlayableMapRect(), Condition(function Trig_AoT_Func001Func001Func002001002)), function Trig_AoT_Func001Func001Func002A )
        else
        endif
    endif
endfunction

