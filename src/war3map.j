function Trig_After_Shock_Func002Func002C takes nothing returns boolean
    if ( ( GetSpellAbilityId() == 'A05Q' ) ) then
        return true
    endif
    if ( ( GetSpellAbilityId() == 'AEET' ) ) then
        return true
    endif
    if ( ( GetSpellAbilityId() == 'A100' ) ) then
        return true
    endif
    return false
endfunction

function Trig_After_Shock_Func002C takes nothing returns boolean
    if ( not ( GetUnitAbilityLevelSwapped('A0as', GetTriggerUnit()) >= 1 ) ) then
        return false
    endif
    if ( not Trig_After_Shock_Func002Func002C() ) then
        return false
    endif
    return true
endfunction

function Trig_After_Shock_Conditions takes nothing returns boolean
    if ( not Trig_After_Shock_Func002C() ) then
        return false
    endif
    return true
endfunction

function Trig_After_Shock_Actions takes nothing returns nothing
    if GetSpellAbilityId() == 'AEET' then
        call Esh_TotemVault(GetTriggerUnit())
    endif
    call Esh_Aftershock(GetTriggerUnit())
endfunction

