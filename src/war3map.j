    call UnitDamageTargetBJ( udg_GDD_DamageSource, udg_GDD_DamagedUnit, udg_PowerStance, ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL )
    call CreateTextTagUnitBJ( ( udg_PlayerColors[GetConvertedPlayerId(GetOwningPlayer(udg_GDD_DamageSource))] + I2S(R2I(( udg_GDD_Damage + udg_PowerStance ))) ), udg_GDD_DamagedUnit, 0.00, 8.50, 100.00, 100.00, 100.00, 0 )
