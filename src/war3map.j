function InitTrig_Knockback_Effects takes nothing returns nothing
    set gg_trg_Knockback_Effects = CreateTrigger(  )
    call TriggerRegisterTimerExpireEventBJ( gg_trg_Knockback_Effects, udg_K2DTimer )
