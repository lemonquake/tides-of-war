//===========================================================================
function Trig_SW_Time_Func001C takes nothing returns boolean
    if ( not ( udg_PC_Integers[0] == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_SW_Time_Actions takes nothing returns nothing
    if ( Trig_SW_Time_Func001C() ) then
        call EnableTrigger( gg_trg_SW )
    else
    endif
    set udg_PC_Integers[0] = ( udg_PC_Integers[0] + 1 )
    set udg_PC_Integers[1] = ( udg_PC_Integers[1] + 1 )
    set udg_PC_Angle[udg_PC_Integers[1]] = GetUnitFacing(GetTriggerUnit())
    set udg_PC_Level[udg_PC_Integers[1]] = GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())
    set udg_MVC_Point[0] = GetUnitLoc(GetTriggerUnit())
    set udg_MVC_Point[1] = GetUnitLoc(GetTriggerUnit())
    set udg_PC_CastDelay[udg_PC_Integers[1]] = 0.50
    set udg_PC_DamageInterval[udg_PC_Integers[1]] = 0.30
    set udg_PC_ShootCount[udg_PC_Integers[1]] = 12
    set udg_PC_Ability[udg_PC_Integers[1]] = 'A005'
    set udg_MVC_UnitType[0] = 'h005'
    set udg_MVC_UnitType[8] = 'h005'
    call CreateNUnitsAtLoc( 1, udg_MVC_UnitType[0], GetOwningPlayer(GetTriggerUnit()), udg_MVC_Point[1], udg_PC_Angle[udg_PC_Integers[1]] )
    set udg_PC_Cannon[udg_PC_Integers[1]] = GetLastCreatedUnit()
    call RemoveLocation (udg_MVC_Point[0])
    call RemoveLocation (udg_MVC_Point[1])
endfunction

