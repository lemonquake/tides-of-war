function InitTrig_LF takes nothing returns nothing
    set gg_trg_LF = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_LF, EVENT_PLAYER_UNIT_SPELL_EFFECT )
    call TriggerAddCondition( gg_trg_LF, Condition( function Trig_LF_Conditions ) )
    call TriggerAddAction( gg_trg_LF, function Trig_LF_Actions )
endfunction

//===========================================================================
// Trigger: LF Rem
//===========================================================================
function Trig_LF_Rem_Conditions takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetTriggerUnit()) == udg_SR_RockCore ) ) then
        return false
    endif
    return true
endfunction

function Trig_LF_Rem_Func003C takes nothing returns boolean
    if ( not ( LoadRealBJ(8, udg_SR_UHandle, udg_SR_Hash) >= 10.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_LF_Rem_Func006C takes nothing returns boolean
    if ( not ( IsUnitGroupEmptyBJ(udg_SR_Rocks) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_LF_Rem_Actions takes nothing returns nothing
    set udg_SR_U = GetTriggerUnit()
    set udg_SR_UHandle = GetHandleId(udg_SR_U)
    if ( Trig_LF_Rem_Func003C() ) then
        set udg_SR_TempPoint = GetUnitLoc(udg_SR_U)
        call CreateNUnitsAtLoc( 1, 'u001', Player(PLAYER_NEUTRAL_PASSIVE), udg_SR_TempPoint, bj_UNIT_FACING )
        call SetUnitFlyHeightBJ( GetLastCreatedUnit(), LoadRealBJ(8, udg_SR_UHandle, udg_SR_Hash), 0.00 )
        call UnitApplyTimedLifeBJ( udg_SR_SummonSFXDuration, 'BTLF', GetLastCreatedUnit() )
        call RemoveLocation (udg_SR_TempPoint)
    else
    endif
    call GroupRemoveUnitSimple( udg_SR_U, udg_SR_Rocks )
    call FlushChildHashtableBJ( udg_SR_UHandle, udg_SR_Hash )
    if ( Trig_LF_Rem_Func006C() ) then
        call DisableTrigger( GetTriggeringTrigger() )
        call DisableTrigger( gg_trg_LF_Loop )
    else
    endif
    call RemoveUnit( udg_SR_U )
endfunction

//===========================================================================
function InitTrig_LF_Rem takes nothing returns nothing
    set gg_trg_LF_Rem = CreateTrigger(  )
    call DisableTrigger( gg_trg_LF_Rem )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_LF_Rem, EVENT_PLAYER_UNIT_DEATH )
    call TriggerAddCondition( gg_trg_LF_Rem, Condition( function Trig_LF_Rem_Conditions ) )
    call TriggerAddAction( gg_trg_LF_Rem, function Trig_LF_Rem_Actions )
endfunction

//===========================================================================
// Trigger: LF Loop
//===========================================================================
function Trig_LF_Loop_Func001Func003Func009Func002C takes nothing returns boolean
    if ( not ( IsUnitType(udg_SR_TempU, UNIT_TYPE_MAGIC_IMMUNE) == false ) ) then
        return false
    endif
    if ( not ( IsUnitType(udg_SR_TempU, UNIT_TYPE_STRUCTURE) == false ) ) then
        return false
    endif
    if ( not ( IsUnitInGroup(udg_SR_TempU, udg_SR_Rocks) == false ) ) then
        return false
    endif
    if ( not ( IsUnitAliveBJ(udg_SR_TempU) == true ) ) then
        return false
    endif
    if ( not ( IsUnitType(udg_SR_TempU, UNIT_TYPE_GROUND) == true ) ) then
        return false
    endif
    if ( not ( IsUnitEnemy(udg_SR_TempU, GetOwningPlayer(udg_SR_U)) == true ) ) then
        return false
    endif
    if ( not ( LoadUnitHandleBJ(9, udg_SR_UHandle, udg_SR_Hash) == LoadUnitHandleBJ(1, udg_SR_UHandle, udg_SR_Hash) ) ) then
        return false
    endif
    return true
endfunction

function Trig_LF_Loop_Func001Func003Func009A takes nothing returns nothing
    set udg_SR_TempU = GetEnumUnit()
    if ( Trig_LF_Loop_Func001Func003Func009Func002C() ) then
        call SaveUnitHandleBJ( udg_SR_TempU, 9, udg_SR_UHandle, udg_SR_Hash )
        call SaveIntegerBJ( 2, 2, udg_SR_UHandle, udg_SR_Hash )
        call GroupAddUnitSimple( udg_SR_TempU, udg_SR_Rocks )
        call UnitPauseTimedLifeBJ( true, udg_SR_U )
    else
    endif
endfunction

function Trig_LF_Loop_Func001Func003C takes nothing returns boolean
    if ( not ( LoadIntegerBJ(2, udg_SR_UHandle, udg_SR_Hash) == 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_LF_Loop_Func001Func004Func007C takes nothing returns boolean
    if ( not ( RectContainsLoc(GetPlayableMapRect(), udg_SR_TempPoint3) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_LF_Loop_Func001Func004Func008C takes nothing returns boolean
    if ( not ( DistanceBetweenPoints(udg_SR_TempPoint, udg_SR_TempPoint2) <= 50.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_LF_Loop_Func001Func004C takes nothing returns boolean
    if ( not ( LoadIntegerBJ(2, udg_SR_UHandle, udg_SR_Hash) == 2 ) ) then
        return false
    endif
    return true
endfunction

function Trig_LF_Loop_Func001Func005Func001C takes nothing returns boolean
    if ( not ( LoadRealBJ(8, udg_SR_UHandle, udg_SR_Hash) <= 10.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_LF_Loop_Func001Func005C takes nothing returns boolean
    if ( not ( LoadIntegerBJ(2, udg_SR_UHandle, udg_SR_Hash) == 3 ) ) then
        return false
    endif
    return true
endfunction

function Trig_LF_Loop_Func001Func006Func001C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(LoadUnitHandleBJ(3, udg_SR_UHandle, udg_SR_Hash)) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_LF_Loop_Func001Func006C takes nothing returns boolean
    if ( not ( LoadIntegerBJ(2, udg_SR_UHandle, udg_SR_Hash) == 4 ) ) then
        return false
    endif
    return true
endfunction

function Trig_LF_Loop_Func001A takes nothing returns nothing
    set udg_SR_U = GetEnumUnit()
    set udg_SR_UHandle = GetHandleId(udg_SR_U)
    if ( Trig_LF_Loop_Func001Func003C() ) then
        set udg_SR_Angle = ( LoadRealBJ(6, udg_SR_UHandle, udg_SR_Hash) + udg_SR_RockSpinSpeed )
        call SaveRealBJ( udg_SR_Angle, 6, udg_SR_UHandle, udg_SR_Hash )
        set udg_SR_TempPoint = GetUnitLoc(LoadUnitHandleBJ(1, udg_SR_UHandle, udg_SR_Hash))
        set udg_SR_TempX = GetLocationX(udg_SR_TempPoint)
        set udg_SR_TempY = GetLocationY(udg_SR_TempPoint)
        call SetUnitX(udg_SR_U, udg_SR_TempX + udg_SR_RockDistance * Cos(udg_SR_Angle * bj_DEGTORAD))
        call SetUnitY(udg_SR_U, udg_SR_TempY + udg_SR_RockDistance * Sin(udg_SR_Angle * bj_DEGTORAD))
        set udg_SR_TempGroup = GetUnitsInRangeOfLocAll(LoadRealBJ(4, udg_SR_UHandle, udg_SR_Hash), udg_SR_TempPoint)
        call ForGroupBJ( udg_SR_TempGroup, function Trig_LF_Loop_Func001Func003Func009A )
        call RemoveLocation(udg_SR_TempPoint)
        call DestroyGroup (udg_SR_TempGroup)
    else
    endif
    if ( Trig_LF_Loop_Func001Func004C() ) then
        set udg_SR_TempPoint = GetUnitLoc(udg_SR_U)
        set udg_SR_TempU = LoadUnitHandleBJ(9, udg_SR_UHandle, udg_SR_Hash)
        set udg_SR_TempPoint2 = GetUnitLoc(udg_SR_TempU)
        set udg_SR_TempReal = LoadRealBJ(5, udg_SR_UHandle, udg_SR_Hash)
        set udg_SR_Angle = AngleBetweenPoints(udg_SR_TempPoint, udg_SR_TempPoint2)
        set udg_SR_TempPoint3 = PolarProjectionBJ(udg_SR_TempPoint, udg_SR_TempReal, udg_SR_Angle)
        if ( Trig_LF_Loop_Func001Func004Func007C() ) then
            set udg_SR_TempX = GetUnitX(udg_SR_U)
            set udg_SR_TempY = GetUnitY(udg_SR_U)
            call SetUnitX(udg_SR_U, udg_SR_TempX + udg_SR_TempReal * Cos(udg_SR_Angle * bj_DEGTORAD))
            call SetUnitY(udg_SR_U, udg_SR_TempY + udg_SR_TempReal * Sin(udg_SR_Angle * bj_DEGTORAD))
        else
            call KillUnit( udg_SR_U )
        endif
        if ( Trig_LF_Loop_Func001Func004Func008C() ) then
            call SaveIntegerBJ( 3, 2, udg_SR_UHandle, udg_SR_Hash )
        else
        endif
        call RemoveLocation(udg_SR_TempPoint2)
        call RemoveLocation(udg_SR_TempPoint)
    else
    endif
    if ( Trig_LF_Loop_Func001Func005C() ) then
        if ( Trig_LF_Loop_Func001Func005Func001C() ) then
            set udg_SR_TempPoint = GetUnitLoc(udg_SR_U)
            call UnitDamageTargetBJ( LoadUnitHandleBJ(1, udg_SR_UHandle, udg_SR_Hash), LoadUnitHandleBJ(9, udg_SR_UHandle, udg_SR_Hash), LoadRealBJ(3, udg_SR_UHandle, udg_SR_Hash), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL )
            call AddSpecialEffectLocBJ( udg_SR_TempPoint, udg_SR_CollisionSFX )
            call DestroyEffectBJ( GetLastCreatedEffectBJ() )
            call GroupRemoveUnitSimple( LoadUnitHandleBJ(9, udg_SR_UHandle, udg_SR_Hash), udg_SR_Rocks )
            call KillUnit( udg_SR_U )
            call RemoveLocation (udg_SR_TempPoint)
        else
            set udg_SR_TempReal = ( LoadRealBJ(8, udg_SR_UHandle, udg_SR_Hash) - udg_SR_RockFallSpeed )
            call SaveRealBJ( udg_SR_TempReal, 8, udg_SR_UHandle, udg_SR_Hash )
            call SetUnitFlyHeightBJ( udg_SR_TempU, udg_SR_TempReal, 0.00 )
        endif
    else
    endif
    if ( Trig_LF_Loop_Func001Func006C() ) then
        if ( Trig_LF_Loop_Func001Func006Func001C() ) then
            call DestroyLightningBJ( LoadLightningHandleBJ(9, udg_SR_UHandle, udg_SR_Hash) )
            set udg_SR_Angle = ( LoadRealBJ(6, udg_SR_UHandle, udg_SR_Hash) + udg_SR_RockSpinSpeed2 )
            call SaveRealBJ( udg_SR_Angle, 6, udg_SR_UHandle, udg_SR_Hash )
            set udg_SR_TempPoint = GetUnitLoc(LoadUnitHandleBJ(3, udg_SR_UHandle, udg_SR_Hash))
            set udg_SR_TempPoint2 = GetUnitLoc(udg_SR_U)
            call SaveRealBJ( LoadRealBJ(8, GetHandleIdBJ(LoadUnitHandleBJ(3, udg_SR_UHandle, udg_SR_Hash)), udg_SR_Hash), 8, udg_SR_UHandle, udg_SR_Hash )
            set udg_SR_TempReal = LoadRealBJ(8, udg_SR_UHandle, udg_SR_Hash)
            call SetUnitFlyHeightBJ( udg_SR_U, udg_SR_TempReal, 0.00 )
            set udg_SR_TempZ = GetLocationZ(udg_SR_TempPoint) + udg_SR_TempReal
            set udg_SR_TempZ2 = GetLocationZ(udg_SR_TempPoint2) + udg_SR_TempReal
            set udg_SR_TempLightning = AddLightningEx(udg_SR_RockLinkLightning, true, GetLocationX(udg_SR_TempPoint), GetLocationY(udg_SR_TempPoint), udg_SR_TempZ, GetLocationX(udg_SR_TempPoint2), GetLocationY(udg_SR_TempPoint2), udg_SR_TempZ2)
            call SaveLightningHandleBJ( udg_SR_TempLightning, 9, udg_SR_UHandle, udg_SR_Hash )
            set udg_SR_TempReal = LoadRealBJ(7, udg_SR_UHandle, udg_SR_Hash)
            set udg_SR_TempX = GetLocationX(udg_SR_TempPoint)
            set udg_SR_TempY = GetLocationY(udg_SR_TempPoint)
            call SetUnitX(udg_SR_U, udg_SR_TempX + udg_SR_TempReal * Cos(udg_SR_Angle * bj_DEGTORAD))
            call SetUnitY(udg_SR_U, udg_SR_TempY + udg_SR_TempReal * Sin(udg_SR_Angle * bj_DEGTORAD))
            call RemoveLocation(udg_SR_TempPoint2)
            call RemoveLocation(udg_SR_TempPoint)
        else
            call DestroyLightningBJ( LoadLightningHandleBJ(9, udg_SR_UHandle, udg_SR_Hash) )
            call FlushChildHashtableBJ( udg_SR_UHandle, udg_SR_Hash )
            call RemoveUnit( udg_SR_U )
        endif
    else
    endif
        call RemoveLocation(udg_SR_TempPoint3)
endfunction

function Trig_LF_Loop_Actions takes nothing returns nothing
    call ForGroupBJ( udg_SR_Rocks, function Trig_LF_Loop_Func001A )
endfunction

//===========================================================================
function InitTrig_LF_Loop takes nothing returns nothing
    set gg_trg_LF_Loop = CreateTrigger(  )
    call DisableTrigger( gg_trg_LF_Loop )
    call TriggerRegisterTimerEventPeriodic( gg_trg_LF_Loop, 0.03 )
    call TriggerAddAction( gg_trg_LF_Loop, function Trig_LF_Loop_Actions )
endfunction

//===========================================================================
// Trigger: Dimensional Objects
//===========================================================================
function Trig_Dimensional_Objects_Func003002003001 takes nothing returns boolean
    return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_STRUCTURE) == false )
endfunction

function Trig_Dimensional_Objects_Func003002003002001 takes nothing returns boolean
    return ( IsUnitAliveBJ(GetFilterUnit()) == true )
endfunction

function Trig_Dimensional_Objects_Func003002003002002001 takes nothing returns boolean
    return ( GetUnitAbilityLevelSwapped('A00A', GetFilterUnit()) < 1 )
endfunction

function Trig_Dimensional_Objects_Func003002003002002002 takes nothing returns boolean
    return ( GetFilterUnit() != GetTriggerUnit() )
endfunction

function Trig_Dimensional_Objects_Func003002003002002 takes nothing returns boolean
    return GetBooleanAnd( Trig_Dimensional_Objects_Func003002003002002001(), Trig_Dimensional_Objects_Func003002003002002002() )
endfunction

function Trig_Dimensional_Objects_Func003002003002 takes nothing returns boolean
    return GetBooleanAnd( Trig_Dimensional_Objects_Func003002003002001(), Trig_Dimensional_Objects_Func003002003002002() )
endfunction

function Trig_Dimensional_Objects_Func003002003 takes nothing returns boolean
    return GetBooleanAnd( Trig_Dimensional_Objects_Func003002003001(), Trig_Dimensional_Objects_Func003002003002() )
endfunction

function Trig_Dimensional_Objects_Actions takes nothing returns nothing
    set udg_TempPoint = GetSpellTargetLoc()
    set bj_wantDestroyGroup = true
    set udg_Temp_Group = GetUnitsInRangeOfLocMatching(500.00, udg_TempPoint, Condition(function Trig_Dimensional_Objects_Func003002003))
    call CreateNUnitsAtLoc( 1, 'hkni', GetOwningPlayer(GetTriggerUnit()), udg_TempPoint, bj_UNIT_FACING )
    call UnitAddAbilityBJ( 'A03G', GetLastCreatedUnit() )
    call SetUnitAbilityLevelSwapped( 'A03G', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped('A03H', GetTriggerUnit()) )
    call IssueImmediateOrderBJ( GetLastCreatedUnit(), "thunderclap" )
    call UnitApplyTimedLifeBJ( 2.00, 'BTLF', GetLastCreatedUnit() )
    set udg_JDA_JumpHigh_Distance = 0.70
    set udg_JDA_DestroyTrees_Dash = true
    set udg_JDA_Collusion = false
    set udg_JDA_Unit = GroupPickRandomUnit(udg_Temp_Group)
    set udg_JDA_TargetPoint = udg_TempPoint
    set udg_JDA_Speed = 26.00
    set udg_JDA_Animation = "death"
    set udg_JDA_AnimationSpeed = 2.00
    call ConditionalTriggerExecute( gg_trg_Set_Leap )
    call DestroyGroup(udg_Temp_Group)
    call RemoveLocation(udg_TempPoint)
endfunction

//===========================================================================
function InitTrig_Dimensional_Objects takes nothing returns nothing
    set gg_trg_Dimensional_Objects = CreateTrigger(  )
    call TriggerAddAction( gg_trg_Dimensional_Objects, function Trig_Dimensional_Objects_Actions )
endfunction

//===========================================================================
// Trigger: Warp
//===========================================================================
function Trig_Warp_Func001C takes nothing returns boolean
    if ( not ( udg_GC_Integers[0] == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Warp_Actions takes nothing returns nothing
    if ( Trig_Warp_Func001C() ) then
        call EnableTrigger( gg_trg_Warp_Ef )
    else
    endif
    set udg_GC_Integers[0] = ( udg_GC_Integers[0] + 1 )
    set udg_GC_Integers[1] = ( udg_GC_Integers[1] + 1 )
    set udg_GC_Cast[udg_GC_Integers[1]] = GetTriggerUnit()
    set udg_GC_Target[udg_GC_Integers[1]] = GetSpellTargetUnit()
    set udg_MVC_Point[0] = GetUnitLoc(udg_GC_Target[udg_GC_Integers[1]])
    set udg_GC_Counter[udg_GC_Integers[1]] = 0.00
    set udg_GC_Check[udg_GC_Integers[1]] = false
    set udg_GC_AOE[udg_GC_Integers[1]] = 300.00
    set udg_GC_Damage[udg_GC_Integers[1]] = 0.00
    set udg_GC_Speed[udg_GC_Integers[1]] = 60.00
    set udg_GC_Delay[udg_GC_Integers[1]] = 1.50
    set udg_MVC_UnitType[1] = 'h011'
    set udg_MVC_UnitType[2] = 'h012'
    set udg_MVC_UnitType[3] = 'h00Y'
    set udg_MVC_UnitType[4] = 'h00Y'
    call CreateNUnitsAtLoc( 1, udg_MVC_UnitType[1], GetOwningPlayer(udg_GC_Target[1]), udg_MVC_Point[0], GetUnitFacing(udg_GC_Target[1]) )
    set udg_GC_Dummy[udg_GC_Integers[1]] = GetLastCreatedUnit()
    call SelectUnitForPlayerSingle( udg_GC_Dummy[udg_GC_Integers[1]], GetOwningPlayer(udg_GC_Dummy[udg_GC_Integers[1]]) )
    call PauseUnitBJ( true, udg_GC_Target[udg_GC_Integers[1]] )
    call ShowUnitHide( udg_GC_Target[udg_GC_Integers[1]] )
    call GroupAddUnitSimple( udg_GC_Target[udg_GC_Integers[1]], udg_GC_Group )
    call RemoveLocation (udg_MVC_Point[0])
endfunction

