    if ( not Trig_Create_Multiboard_Func006Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_Create_Multiboard_Func007Func001C takes nothing returns boolean
    if ( ( udg_KILL_LIM == 99 ) ) then
        return true
    endif
    if ( ( udg_Point_Limit == 99 ) ) then
        return true
    endif
    return false
endfunction

