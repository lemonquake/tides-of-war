            set udg_DUEL_MODE_BOOL = false
            call DialogDisplayBJ( false, udg_DIALOG3_DUEL, Player(0) )
            set bj_wantDestroyGroup = true
            call ForGroupBJ( GetUnitsInRectMatching(GetEntireMapRect(), Condition(function Trig_Duel_Mode_Dialog_Func001Func001Func005001002)), function Trig_Duel_Mode_Dialog_Func001Func001Func005A )
            call CinematicModeBJ( false, bj_FORCE_ALL_PLAYERS )
