function Trig_Kill_Actions takes nothing returns nothing
    local force tempForce = null
    set udg_Kill_Count_P = GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))
    set udg_Death_Count_P = GetConvertedPlayerId(GetOwningPlayer(GetDyingUnit()))
    set udg_Kill_Count[udg_Kill_Count_P] = ( udg_Kill_Count[udg_Kill_Count_P] + 1 )
    set udg_Death_Count[udg_Death_Count_P] = ( udg_Death_Count[udg_Death_Count_P] + 1 )
    call MultiboardSetItemValueBJ( GetLastCreatedMultiboard(), 3, udg_Multiboard_Spots[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))], I2S(udg_Kill_Count[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))]) )
    call MultiboardSetItemValueBJ( GetLastCreatedMultiboard(), 4, udg_Multiboard_Spots[GetConvertedPlayerId(GetOwningPlayer(GetDyingUnit()))], I2S(udg_Death_Count[GetConvertedPlayerId(GetOwningPlayer(GetDyingUnit()))]) )
    set bj_wantDestroyGroup = true
    call ForForce( GetPlayersAllies(GetOwningPlayer(GetKillingUnitBJ())), function Trig_Kill_Func009A )
    if ( Trig_Kill_Func010C() ) then
        if ( Trig_Kill_Func010Func001C() ) then
            set udg_AI_Dagger[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] = true
            call CreateItem('I000', GetRectCenterX(gg_rct_Item_Dump), GetRectCenterY(gg_rct_Item_Dump))
            call SetItemPlayerBJ( GetLastCreatedItem(), GetOwningPlayer(GetKillingUnitBJ()), false )
        else
        endif
        if ( Trig_Kill_Func010Func002C() ) then
            call CreateItem('gcel', GetRectCenterX(gg_rct_Item_Dump), GetRectCenterY(gg_rct_Item_Dump))
            call SetItemPlayerBJ( GetLastCreatedItem(), GetOwningPlayer(GetKillingUnitBJ()), false )
        else
        endif
        if ( Trig_Kill_Func010Func003C() ) then
            call CreateItem('I00H', GetRectCenterX(gg_rct_Item_Dump), GetRectCenterY(gg_rct_Item_Dump))
            call SetItemPlayerBJ( GetLastCreatedItem(), GetOwningPlayer(GetKillingUnitBJ()), false )
            call CreateItem('I00M', GetRectCenterX(gg_rct_Item_Dump), GetRectCenterY(gg_rct_Item_Dump))
            call SetItemPlayerBJ( GetLastCreatedItem(), GetOwningPlayer(GetKillingUnitBJ()), false )
        else
        endif
        if ( Trig_Kill_Func010Func004C() ) then
            call CreateItem('I00G', GetRectCenterX(gg_rct_Item_Dump), GetRectCenterY(gg_rct_Item_Dump))
            call SetItemPlayerBJ( GetLastCreatedItem(), GetOwningPlayer(GetKillingUnitBJ()), false )
        else
        endif
        if ( Trig_Kill_Func010Func005C() ) then
            call CreateItem('I00F', GetRectCenterX(gg_rct_Item_Dump), GetRectCenterY(gg_rct_Item_Dump))
            call SetItemPlayerBJ( GetLastCreatedItem(), GetOwningPlayer(GetKillingUnitBJ()), false )
        else
        endif
        if ( Trig_Kill_Func010Func006C() ) then
            call CreateItem('I00S', GetRectCenterX(gg_rct_Item_Dump), GetRectCenterY(gg_rct_Item_Dump))
            call SetItemPlayerBJ( GetLastCreatedItem(), GetOwningPlayer(GetKillingUnitBJ()), false )
        else
        endif
        if ( Trig_Kill_Func010Func007C() ) then
            call CreateItem('gcel', GetRectCenterX(gg_rct_Item_Dump), GetRectCenterY(gg_rct_Item_Dump))
            call SetItemPlayerBJ( GetLastCreatedItem(), GetOwningPlayer(GetKillingUnitBJ()), false )
            call CreateItem('I00M', GetRectCenterX(gg_rct_Item_Dump), GetRectCenterY(gg_rct_Item_Dump))
            call SetItemPlayerBJ( GetLastCreatedItem(), GetOwningPlayer(GetKillingUnitBJ()), false )
        else
        endif
    else
    endif
    if ( Trig_Kill_Func011C() ) then
        call DisplayTimedTextToForce( bj_FORCE_ALL_PLAYERS, 15.00, ( udg_Players_Name[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] + " WON TEH GAME!!!111!!!!!1!" ) )
        set bj_wantDestroyGroup = true
        set tempForce = GetPlayersMatching(Condition(function Trig_Kill_Func011Func003001001))
        call ForForce(tempForce, function Trig_Kill_Func011Func003A)
        call DestroyForce(tempForce)
        set tempForce = null
        set bj_wantDestroyGroup = true
        set tempForce = GetPlayersMatching(Condition(function Trig_Kill_Func011Func005001001))
        call ForForce(tempForce, function Trig_Kill_Func011Func005A)
        call DestroyForce(tempForce)
        set tempForce = null
    else
    endif
endfunction

