// Trigger: Add
//===========================================================================
function Trig_Add_Conditions takes nothing returns boolean
    if ( not ( GetItemType(GetManipulatedItem()) == ITEM_TYPE_CHARGED ) ) then
        return false
    endif
    return true
endfunction

function Trig_Add_Func002Func001C takes nothing returns boolean
    if ( not ( GetItemTypeId(UnitItemInSlotBJ(GetTriggerUnit(), GetForLoopIndexA())) == GetItemTypeId(GetManipulatedItem()) ) ) then
        return false
    endif
    if ( not ( UnitItemInSlotBJ(GetTriggerUnit(), GetForLoopIndexA()) != GetManipulatedItem() ) ) then
        return false
    endif
    return true
endfunction

function Trig_Add_Actions takes nothing returns nothing
    set bj_forLoopAIndex = 1
    set bj_forLoopAIndexEnd = 6
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        if ( Trig_Add_Func002Func001C() ) then
            call SetItemCharges( UnitItemInSlotBJ(GetTriggerUnit(), GetForLoopIndexA()), ( GetItemCharges(UnitItemInSlotBJ(GetTriggerUnit(), GetForLoopIndexA())) + GetItemCharges(GetManipulatedItem()) ) )
            call RemoveItem( GetManipulatedItem() )
        else
        endif
        set bj_forLoopAIndex = bj_forLoopAIndex + 1
    endloop
endfunction

//===========================================================================
function InitTrig_Add takes nothing returns nothing
    set gg_trg_Add = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_Add, EVENT_PLAYER_UNIT_PICKUP_ITEM )
    call TriggerAddCondition( gg_trg_Add, Condition( function Trig_Add_Conditions ) )
    call TriggerAddAction( gg_trg_Add, function Trig_Add_Actions )
endfunction

//===========================================================================
// Trigger: Split
//===========================================================================
function Trig_Split_Func002C takes nothing returns boolean
    if ( not ( udg_order >= 852002 ) ) then
        return false
    endif
    if ( not ( udg_order <= 852007 ) ) then
        return false
    endif
    if ( not ( GetOrderTargetItem() == UnitItemInSlotBJ(GetOrderedUnit(), ( udg_order - 852001 )) ) ) then
        return false
    endif
    if ( not ( GetItemCharges(GetOrderTargetItem()) > 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Split_Actions takes nothing returns nothing
    set udg_order = GetIssuedOrderId()
    if ( Trig_Split_Func002C() ) then
        call SetItemCharges( GetOrderTargetItem(), ( GetItemCharges(GetOrderTargetItem()) - 1 ) )
        set udg_L = GetUnitLoc(GetOrderedUnit())
        call CreateItemLoc( GetItemTypeId(GetOrderTargetItem()), udg_L )
        call RemoveLocation(udg_L)
        call SetItemCharges( GetLastCreatedItem(), 1 )
    else
    endif
endfunction

//===========================================================================
function InitTrig_Split takes nothing returns nothing
    set gg_trg_Split = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_Split, EVENT_PLAYER_UNIT_ISSUED_TARGET_ORDER )
    call TriggerAddAction( gg_trg_Split, function Trig_Split_Actions )
endfunction

