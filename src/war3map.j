//===========================================================================
function Trig_Enchant_Totem_Cancel_Func002C takes nothing returns boolean
    if ( not ( udg_DamageEventType != 1 ) ) then
        return false
    endif
    if ( not ( UnitHasBuffBJ(udg_DamageEventSource, 'B01R') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Enchant_Totem_Cancel_Conditions takes nothing returns boolean
    if ( not Trig_Enchant_Totem_Cancel_Func002C() ) then
        return false
    endif
    return true
endfunction

function Trig_Enchant_Totem_Cancel_Actions takes nothing returns nothing
    call UnitDamageTargetBJ( udg_DamageEventSource, udg_DamageEventTarget, 200.00, ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL )
    call CreateTextTagUnitBJ( ( udg_PlayerColors[GetConvertedPlayerId(GetOwningPlayer(udg_DamageEventSource))] + "200!" ), udg_DamageEventTarget, 0.00, 12.00, 100.00, 100.00, 100.00, 0 )
    call SetTextTagVelocityBJ( GetLastCreatedTextTag(), 100.00, 90.00 )
    call SetTextTagPermanentBJ( GetLastCreatedTextTag(), false )
    call SetTextTagLifespanBJ( GetLastCreatedTextTag(), udg_Text_Duration )
    call SetTextTagFadepointBJ( GetLastCreatedTextTag(), 0.65 )
    call UnitRemoveBuffBJ( 'B01R', udg_DamageEventSource )
endfunction

//===========================================================================
function InitTrig_Enchant_Totem_Cancel takes nothing returns nothing
    set gg_trg_Enchant_Totem_Cancel = CreateTrigger(  )
    call DisableTrigger( gg_trg_Enchant_Totem_Cancel )
    call TriggerRegisterVariableEvent( gg_trg_Enchant_Totem_Cancel, "udg_DamageEvent", EQUAL, 1.00 )
    call TriggerAddCondition( gg_trg_Enchant_Totem_Cancel, Condition( function Trig_Enchant_Totem_Cancel_Conditions ) )
    call TriggerAddAction( gg_trg_Enchant_Totem_Cancel, function Trig_Enchant_Totem_Cancel_Actions )
endfunction

//===========================================================================
// Trigger: On Damage
//
// This trigger displays floating text whenever a unit takes damage of any kind.
//===========================================================================
function Trig_On_Damage_Func001C takes nothing returns boolean
    if ( not ( UnitHasBuffBJ(udg_GDD_DamageSource, 'B01R') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_On_Damage_Actions takes nothing returns nothing
    if ( Trig_On_Damage_Func001C() ) then
        call UnitRemoveBuffBJ( 'B01R', udg_GDD_DamageSource )
        call UnitDamageTargetBJ( udg_GDD_DamageSource, udg_GDD_DamagedUnit, 200.00, ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL )
        call AddSpecialEffectTargetUnitBJ( "chest", udg_GDD_DamagedUnit, "Abilities\\Spells\\Human\\Defend\\DefendCaster.mdl" )
        call DestroyEffectBJ( GetLastCreatedEffectBJ() )
        call CreateTextTagUnitBJ( ( udg_PlayerColors[GetConvertedPlayerId(GetOwningPlayer(udg_GDD_DamageSource))] + "200!" ), udg_GDD_DamagedUnit, 0.00, 12.00, 100.00, 100.00, 100.00, 0 )
        call SetTextTagVelocityBJ( GetLastCreatedTextTag(), 100.00, 90.00 )
        call SetTextTagPermanentBJ( GetLastCreatedTextTag(), false )
        call SetTextTagLifespanBJ( GetLastCreatedTextTag(), udg_Text_Duration )
        call SetTextTagFadepointBJ( GetLastCreatedTextTag(), 0.65 )
    else
    endif
endfunction

