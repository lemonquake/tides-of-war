    if ( not Trig_Take_Damage_Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_Take_Damage_Actions takes nothing returns nothing
    set udg_Combat_Index2 = ( udg_Combat_Index2 + 1 )
    set udg_Combat_Unit[udg_Combat_Index2] = udg_GDD_DamagedUnit
    set udg_Combat_Time[udg_Combat_Index2] = 2.00
    call ConditionalTriggerExecute( gg_trg_Combat_Check )
    set udg_Combat_Index2 = ( udg_Combat_Index2 + 1 )
    set udg_Combat_Unit[udg_Combat_Index2] = GetCancelledStructure()
    set udg_Combat_Time[udg_Combat_Index2] = 0.50
    call ConditionalTriggerExecute( gg_trg_Combat_Check )
endfunction

