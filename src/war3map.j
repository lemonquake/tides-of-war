function Trig_RA2_Actions takes nothing returns nothing
    set udg_RA_Integers[2] = 1
    loop
        exitwhen udg_RA_Integers[2] > udg_RA_Integers[1]
        if ( Trig_RA2_Func001Func001C() ) then
