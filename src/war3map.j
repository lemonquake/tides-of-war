//===========================================================================
// Trigger: Loop Spell
//
// This trigger should initially be 'off'
//===========================================================================
function Trig_Loop_Spell_Func001Func006Func002C takes nothing returns boolean
    if ( not ( UnitHasBuffBJ(udg_TargetUnit, 'B01L') == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_Loop_Spell_Func001Func006Func003Func003001002001 takes nothing returns boolean
    return ( GetUnitTypeId(GetFilterUnit()) == 'htow' )
endfunction

function Trig_Loop_Spell_Func001Func006Func003Func003001002002 takes nothing returns boolean
    return ( GetOwningPlayer(GetFilterUnit()) == udg_TempPlayer )
endfunction

function Trig_Loop_Spell_Func001Func006Func003Func003001002 takes nothing returns boolean
    return GetBooleanAnd( Trig_Loop_Spell_Func001Func006Func003Func003001002001(), Trig_Loop_Spell_Func001Func006Func003Func003001002002() )
endfunction

function Trig_Loop_Spell_Func001Func006Func003Func003A takes nothing returns nothing
    call UnitDamageTargetBJ( GetEnumUnit(), udg_TargetUnit, 2.00, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_FIRE )
endfunction

function Trig_Loop_Spell_Func001Func006Func003C takes nothing returns boolean
    if ( not ( IsUnitEnemy(udg_TargetUnit, udg_TempPlayer) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Loop_Spell_Func001Func006A takes nothing returns nothing
    set udg_TargetUnit = GetEnumUnit()
    if ( Trig_Loop_Spell_Func001Func006Func002C() ) then
        call CreateUnit(udg_TempPlayer, 'h005', GetUnitX(udg_TargetUnit), GetUnitY(udg_TargetUnit), bj_UNIT_FACING)
        call UnitAddAbilityBJ( 'A06I', GetLastCreatedUnit() )
        call IssueTargetOrderBJ( GetLastCreatedUnit(), "slow", udg_TargetUnit )
        call UnitApplyTimedLifeBJ( 1.00, 'BTLF', GetLastCreatedUnit() )
    else
    endif
    if ( Trig_Loop_Spell_Func001Func006Func003C() ) then
        set bj_wantDestroyGroup = true
        call ForGroupBJ( GetUnitsInRectMatching(gg_rct_hitman, Condition(function Trig_Loop_Spell_Func001Func006Func003Func003001002)), function Trig_Loop_Spell_Func001Func006Func003Func003A )
    else
    endif
endfunction

function Trig_Loop_Spell_Func001Func009Func005C takes nothing returns boolean
    if ( not ( IsUnitGroupEmptyBJ(udg_TesterSpell_Group) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Loop_Spell_Func001Func009C takes nothing returns boolean
    if ( not ( udg_TesterSpell_Duration[udg_ID] <= 0.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Loop_Spell_Func001A takes nothing returns nothing
    set udg_TempUnit = GetEnumUnit()
    set udg_ID = GetUnitUserData(udg_TempUnit)
    set udg_TempPlayer = GetOwningPlayer(udg_TempUnit)
    set udg_CenterPoint = GetUnitLoc(udg_TempUnit)
    set bj_wantDestroyGroup = true
    call ForGroupBJ( GetUnitsInRangeOfLocAll(udg_TesterSpell_Radius[udg_ID], udg_CenterPoint), function Trig_Loop_Spell_Func001Func006A )
    call RemoveLocation(udg_CenterPoint)
    set udg_TesterSpell_Duration[udg_ID] = ( udg_TesterSpell_Duration[udg_ID] - 0.03 )
    if ( Trig_Loop_Spell_Func001Func009C() ) then
        call DestroyEffectBJ( udg_TesterSpell_Effect[udg_ID] )
        call GroupRemoveUnitSimple( udg_TempUnit, udg_TesterSpell_Group )
        call RemoveUnit( udg_TempUnit )
        if ( Trig_Loop_Spell_Func001Func009Func005C() ) then
            call DisableTrigger( gg_trg_Loop_Spell )
        else
        endif
    else
    endif
endfunction

function Trig_Loop_Spell_Actions takes nothing returns nothing
    call ForGroupBJ( udg_TesterSpell_Group, function Trig_Loop_Spell_Func001A )
endfunction

//===========================================================================
function InitTrig_Loop_Spell takes nothing returns nothing
    set gg_trg_Loop_Spell = CreateTrigger(  )
    call DisableTrigger( gg_trg_Loop_Spell )
    call TriggerRegisterTimerEventPeriodic( gg_trg_Loop_Spell, 0.03 )
    call TriggerAddAction( gg_trg_Loop_Spell, function Trig_Loop_Spell_Actions )
endfunction

