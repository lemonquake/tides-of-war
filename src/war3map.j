// Trigger: Blessing
//===========================================================================
function Trig_Blessing_Func001C takes nothing returns boolean
    if ( not ( UnitHasBuffBJ(udg_GDD_DamagedUnit, 'B00L') == true ) ) then
        return false
    endif
    if ( not ( udg_GDD_Damage > 0.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Blessing_Conditions takes nothing returns boolean
    if ( not Trig_Blessing_Func001C() ) then
        return false
    endif
    return true
endfunction

function Trig_Blessing_Actions takes nothing returns nothing
    call SetUnitLifeBJ( udg_GDD_DamagedUnit, ( GetUnitStateSwap(UNIT_STATE_LIFE, udg_GDD_DamagedUnit) + udg_GDD_Damage ) )
    call CreateTextTagUnitBJ( "TRIGSTR_2892", udg_GDD_DamagedUnit, 0.00, 9.00, 100.00, 100.00, 100.00, 0 )
    call SetTextTagVelocityBJ( GetLastCreatedTextTag(), 120.00, GetRandomReal(70.00, 100.00) )
    call SetTextTagPermanentBJ( GetLastCreatedTextTag(), false )
    call SetTextTagLifespanBJ( GetLastCreatedTextTag(), udg_Text_Duration )
    call SetTextTagFadepointBJ( GetLastCreatedTextTag(), 0.65 )
endfunction

