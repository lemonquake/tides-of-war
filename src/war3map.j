    return true
endfunction

function Trig_TO_AW_eff_Actions takes nothing returns nothing
    set udg_AW1 = 1
    loop
        exitwhen udg_AW1 > udg_AW_Times
        if ( Trig_TO_AW_eff_Func001Func001C() ) then
            set udg_AW_Point[2] = GetUnitLoc(udg_AW_Caster[udg_AW1])
            set udg_AW_Point[3] = GetUnitLoc(udg_AW_Dummy[udg_AW1])
            set udg_AW_Point[4] = PolarProjectionBJ(udg_AW_Point[2], udg_AW_Distance_Attract_React[udg_AW1], udg_AW_Angle[udg_AW1])
            set udg_AW_Angle[udg_AW1] = ( udg_AW_Angle[udg_AW1] + udg_AW_SpinSpeed[udg_AW1] )
            if ( Trig_TO_AW_eff_Func001Func001Func006C() ) then
                set udg_AW_Angle[udg_AW1] = 0.00
            else
            endif
            call SetUnitPositionLocFacingBJ( udg_AW_Dummy[udg_AW1], udg_AW_Point[4], ( udg_AW_Angle[udg_AW1] + 90.00 ) )
            if ( Trig_TO_AW_eff_Func001Func001Func008C() ) then
                if ( Trig_TO_AW_eff_Func001Func001Func008Func003C() ) then
                    if ( Trig_TO_AW_eff_Func001Func001Func008Func003Func002C() ) then
                        set udg_AW_Steps[udg_AW1] = 1
                    else
                        set udg_AW_Height[udg_AW1] = ( udg_AW_Height[udg_AW1] - udg_AW_FallingSpeed[udg_AW1] )
                        call SetUnitFlyHeightBJ( udg_AW_Dummy[udg_AW1], udg_AW_Height[udg_AW1], 1000000000.00 )
                    endif
                else
                    if ( Trig_TO_AW_eff_Func001Func001Func008Func003Func001C() ) then
                        set udg_AW_ExpirationTime[udg_AW1] = ( udg_AW_ExpirationTime[udg_AW1] - 1 )
                        if ( Trig_TO_AW_eff_Func001Func001Func008Func003Func001Func002C() ) then
                            set udg_AW_StepLast[udg_AW1] = 1
                            set udg_AW_AT_REA_Debug[udg_AW1] = 0
                        else
                        endif
                        set udg_AW_Group[udg_AW1] = GetUnitsInRangeOfLocMatching(125.00, udg_AW_Point[4], Condition(function Trig_TO_AW_eff_Func001Func001Func008Func003Func001Func003002003))
                        if ( Trig_TO_AW_eff_Func001Func001Func008Func003Func001Func004C() ) then
                            set udg_AW_Off[udg_AW1] = false
                            set udg_AW_Damage[udg_AW1] = true
                            call DestroyEffectBJ( udg_AW_SpecialEffect1[udg_AW1] )
                            call DestroyEffectBJ( udg_AW_SpecialEffect2[udg_AW1] )
                            call UnitApplyTimedLifeBJ( 0.01, 'BTLF', udg_AW_Dummy[udg_AW1] )
                            set udg_AW_Dummy[udg_AW1] = GroupPickRandomUnit(udg_AW_Group[udg_AW1])
                            call UnitDamageTargetBJ( udg_AW_Caster[udg_AW1], udg_AW_Dummy[udg_AW1], 100.00, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_SONIC )
                            call AddSpecialEffectTargetUnitBJ( "chest", udg_AW_Dummy[udg_AW1], "Abilities\\Spells\\Undead\\FreezingBreath\\FreezingBreathMissile.mdl" )
                            call DestroyEffectBJ( GetLastCreatedEffectBJ() )
                        else
                        endif
                        call DestroyGroup(udg_AW_Group[udg_AW1])
                        if ( Trig_TO_AW_eff_Func001Func001Func008Func003Func001Func006C() ) then
                            if ( Trig_TO_AW_eff_Func001Func001Func008Func003Func001Func006Func001C() ) then
                                set udg_AW_AT_REA_Debug[udg_AW1] = 0
                            else
                                set udg_AW_Distance_Attract_React[udg_AW1] = ( udg_AW_Distance_Attract_React[udg_AW1] + udg_AW_AttractionSpeed_ReactionS_P[udg_AW1] )
                            endif
                        else
                            if ( Trig_TO_AW_eff_Func001Func001Func008Func003Func001Func006Func002C() ) then
                                set udg_AW_AT_REA_Debug[udg_AW1] = 1
                            else
                                set udg_AW_Distance_Attract_React[udg_AW1] = ( udg_AW_Distance_Attract_React[udg_AW1] - udg_AW_AttractionSpeed_ReactionS_P[udg_AW1] )
                            endif
                        endif
                    else
                    endif
                endif
            else
                if ( Trig_TO_AW_eff_Func001Func001Func008Func001C() ) then
                    if ( Trig_TO_AW_eff_Func001Func001Func008Func001Func001C() ) then
                        if ( Trig_TO_AW_eff_Func001Func001Func008Func001Func001Func001C() ) then
                            set udg_AW_Skip = ( udg_AW_Skip - 1 )
                            set udg_AW_Off[udg_AW1] = false
                            call DestroyEffectBJ( udg_AW_SpecialEffect1[udg_AW1] )
                            call DestroyEffectBJ( udg_AW_SpecialEffect2[udg_AW1] )
                            call UnitApplyTimedLifeBJ( 0.01, 'BTLF', udg_AW_Dummy[udg_AW1] )
                            if ( Trig_TO_AW_eff_Func001Func001Func008Func001Func001Func001Func006C() ) then
                                set udg_AW_Times = 0
                                call DisableTrigger( gg_trg_TO_AW_eff )
                            else
                            endif
                        else
                            set udg_AW_Height[udg_AW1] = ( udg_AW_Height[udg_AW1] + udg_AW_FallingSpeed[udg_AW1] )
                            call SetUnitFlyHeightBJ( udg_AW_Dummy[udg_AW1], udg_AW_Height[udg_AW1], 1000000000.00 )
                        endif
                    else
                        if ( Trig_TO_AW_eff_Func001Func001Func008Func001Func001Func003C() ) then
                            if ( Trig_TO_AW_eff_Func001Func001Func008Func001Func001Func003Func001C() ) then
                                set udg_AW_AT_REA_Debug[udg_AW1] = 1
                            else
                                set udg_AW_Distance_Attract_React[udg_AW1] = ( udg_AW_Distance_Attract_React[udg_AW1] - udg_AW_AttractionSpeed_ReactionS_P[udg_AW1] )
                            endif
                        else
                        endif
                    endif
                else
                endif
            endif
            call RemoveLocation(udg_AW_Point[2])
            call RemoveLocation(udg_AW_Point[3])
            call RemoveLocation(udg_AW_Point[4])
        else
            if ( Trig_TO_AW_eff_Func001Func001Func001C() ) then
                if ( Trig_TO_AW_eff_Func001Func001Func001Func001C() ) then
                    set udg_AW_Skip = ( udg_AW_Skip - 1 )
                    set udg_AW_Damage[udg_AW1] = false
                    if ( Trig_TO_AW_eff_Func001Func001Func001Func001Func004C() ) then
                        set udg_AW_Times = 0
                        call DisableTrigger( gg_trg_TO_AW_eff )
                    else
                    endif
                else
                    set udg_AW_Real_Damage_Time_Caa[udg_AW1] = ( udg_AW_Real_Damage_Time_Caa[udg_AW1] - 1 )
                    if ( Trig_TO_AW_eff_Func001Func001Func001Func001Func006C() ) then
                        set udg_AW_Damage_Time[udg_AW1] = ( udg_AW_Damage_Time[udg_AW1] - 1 )
                    else
                    endif
                endif
            else
            endif
        endif
        set udg_AW1 = udg_AW1 + 1
    endloop
endfunction

