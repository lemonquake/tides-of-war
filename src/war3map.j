    set udg_Sample_Point = GetUnitLoc(GetTriggerUnit())
    call CreateNUnitsAtLoc( 1, 'h005', GetOwningPlayer(GetTriggerUnit()), udg_Sample_Point, bj_UNIT_FACING )
