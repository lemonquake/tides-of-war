endfunction

//===========================================================================
// Trigger: Knockback Collider
//===========================================================================
function Trig_Knockback_Collider_Actions takes nothing returns nothing
    local unit u
    local real x
    local real y
    local integer i = udg_K2DNext[0]
    loop
        exitwhen i == 0
        set udg_TempUnit = udg_UDexUnits[i]
        set x = GetUnitX(udg_TempUnit)
        set y = GetUnitY(udg_TempUnit)
        call GroupEnumUnitsInRange(udg_LeaklessGroup, x, y, 160, null)
    call GroupRemoveUnitSimple( udg_TempUnit, udg_LeaklessGroup )
        loop
            set u = FirstOfGroup(udg_LeaklessGroup)
            exitwhen u == null
            call GroupRemoveUnit(udg_LeaklessGroup, u)
            if IsUnitInRange(u, udg_TempUnit, udg_K2DRadius[i] * 32) and IsUnitAlly(u, GetOwningPlayer(udg_TempUnit)) and not IsUnitType(u, UNIT_TYPE_DEAD) then
                set udg_Knockback2DUnit = u
                set udg_Knockback2DTime = udg_K2DTimeLeft[i]
                set udg_Knockback2DDistance = udg_K2DVelocity[i] / udg_K2DTimeout * udg_K2DTimeLeft[i] / 2
                set udg_Knockback2DAngle = bj_RADTODEG * Atan2(GetUnitY(u) - y, GetUnitX(u) - x)
    call TriggerExecute( gg_trg_Knockback_2D )
            endif
        endloop
        set i = udg_K2DNext[i]
    endloop
    set u = null
endfunction

