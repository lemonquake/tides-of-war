function Trig_Initialization_Func023001002001 takes nothing returns boolean
    return ( GetUnitTypeId(GetFilterUnit()) == 'htow' )
endfunction

function Trig_Initialization_Func023001002002 takes nothing returns boolean
    return ( GetOwningPlayer(GetFilterUnit()) == GetOwningPlayer(udg_DT_Dealers[udg_DT_Integers[3]]) )
endfunction

function Trig_Initialization_Func023001002 takes nothing returns boolean
    return GetBooleanAnd( Trig_Initialization_Func023001002001(), Trig_Initialization_Func023001002002() )
endfunction

function Trig_Initialization_Func023A takes nothing returns nothing
    set udg_Unit[GetConvertedPlayerId(GetOwningPlayer(GetEnumUnit()))] = GetEnumUnit()
endfunction

function Trig_Initialization_Func025A takes nothing returns nothing
    call SetPlayerAbilityAvailableBJ( false, 'A061', GetEnumPlayer() )
    set udg_Kill_P = GetConvertedPlayerId(GetEnumPlayer())
    set udg_Kill_Limit[udg_Kill_P] = 50
    call SetPlayerFlagBJ( PLAYER_STATE_GIVES_BOUNTY, true, GetEnumPlayer() )
    call SetPlayerStateBJ( GetEnumPlayer(), PLAYER_STATE_RESOURCE_GOLD, 700 )
    call PanCameraToTimedForPlayer(GetEnumPlayer(), GetRectCenterX(gg_rct_InitialView), GetRectCenterY(gg_rct_InitialView), 0)
    call CreateFogModifierRectBJ( true, GetEnumPlayer(), FOG_OF_WAR_VISIBLE, gg_rct_InitialView )
endfunction

